{
  "name": "schooltrustlands-encyclopedia",
  "type": "module",
  "version": "0.0.1",
  "description": "America's School Trust Library — an evidentiary archive of America's school trust lands and funds.",
  "scripts": {
    "dev": "npm run build:data && astro dev",
    "start": "npm run build:data && astro dev",
    "build": "npm run build:data && astro build && pagefind --site dist",
    "preview": "astro preview",
    "build:data": "node scripts/build-map-layers.mjs && node scripts/build-finance-data.mjs",
    "build:layers": "node scripts/build-map-layers.mjs",
    "build:finance": "node scripts/build-finance-data.mjs",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/tailwind": "^6.0.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.3",
    "astro": "^5.18.1",
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.4.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "pagefind": "^1.5.2"
  }
}

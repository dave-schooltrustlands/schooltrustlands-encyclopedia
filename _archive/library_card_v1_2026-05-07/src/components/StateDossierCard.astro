---
// Top-of-page dossier card for state entries. Distinct from the
// right-rail StateDossier component (which lists library cross-links
// alongside the article). This card frames the entry: why the state
// matters, what's actively contested, and where to find the state in
// each library room. Editorial copy (summary, currentIssue) lives in
// state frontmatter; absent overrides hydrate from the era / admission
// / governance / grant fields so every state's card reads as functional.

interface Props {
  iso: string; // lowercase, e.g. "us-or"
  name: string;
  admittedDate: Date;
  eraName: string;
  governanceForm: string;
  federalGrantAcres: number | null;
  summary?: string;
  currentIssue?: string;
}

const {
  iso,
  name,
  admittedDate,
  eraName,
  governanceForm,
  federalGrantAcres,
  summary,
  currentIssue,
} = Astro.props;

const num = new Intl.NumberFormat('en-US');

function formatAcres(n: number): string {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1).replace(/\.0$/, '')} million acres`;
  return `${num.format(n)} acres`;
}

const admittedYear = admittedDate.getUTCFullYear();
const grantAcres = federalGrantAcres ?? 0;
const grantClause =
  grantAcres > 0
    ? `It received ${formatAcres(grantAcres)} in federal school-land grants at admission.`
    : 'It is a state-derived state — no federal school-land grant at admission.';

const fallbackSummary = `${name} entered the Union in ${admittedYear} (${eraName} cohort) with a ${governanceForm} school-trust structure. ${grantClause}`;
const resolvedSummary = summary && summary.trim().length > 0 ? summary : fallbackSummary;
const resolvedIssue = currentIssue && currentIssue.trim().length > 0 ? currentIssue : '—';
---

<section
  class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm sm:p-6"
  aria-labelledby={`dossier-card-${iso}-heading`}
>
  <p
    id={`dossier-card-${iso}-heading`}
    class="text-xs font-semibold uppercase tracking-wide text-slate-500"
  >
    State dossier
  </p>

  <div class="mt-3">
    <h2 class="text-base font-semibold tracking-tight text-slate-800">Why this state matters</h2>
    <p class="mt-1 text-slate-700">{resolvedSummary}</p>
  </div>

  <div class="mt-4">
    <h2 class="text-base font-semibold tracking-tight text-slate-800">Current issue</h2>
    <p class="mt-1 text-slate-700">{resolvedIssue}</p>
  </div>

  <div class="mt-4">
    <h2 class="text-base font-semibold tracking-tight text-slate-800">Find this state in</h2>
    <ul class="mt-2 space-y-1 text-sm">
      <li>
        <span class="font-medium text-slate-700">The Atlas:</span>{' '}
        <a href="/atlas/" class="text-blue-700 underline hover:text-blue-900">era cohort lens</a>
        <span class="text-slate-400"> · </span>
        <a href="/atlas/" class="text-blue-700 underline hover:text-blue-900">transparency lens</a>
      </li>
      <li>
        <span class="font-medium text-slate-700">The Counting House:</span>{' '}
        <a href={`/counting/${iso}/`} class="text-blue-700 underline hover:text-blue-900">financial card</a>
      </li>
      <li>
        <span class="font-medium text-slate-700">The Court Room:</span>{' '}
        <span class="text-slate-500">opening later</span>
      </li>
      <li>
        <span class="font-medium text-slate-700">The Records Room:</span>{' '}
        <span class="text-slate-500">opening later</span>
      </li>
      <li>
        <span class="font-medium text-slate-700">Breach &amp; Recovery:</span>{' '}
        <span class="text-slate-500">opening later</span>
      </li>
    </ul>
  </div>
</section>

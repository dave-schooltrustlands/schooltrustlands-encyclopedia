---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  sourceId?: string;
}

const { title, description, sourceId } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body
    class="min-h-screen bg-archive-paper text-ink"
    data-source-id={sourceId}
  >
    <Header />
    <main class="mx-auto max-w-prose p-4 sm:p-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>

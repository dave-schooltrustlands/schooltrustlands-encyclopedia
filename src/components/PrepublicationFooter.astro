---
// PrepublicationFooter.astro
//
// Site-wide preview footer. A thin strip carrying the public-preview reminder
// at the very bottom of every page. The per-chapter PrepublicationBanner is
// separate and remains governed by the book-draft PREPUBLICATION flag.
//
// Controlled by SITE_PREVIEW. When the Library board adopts the site as the
// Library publication, that one flag removes the footer and the top preview
// strip together.

import { SITE_PREVIEW } from '../site.config';
---

{SITE_PREVIEW && (
  <div
    class="prepublication-footer"
    role="note"
    aria-label="Preview publication notice"
    data-pagefind-ignore
  >
    <p>
      <span class="prepublication-footer__icon" aria-hidden="true">⚠</span>
      Preview publication — cite the linked primary sources;
      interpretive framing is provisional.
    </p>
  </div>
)}

<style>
  /* Slim parchment-on-amber strip. Same palette family as the chapter
     banner (v24) so the two surfaces read as one warning system. Darker
     amber top border separates the strip from page content above. */
  .prepublication-footer {
    background: #FBF1D2; /* parchment-amber */
    border-top: 1px solid #B45309; /* amber-700, slightly darker than banner */
    color: #92400E; /* amber-800 caution text */
    font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
    font-size: 0.85rem;
    line-height: 1.4;
    text-align: center;
    padding: 0.55rem 1rem;
    min-height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .prepublication-footer p {
    margin: 0;
    font-weight: 500;
  }

  .prepublication-footer__icon {
    display: inline-block;
    margin-right: 0.4rem;
    color: #B45309; /* amber-700 */
  }

  @media (max-width: 640px) {
    .prepublication-footer {
      font-size: 0.78rem;
      min-height: 2.1rem;
      padding: 0.45rem 0.75rem;
    }
  }
</style>

---
// Site Update v43 — Newsroom Buttondown embed subscribe form.
//
// Subscriptions go directly to Buttondown (list: treebook).
// Single email field; inline form; tagged web_signup so Buttondown
// can distinguish from the seed_list_2026-05-12 import set.
// Replaces the v42 Supabase-backed signup; the old /api/newsroom-subscribe
// route and newsroom_subscribers table remain in place but dormant.
---

<form
  class="newsroom-subscribe"
  action="https://buttondown.com/api/emails/embed-subscribe/treebook"
  method="post"
  target="popupwindow"
  onsubmit="window.open('https://buttondown.com/treebook', 'popupwindow')"
>
  <label class="newsroom-subscribe__field" for="bd-email">
    <span class="newsroom-subscribe__label">Your email</span>
    <input
      type="email"
      id="bd-email"
      name="email"
      placeholder="you@example.com"
      autocomplete="email"
      required
    />
  </label>
  <input type="hidden" name="tag" value="web_signup" />
  <input type="hidden" name="embed" value="1" />
  <button type="submit" class="newsroom-subscribe__submit">
    Subscribe
  </button>
</form>

<style>
  .newsroom-subscribe {
    margin: 1.25rem 0 1.75rem;
    padding: 1.25rem 1.5rem;
    background: var(--linen-card, #fffdf7);
    border: 1px solid var(--rule-border, #d8d1c2);
    border-left: 3px solid var(--old-gold, #b88a2e);
    border-radius: 4px;
    font-family: var(--font-sans);
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 0.85rem;
  }
  .newsroom-subscribe__field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1 1 16rem;
    min-width: 0;
  }
  .newsroom-subscribe__label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--deep-navy, #1f2a44);
    letter-spacing: 0.02em;
  }
  .newsroom-subscribe input[type='email'] {
    font-family: inherit;
    font-size: 0.95rem;
    padding: 0.5rem 0.65rem;
    border: 1px solid #cbd5e1;
    border-radius: 3px;
    background: #fff;
    color: var(--ink, #17202a);
    min-height: 40px;
    width: 100%;
    box-sizing: border-box;
  }
  .newsroom-subscribe input:focus {
    outline: 2px solid var(--trust-blue, #1d4f7c);
    outline-offset: 1px;
    border-color: var(--trust-blue, #1d4f7c);
  }
  .newsroom-subscribe__submit {
    background: var(--deep-navy, #1f2a44);
    color: var(--linen-card, #fffdf7);
    border: 0;
    padding: 0.55rem 1.2rem;
    border-radius: 3px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    min-height: 40px;
    flex: 0 0 auto;
  }
  .newsroom-subscribe__submit:hover {
    background: var(--trust-blue, #1d4f7c);
  }
</style>

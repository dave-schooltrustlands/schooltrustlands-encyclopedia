---
/**
 * VisualDensitySlider
 *
 * Three-position segmented control (Reference / Standard / Library) that
 * sets a single body class — mode-reference | mode-standard | mode-library —
 * and persists the choice in localStorage under "library-visual-density".
 *
 * Server-rendered default: Standard. Per-mode visual rules live in
 * mode-reference.css / mode-standard.css / mode-library.css (other agents).
 *
 * Mounts in the site header. No props. Self-contained: own <style> + <script>.
 */
---
<script is:inline>
  /* Early-paint script: rewrite body.mode-* before first paint to avoid
     a flash of mode-standard for visitors whose stored preference is
     reference or library. Runs as soon as parsed; if <body> isn't there
     yet, defers to DOMContentLoaded. */
  (function () {
    try {
      var v = localStorage.getItem('library-visual-density');
      if (!v || (v !== 'reference' && v !== 'standard' && v !== 'library')) v = 'standard';
      var apply = function (b) {
        if (!b) return;
        b.classList.remove('mode-reference', 'mode-standard', 'mode-library');
        b.classList.add('mode-' + v);
      };
      if (document.body) {
        apply(document.body);
      } else {
        document.addEventListener('DOMContentLoaded', function () {
          apply(document.body);
        });
      }
    } catch (e) {
      /* default mode-standard already on body via BaseLayout */
    }
  })();
</script>

<div
  class="vds-wrap"
  data-density-slider
>
  <div
    class="vds-pill"
    role="radiogroup"
    aria-label="Visual density mode"
  >
    <button
      type="button"
      role="radio"
      class="vds-seg"
      data-mode="reference"
      aria-checked="false"
      tabindex="-1"
    >Reference</button>
    <span class="vds-hairline" aria-hidden="true"></span>
    <button
      type="button"
      role="radio"
      class="vds-seg is-active"
      data-mode="standard"
      aria-checked="true"
      tabindex="0"
    >Standard</button>
    <span class="vds-hairline" aria-hidden="true"></span>
    <button
      type="button"
      role="radio"
      class="vds-seg"
      data-mode="library"
      aria-checked="false"
      tabindex="-1"
    >Library</button>
  </div>
  <div
    class="vds-tooltip"
    data-density-tooltip
    hidden
    aria-hidden="true"
  >Choose how visual you want the Library to feel.</div>
  <div
    class="vds-sr"
    data-density-live
    role="status"
    aria-live="polite"
    aria-atomic="true"
  ></div>
</div>

<style>
  .vds-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .vds-pill {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--rule-border);
    border-radius: 999px;
    background: transparent;
    overflow: hidden;
    min-height: 36px;
    line-height: 1;
    font-family: var(--font-sans);
  }

  .vds-seg {
    appearance: none;
    background: transparent;
    border: 0;
    margin: 0;
    padding: 6px 12px;
    min-width: 44px;
    min-height: 24px;
    font: inherit;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--deep-navy);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background-color 120ms ease, color 120ms ease;
  }

  .vds-seg:hover:not(.is-active) {
    background: rgba(31, 42, 68, 0.06);
  }

  .vds-seg:focus-visible {
    outline: 2px solid var(--trust-blue);
    outline-offset: 2px;
    border-radius: 999px;
  }

  .vds-seg.is-active {
    background: var(--deep-navy);
    color: var(--linen-card);
  }

  .vds-hairline {
    width: 1px;
    background: var(--rule-border);
    align-self: stretch;
    flex: 0 0 1px;
  }

  /* Hairlines bordering the active segment fade so the active fill reads
     as a solid pill end. */
  .vds-seg.is-active + .vds-hairline,
  .vds-seg.is-active {
    /* nothing extra needed visually, kept for clarity */
  }

  .vds-tooltip {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--linen-card);
    color: var(--deep-navy);
    border: 1px solid var(--rule-border);
    border-radius: 6px;
    padding: 8px 12px;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    line-height: 1.35;
    white-space: nowrap;
    box-shadow: 0 6px 18px rgba(31, 42, 68, 0.12);
    z-index: 50;
    pointer-events: none;
  }

  .vds-tooltip::before {
    content: '';
    position: absolute;
    top: -6px;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 10px;
    height: 10px;
    background: var(--linen-card);
    border-left: 1px solid var(--rule-border);
    border-top: 1px solid var(--rule-border);
  }

  .vds-sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Mobile: under 480px, the slider drops below the wordmark in its own
     full-width row with equal-segment buttons. The header flex-wrap will
     already break the slider onto its own row; we just expand it. */
  @media (max-width: 479px) {
    .vds-wrap {
      width: 100%;
      display: flex;
      justify-content: stretch;
    }
    .vds-pill {
      width: 100%;
    }
    .vds-seg {
      flex: 1 1 0;
    }
    .vds-tooltip {
      white-space: normal;
      max-width: 90vw;
    }
  }
</style>

<script is:inline>
  (function () {
    var MODES = ['reference', 'standard', 'library'];
    var STORAGE_KEY = 'library-visual-density';
    var TOOLTIP_KEY = 'library-density-tooltip-dismissed';
    var TOOLTIP_TIMEOUT_MS = 6000;

    function init() {
      var wraps = document.querySelectorAll('[data-density-slider]');
      wraps.forEach(function (wrap) { wireOne(wrap); });
    }

    function wireOne(wrap) {
      var segs = wrap.querySelectorAll('.vds-seg');
      var live = wrap.querySelector('[data-density-live]');
      var tooltip = wrap.querySelector('[data-density-tooltip]');

      function readStored() {
        try {
          var v = localStorage.getItem(STORAGE_KEY);
          if (v === 'reference' || v === 'standard' || v === 'library') return v;
        } catch (_) { /* ignore */ }
        return 'standard';
      }

      function applyMode(mode, opts) {
        opts = opts || {};
        var b = document.body;
        if (b) {
          b.classList.remove('mode-reference', 'mode-standard', 'mode-library');
          b.classList.add('mode-' + mode);
        }
        segs.forEach(function (s) {
          var active = s.getAttribute('data-mode') === mode;
          s.classList.toggle('is-active', active);
          s.setAttribute('aria-checked', active ? 'true' : 'false');
          s.setAttribute('tabindex', active ? '0' : '-1');
        });
        if (opts.persist) {
          try { localStorage.setItem(STORAGE_KEY, mode); } catch (_) { /* ignore */ }
        }
        if (opts.announce && live) {
          var label = mode.charAt(0).toUpperCase() + mode.slice(1);
          live.textContent = 'Mode set to ' + label + '.';
        }
      }

      function dismissTooltip(permanent) {
        if (!tooltip) return;
        tooltip.hidden = true;
        if (permanent) {
          try { localStorage.setItem(TOOLTIP_KEY, '1'); } catch (_) { /* ignore */ }
        }
      }

      function maybeShowTooltip() {
        if (!tooltip) return;
        try {
          if (localStorage.getItem(TOOLTIP_KEY) === '1') return;
        } catch (_) { /* if storage fails, just don't show */ return; }
        tooltip.hidden = false;
        tooltip.setAttribute('aria-hidden', 'false');
        setTimeout(function () { dismissTooltip(true); }, TOOLTIP_TIMEOUT_MS);
      }

      // Sync visible state to whatever the early-paint script applied.
      applyMode(readStored(), { persist: false, announce: false });

      // Click handling — also dismisses tooltip permanently.
      segs.forEach(function (seg) {
        seg.addEventListener('click', function () {
          var mode = seg.getAttribute('data-mode');
          if (!mode) return;
          applyMode(mode, { persist: true, announce: true });
          dismissTooltip(true);
          seg.focus();
        });
      });

      // Roving tabindex + arrow-key navigation per the radiogroup pattern.
      wrap.addEventListener('keydown', function (ev) {
        var target = ev.target;
        if (!(target instanceof HTMLElement) || !target.classList.contains('vds-seg')) return;
        var key = ev.key;
        var current = target.getAttribute('data-mode') || 'standard';
        var idx = MODES.indexOf(current);
        if (idx < 0) idx = 1;

        if (key === 'ArrowRight' || key === 'ArrowDown') {
          ev.preventDefault();
          idx = (idx + 1) % MODES.length;
        } else if (key === 'ArrowLeft' || key === 'ArrowUp') {
          ev.preventDefault();
          idx = (idx - 1 + MODES.length) % MODES.length;
        } else if (key === 'Home') {
          ev.preventDefault();
          idx = 0;
        } else if (key === 'End') {
          ev.preventDefault();
          idx = MODES.length - 1;
        } else if (key === ' ' || key === 'Enter' || key === 'Spacebar') {
          ev.preventDefault();
          applyMode(current, { persist: true, announce: true });
          dismissTooltip(true);
          return;
        } else {
          return;
        }

        var nextMode = MODES[idx];
        applyMode(nextMode, { persist: true, announce: true });
        dismissTooltip(true);
        var nextSeg = wrap.querySelector('.vds-seg[data-mode="' + nextMode + '"]');
        if (nextSeg) nextSeg.focus();
      });

      maybeShowTooltip();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

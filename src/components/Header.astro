---
import '../styles/global.css';
import NavIcon from './NavIcon.astro';
import WalkingTour from './library/WalkingTour.astro';

// v38 — header search rebuilt:
//   - The Pagefind-UI dropdown panel and #search-toggle buttons are gone.
//   - The header carries a plain <form action="/search/" method="get">
//     with a single <input name="q">. Pressing Enter (or tapping the
//     button) navigates to /search/?q=<query>, where a full-width
//     results page handles rendering. The narrow right-pinned dropdown
//     that v37 left in place is retired.
//
// v36 — header simplified:
//   - View toggle (VisualDensitySlider) and LibraryV1Banner removed.
//   - Mobile nav replaced with a hamburger overlay.

const NAV_LINKS = [
  { href: '/start/', label: 'Start Here' },
  { href: '/explore/', label: 'Explore' },
  { href: '/why/', label: 'Why' },
  { href: '/reading/', label: 'Reading', icon: 'BookOpen' },
  { href: '/atlas/', label: 'Atlas', icon: 'Compass' },
  { href: '/maps/', label: 'Map Room', icon: 'Map' },
  { href: '/counting/', label: 'Counting House', icon: 'ScrollText' },
  { href: '/contribute/', label: 'Contribute', icon: 'HandHeart' },
  { href: '/about/', label: 'About', icon: 'Building2' },
  { href: '/newsroom/', label: 'Newsroom', icon: 'Newspaper' },
  { href: '/pro/', label: 'Pro', icon: 'Building2' },
  { href: '/updates/', label: 'Updates' },
  { href: '/voices/', label: 'Voices', icon: 'Mic' },
];
---
<header
  data-pagefind-ignore
  class="sticky top-0 z-40 border-b border-slate-200 bg-white/95 backdrop-blur"
>
  <div class="mx-auto flex max-w-5xl flex-wrap items-center gap-3 px-4 py-3 sm:gap-4">
    <a href="/" class="site-wordmark mr-auto min-h-[44px]">
      <svg
        class="plss-mark"
        viewBox="0 0 60 60"
        aria-hidden="true"
      >
        <!--
          6×6 township grid. Sections numbered boustrophedon-style starting
          top-right; Section 16 is dead center (geographically correct).
          Section 36 (lower-left) is highlighted at reduced opacity for
          post-1848 states that received both Sections 16 and 36.
        -->
        <g fill="none" stroke="currentColor" stroke-width="1" opacity="0.55">
          <rect x="0" y="0" width="60" height="60"></rect>
          <line x1="10" y1="0" x2="10" y2="60"></line>
          <line x1="20" y1="0" x2="20" y2="60"></line>
          <line x1="30" y1="0" x2="30" y2="60"></line>
          <line x1="40" y1="0" x2="40" y2="60"></line>
          <line x1="50" y1="0" x2="50" y2="60"></line>
          <line x1="0" y1="10" x2="60" y2="10"></line>
          <line x1="0" y1="20" x2="60" y2="20"></line>
          <line x1="0" y1="30" x2="60" y2="30"></line>
          <line x1="0" y1="40" x2="60" y2="40"></line>
          <line x1="0" y1="50" x2="60" y2="50"></line>
        </g>
        <rect x="30" y="20" width="10" height="10" fill="var(--old-gold)" opacity="0.9"></rect>
        <rect x="0" y="50" width="10" height="10" fill="var(--old-gold)" opacity="0.55"></rect>
      </svg>
      <span class="wordmark-text">
        <strong>America's School Trust Library</strong>
        <em>An evidentiary archive of America's school trust lands and funds</em>
      </span>
    </a>

    {/* Desktop nav — visible at lg+, hidden at smaller widths so the
        wordmark + hamburger + search fit on a single mobile row. */}
    <nav class="hidden flex-wrap items-center gap-x-1 gap-y-2 text-sm lg:flex sm:gap-x-3">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center px-2 text-blue-700 hover:underline"
        >
          {link.icon && <NavIcon name={link.icon} />}
          {link.label.replace(/ /g, ' ')}
        </a>
      ))}
      <a
        id="library-card-link"
        href="/library-card/"
        class="library-card-link inline-flex min-h-[36px] items-center justify-center px-2 text-blue-700 hover:underline"
        data-default-href="/library-card/"
        data-default-label="Library Card"
        >Library&nbsp;Card</a
      >
      <a
        id="library-card-signout"
        href="/auth/sign-out"
        hidden
        class="library-card-signout inline-flex min-h-[36px] items-center justify-center px-2 text-slate-500 hover:text-slate-700 hover:underline"
        >Sign&nbsp;out</a
      >
      <form
        action="/search/"
        method="get"
        role="search"
        class="header-search header-search--desktop"
        aria-label="Search the Library"
      >
        <label class="sr-only" for="header-search-input">Search the Library</label>
        <input
          id="header-search-input"
          type="search"
          name="q"
          placeholder="Search…"
          autocomplete="off"
          spellcheck="false"
          aria-label="Search the Library"
          class="header-search__input"
        />
        <button
          type="submit"
          class="header-search__submit"
          aria-label="Submit search"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </button>
      </form>
    </nav>

    {/* Mobile controls — visible below lg. Search input + hamburger.
        Hamburger opens a full overlay with the complete nav. */}
    <div class="flex items-center gap-1 lg:hidden">
      <form
        action="/search/"
        method="get"
        role="search"
        class="header-search header-search--mobile"
        aria-label="Search the Library"
      >
        <label class="sr-only" for="header-search-input-mobile">Search the Library</label>
        <input
          id="header-search-input-mobile"
          type="search"
          name="q"
          placeholder="Search…"
          autocomplete="off"
          spellcheck="false"
          aria-label="Search the Library"
          class="header-search__input header-search__input--mobile"
        />
        <button
          type="submit"
          class="header-search__submit header-search__submit--mobile"
          aria-label="Submit search"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </button>
      </form>
      <button
        id="mobile-nav-toggle"
        type="button"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav-overlay"
        class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded text-slate-700 hover:bg-slate-100"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<div
  id="mobile-nav-overlay"
  class="mobile-nav-overlay"
  data-state="closed"
  aria-hidden="true"
>
  <div class="mobile-nav-overlay__scrim" data-mobile-nav-scrim></div>
  <nav
    class="mobile-nav-overlay__panel"
    aria-label="Site navigation"
    data-mobile-nav-panel
  >
    <div class="mobile-nav-overlay__header">
      <span class="mobile-nav-overlay__title">Menu</span>
      <button
        type="button"
        class="mobile-nav-overlay__close"
        data-mobile-nav-close
        aria-label="Close navigation menu"
      >×</button>
    </div>
    <ul class="mobile-nav-overlay__list">
      {NAV_LINKS.map((link) => (
        <li>
          <a href={link.href} class="mobile-nav-overlay__link">
            {link.icon && <NavIcon name={link.icon} />}
            <span>{link.label}</span>
          </a>
        </li>
      ))}
      <li class="mobile-nav-overlay__divider"></li>
      <li>
        <a
          id="library-card-link-mobile"
          href="/library-card/"
          class="library-card-link mobile-nav-overlay__link"
          data-default-href="/library-card/"
          data-default-label="Library Card"
          >Library Card</a
        >
      </li>
      <li>
        <a
          id="library-card-signout-mobile"
          href="/auth/sign-out"
          hidden
          class="library-card-signout mobile-nav-overlay__link mobile-nav-overlay__link--muted"
          >Sign out</a
        >
      </li>
    </ul>
  </nav>
</div>

<WalkingTour />

<style is:global>
  /* v38 — header search input/button. Replaces the v35-era Pagefind
     dropdown panel. The form submits to /search/?q= where a full-width
     results page handles rendering. */
  .header-search {
    display: inline-flex;
    align-items: stretch;
    gap: 0;
    min-height: 36px;
  }
  .header-search--desktop {
    min-width: 0;
  }
  .header-search__input {
    min-width: 0;
    width: 11rem;
    padding: 0.35rem 0.6rem;
    font-size: 0.875rem;
    line-height: 1.3;
    border: 1px solid #cbd5e1;
    border-right: 0;
    border-top-left-radius: 4px;
    border-bottom-left-radius: 4px;
    background: #fff;
    color: #0f172a;
  }
  .header-search__input:focus {
    outline: 2px solid #1d4ed8;
    outline-offset: 1px;
    border-color: #1d4ed8;
  }
  .header-search__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    min-width: 40px;
    padding: 0 0.5rem;
    background: #1e3a5f;
    color: #ffd07a;
    border: 1px solid #1e3a5f;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    cursor: pointer;
  }
  .header-search__submit:hover {
    background: #16304f;
  }
  /* Mobile header search — compact, sits between hamburger and wordmark.
     Min 44px tap target on the submit button. */
  .header-search__input--mobile {
    width: 8rem;
    font-size: 0.85rem;
  }
  .header-search__submit--mobile {
    min-height: 44px;
    min-width: 44px;
  }
  @media (max-width: 380px) {
    .header-search__input--mobile {
      width: 6rem;
    }
  }

  /* v36 — full-overlay mobile navigation. */
  .mobile-nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 80;
    pointer-events: none;
    opacity: 0;
    transition: opacity 150ms ease;
  }
  .mobile-nav-overlay[data-state='open'] {
    pointer-events: auto;
    opacity: 1;
  }
  .mobile-nav-overlay__scrim {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.5);
  }
  .mobile-nav-overlay__panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(20rem, 88vw);
    background: #fff;
    border-left: 1px solid #e5e7eb;
    box-shadow: -8px 0 24px rgba(15, 23, 42, 0.12);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 200ms ease;
    overflow-y: auto;
  }
  .mobile-nav-overlay[data-state='open'] .mobile-nav-overlay__panel {
    transform: translateX(0);
  }
  .mobile-nav-overlay__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid #e5e7eb;
  }
  .mobile-nav-overlay__title {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #475569;
  }
  .mobile-nav-overlay__close {
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid #e5e7eb;
    background: #fff;
    border-radius: 4px;
    font-size: 1.5rem;
    line-height: 1;
    color: #1e3a5f;
    cursor: pointer;
  }
  .mobile-nav-overlay__close:hover {
    background: #f8fafc;
  }
  .mobile-nav-overlay__list {
    list-style: none;
    margin: 0;
    padding: 0.4rem 0;
    flex: 1 1 auto;
  }
  .mobile-nav-overlay__divider {
    height: 1px;
    background: #e5e7eb;
    margin: 0.4rem 0;
  }
  .mobile-nav-overlay__link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    min-height: 44px;
    padding: 0.6rem 1rem;
    color: #1d4ed8;
    text-decoration: none;
    font-size: 0.95rem;
  }
  .mobile-nav-overlay__link:hover {
    background: #f1f5f9;
    text-decoration: underline;
  }
  .mobile-nav-overlay__link--muted {
    color: #64748b;
  }
  /* When the body has mobile-nav-open, lock scroll. */
  body.mobile-nav-open {
    overflow: hidden;
  }
</style>

<script>
  // Header login-state hydration: when a Library Card holder is signed in,
  // the "Library Card" nav link rewrites to "My Library" and the hidden
  // "Sign out" link reveals. v36: the link is mounted in the desktop nav
  // and inside the mobile-nav overlay; hydration updates both copies so
  // either is correct regardless of viewport.
  import { getBrowserSupabase } from '../lib/supabase';

  (async () => {
    const links = [
      document.getElementById('library-card-link'),
      document.getElementById('library-card-link-mobile'),
    ].filter((el): el is HTMLElement => el !== null);
    const signouts = [
      document.getElementById('library-card-signout'),
      document.getElementById('library-card-signout-mobile'),
    ].filter((el): el is HTMLElement => el !== null);
    if (links.length === 0 || signouts.length === 0) return;
    try {
      const supabase = getBrowserSupabase();
      const {
        data: { user },
      } = await supabase.auth.getUser();
      if (user) {
        for (const link of links) {
          link.setAttribute('href', '/my-library/');
          link.textContent = 'My Library';
        }
        for (const signout of signouts) {
          signout.removeAttribute('hidden');
        }
      }
    } catch (_) {
      // Silently leave the default logged-out state on any failure.
    }
  })();
</script>
<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    // v36 — mobile-nav overlay. Hamburger opens a full overlay; ESC and
    // click-on-scrim close it. The body picks up `.mobile-nav-open` while
    // the overlay is open to prevent background scroll.
    const overlay = document.getElementById('mobile-nav-overlay');
    const toggleBtn = document.getElementById('mobile-nav-toggle');
    const closeBtn = overlay
      ? overlay.querySelector('[data-mobile-nav-close]')
      : null;
    const scrim = overlay
      ? overlay.querySelector('[data-mobile-nav-scrim]')
      : null;

    function setOverlay(open) {
      if (!overlay || !toggleBtn) return;
      overlay.setAttribute('data-state', open ? 'open' : 'closed');
      overlay.setAttribute('aria-hidden', open ? 'false' : 'true');
      toggleBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
      document.body.classList.toggle('mobile-nav-open', open);
      if (open) {
        // Focus the close button so keyboard users can dismiss it.
        const c = overlay.querySelector('[data-mobile-nav-close]');
        if (c && typeof c.focus === 'function') c.focus();
      }
    }

    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        const isOpen = overlay && overlay.getAttribute('data-state') === 'open';
        setOverlay(!isOpen);
      });
    }
    if (closeBtn) closeBtn.addEventListener('click', () => setOverlay(false));
    if (scrim) scrim.addEventListener('click', () => setOverlay(false));
    document.addEventListener('keydown', (ev) => {
      if (ev.key !== 'Escape') return;
      if (overlay && overlay.getAttribute('data-state') === 'open') {
        setOverlay(false);
        if (toggleBtn && typeof toggleBtn.focus === 'function') toggleBtn.focus();
      }
    });
    // Close the overlay when a nav link is activated so the destination
    // page lands without the overlay still occluding it.
    if (overlay) {
      overlay.addEventListener('click', (ev) => {
        const target =
          ev.target instanceof Element ? ev.target.closest('a') : null;
        if (target) setOverlay(false);
      });
    }

    // ?q= fallback for browsers without Text Fragment support: walk text
    // nodes in <main> and wrap case-insensitive matches in <mark>. Modern
    // browsers (those with document.fragmentDirective) get the native
    // ::target-text highlight from the URL hash and don't need this.
    const params = new URLSearchParams(window.location.search);
    const q = (params.get('q') || '').trim();
    // Skip the highlight walker on /search/ — that page owns its own
    // result rendering and uses Pagefind's <mark> in excerpts.
    const onSearchPage = window.location.pathname === '/search/' ||
      window.location.pathname === '/search';
    if (q && !onSearchPage && !('fragmentDirective' in document)) {
      const root = document.querySelector('main');
      if (root) {
        const terms = q
          .split(/\s+/)
          .filter((t) => t.length > 1)
          .map((t) => t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
        if (terms.length > 0) {
          const re = new RegExp(`(${terms.join('|')})`, 'gi');
          const skip = new Set(['SCRIPT', 'STYLE', 'MARK', 'CODE', 'PRE']);
          const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
            acceptNode(node) {
              if (!node.parentElement) return NodeFilter.FILTER_REJECT;
              if (skip.has(node.parentElement.tagName)) return NodeFilter.FILTER_REJECT;
              return re.test(node.nodeValue || '')
                ? NodeFilter.FILTER_ACCEPT
                : NodeFilter.FILTER_REJECT;
            },
          });
          const targets = [];
          let n;
          while ((n = walker.nextNode())) targets.push(n);
          let firstMark = null;
          for (const node of targets) {
            const span = document.createElement('span');
            span.innerHTML = (node.nodeValue || '').replace(
              re,
              '<mark>$1</mark>',
            );
            if (!firstMark) firstMark = span.querySelector('mark');
            node.parentNode.replaceChild(span, node);
          }
          if (firstMark) {
            firstMark.scrollIntoView({ behavior: 'auto', block: 'center' });
          }
        }
      }
    }
  });
</script>

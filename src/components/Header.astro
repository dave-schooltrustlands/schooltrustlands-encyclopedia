---
import '../styles/global.css';
import NavIcon from './NavIcon.astro';
import WalkingTour from './library/WalkingTour.astro';

// v55 — Navigation Direction B:
//   - Library rooms (Reading, Atlas, Map Room, Counting House) pulled
//     into a new "Rooms ▾" disclosure (parallel to v50's "More ▾").
//   - Three future-room placeholders (Records Room, Court Room, Breach
//     & Recovery) shown below a divider as "coming soon."
//   - When the reader is on a library page, the Rooms ▾ trigger picks
//     up an active-state gold underline.
//   - Mobile overlay continues to list every live destination inline.
//
// v50 — header compaction:
//   - Italic tagline dropped from the wordmark.
//   - Inner container moved from max-w-5xl to max-w-7xl.
//   - Pro / Voices / Updates pulled into a "More ▾" <details> disclosure.
//   - Desktop search collapses to a magnifying-glass icon; clicking
//     (or pressing ⌘K / Ctrl+K / `/`) expands the input inline.
//
// v38 — header search rebuilt as a plain <form action="/search/" method="get">.
// v36 — view toggle removed, mobile nav replaced with a hamburger overlay.

const NAV_LINKS = [
  { href: '/start/', label: 'Start Here' },
  { href: '/explore/', label: 'Explore' },
  { href: '/why/', label: 'Why' },
  { href: '/contribute/', label: 'Contribute', icon: 'HandHeart' },
  { href: '/about/', label: 'About', icon: 'Building2' },
  // v57b cleanup — Newsroom moves out of the inline top-nav and into
  // LIBRARY_ROOMS / Rooms ▾ dropdown. The word "room" is in the name;
  // treating it as a non-library category was a v55 inconsistency.
];

const LIBRARY_ROOMS = [
  { href: '/reading/', label: 'Reading Room', icon: 'BookOpen', live: true },
  { href: '/atlas/', label: 'Atlas', icon: 'Compass', live: true },
  { href: '/maps/', label: 'Map Room', icon: 'Map', live: true },
  { href: '/counting/', label: 'Counting House', icon: 'ScrollText', live: true },
  { href: '/newsroom/', label: 'Newsroom', icon: 'Newspaper', live: true },
  { href: '/reference-desk/', label: 'Reference Desk', icon: 'HandHeart', live: true },
  { href: null, label: 'Records Room', icon: 'Archive', live: false },
  { href: null, label: 'Court Room', icon: 'Scale', live: false },
  { href: null, label: 'Breach & Recovery', icon: 'ShieldAlert', live: false },
];

const MORE_LINKS = [
  { href: '/pro/', label: 'Pro', icon: 'Building2' },
  { href: '/voices/', label: 'Voices', icon: 'Mic' },
  { href: '/updates/', label: 'Updates' },
];

// v56 — Coming Soon ▾ disclosure. Each entry has a live stub page at
// its eventual URL; the stub gets replaced in place when the room ships
// in full. Entries render as italic slate links (not muted aria-disabled
// spans) because the destination exists — it's a stub, not a dead link.
const COMING_SOON_LINKS = [
  { href: '/records/', label: 'Records Room', icon: 'Archive' },
  { href: '/court/', label: 'Court Room', icon: 'Scale' },
  { href: '/breach-recovery/', label: 'Breach & Recovery', icon: 'ShieldAlert' },
  { href: '/chronicle/', label: 'Chronicle Room', icon: 'Compass' },
  { href: '/stacks/', label: 'The Stacks', icon: 'BookOpen' },
  { href: '/founders/', label: "Founders' Cabinet", icon: 'Building2' },
  { href: '/school/', label: 'Schoolroom', icon: 'BookOpen' },
  { href: '/lectures/', label: 'Lecture Hall', icon: 'Mic' },
  { href: '/computer-room/', label: 'Computer Room', icon: 'ScrollText' },
];

const LIVE_LIBRARY_ROOMS = LIBRARY_ROOMS.filter((r) => r.live);
const COMING_LIBRARY_ROOMS = LIBRARY_ROOMS.filter((r) => !r.live);

// Active-state detection: which top-nav surface the current page belongs to.
// Trailing-slash normalized so /reading and /reading/ both match.
const rawPath = Astro.url.pathname;
const path = rawPath.replace(/\/$/, '') || '/';
const LIBRARY_PREFIXES = ['/reading', '/atlas', '/maps', '/counting', '/reference-desk', '/newsroom'];
const isInLibraryRoom = LIBRARY_PREFIXES.some(
  (prefix) => path === prefix || path.startsWith(`${prefix}/`),
);
---
<header
  data-pagefind-ignore
  class="sticky top-0 z-40 border-b border-slate-200 bg-white/95 backdrop-blur"
>
  <div class="mx-auto flex max-w-7xl flex-wrap items-center gap-3 px-4 py-3 sm:gap-4">
    <a href="/" class="site-wordmark mr-auto min-h-[44px]">
      <svg
        class="plss-mark"
        viewBox="0 0 60 60"
        aria-hidden="true"
      >
        <g fill="none" stroke="currentColor" stroke-width="1" opacity="0.55">
          <rect x="0" y="0" width="60" height="60"></rect>
          <line x1="10" y1="0" x2="10" y2="60"></line>
          <line x1="20" y1="0" x2="20" y2="60"></line>
          <line x1="30" y1="0" x2="30" y2="60"></line>
          <line x1="40" y1="0" x2="40" y2="60"></line>
          <line x1="50" y1="0" x2="50" y2="60"></line>
          <line x1="0" y1="10" x2="60" y2="10"></line>
          <line x1="0" y1="20" x2="60" y2="20"></line>
          <line x1="0" y1="30" x2="60" y2="30"></line>
          <line x1="0" y1="40" x2="60" y2="40"></line>
          <line x1="0" y1="50" x2="60" y2="50"></line>
        </g>
        <rect x="30" y="20" width="10" height="10" fill="var(--old-gold)" opacity="0.9"></rect>
        <rect x="0" y="50" width="10" height="10" fill="var(--old-gold)" opacity="0.55"></rect>
      </svg>
      <span class="wordmark-text">
        <strong>America's School Trust Library</strong>
      </span>
    </a>

    {/* Desktop nav — visible at lg+, hidden at smaller widths so the
        wordmark + hamburger + search fit on a single mobile row.

        Order (v55): Start Here · Explore · Why · Rooms ▾ · Contribute
        · About · Newsroom · More ▾ · Library Card · search-icon.
        Rooms ▾ sits between Why and the front-of-house categories — adjacent
        to Explore, the floor plan that introduces the rooms. */}
    <nav class="hidden flex-wrap items-center gap-x-1 gap-y-2 text-sm lg:flex sm:gap-x-3">
      {NAV_LINKS.slice(0, 3).map((link) => (
        <a
          href={link.href}
          class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center px-2 text-blue-700 hover:underline"
        >
          {link.icon && <NavIcon name={link.icon} />}
          {link.label.replace(/ /g, ' ')}
        </a>
      ))}

      <details class="header-more header-rooms relative" data-header-rooms>
        <summary
          class:list={[
            'inline-flex min-h-[44px] min-w-[44px] cursor-pointer items-center justify-center px-2 text-blue-700 hover:underline',
            isInLibraryRoom && 'header-rooms--active',
          ]}
          aria-label="Library rooms"
        >Rooms&nbsp;▾</summary>
        <div class="header-more__panel" role="menu">
          {LIVE_LIBRARY_ROOMS.map((room) => (
            <a
              href={room.href!}
              role="menuitem"
              class="header-more__link"
            >
              <NavIcon name={room.icon} />
              <span>{room.label}</span>
            </a>
          ))}
          <div class="header-more__divider" role="separator"></div>
          {COMING_LIBRARY_ROOMS.map((room) => (
            <span
              class="header-more__link header-more__link--coming-soon"
              aria-disabled="true"
              role="menuitem"
            >
              <NavIcon name={room.icon} />
              <span>{room.label}</span>
              <small>coming soon</small>
            </span>
          ))}
        </div>
      </details>

      {/* v56 — Coming Soon ▾ disclosure. Lists the ten rooms-being-planned
          that have stub pages. Italicized slate text on each link
          communicates "future thing, click to see what's planned." */}
      <details class="header-more header-coming relative" data-header-coming>
        <summary
          class="inline-flex min-h-[44px] min-w-[44px] cursor-pointer items-center justify-center px-2 text-blue-700 hover:underline"
          aria-label="Rooms being planned"
        >Coming&nbsp;Soon&nbsp;▾</summary>
        <div class="header-more__panel" role="menu">
          {COMING_SOON_LINKS.map((room) => (
            <a
              href={room.href}
              role="menuitem"
              class="header-more__link"
            >
              <NavIcon name={room.icon} />
              <span>{room.label}</span>
            </a>
          ))}
        </div>
      </details>

      {NAV_LINKS.slice(3).map((link) => (
        <a
          href={link.href}
          class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center px-2 text-blue-700 hover:underline"
        >
          {link.icon && <NavIcon name={link.icon} />}
          {link.label.replace(/ /g, ' ')}
        </a>
      ))}

      <details class="header-more relative" data-header-more>
        <summary
          class="inline-flex min-h-[44px] min-w-[44px] cursor-pointer items-center justify-center px-2 text-blue-700 hover:underline"
          aria-label="More navigation"
        >More&nbsp;▾</summary>
        <div class="header-more__panel" role="menu">
          {MORE_LINKS.map((link) => (
            <a
              href={link.href}
              role="menuitem"
              class="header-more__link"
            >
              {link.icon && <NavIcon name={link.icon} />}
              <span>{link.label}</span>
            </a>
          ))}
        </div>
      </details>

      <a
        id="library-card-link"
        href="/library-card/"
        class="library-card-link inline-flex min-h-[36px] items-center justify-center px-2 text-blue-700 hover:underline"
        data-default-href="/library-card/"
        data-default-label="Library Card"
        >Library&nbsp;Card</a
      >
      <a
        id="library-card-signout"
        href="/auth/sign-out"
        hidden
        class="library-card-signout inline-flex min-h-[36px] items-center justify-center px-2 text-slate-500 hover:text-slate-700 hover:underline"
        >Sign&nbsp;out</a
      >

      <div class="header-search-wrap" data-search-wrap>
        <button
          type="button"
          class="header-search-icon"
          aria-label="Open search (⌘K or /)"
          data-search-toggle
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </button>
        <form
          action="/search/"
          method="get"
          role="search"
          class="header-search header-search--desktop"
          aria-label="Search the Library"
          data-search-form
        >
          <label class="sr-only" for="header-search-input">Search the Library</label>
          <input
            id="header-search-input"
            type="search"
            name="q"
            placeholder="Search…"
            autocomplete="off"
            spellcheck="false"
            aria-label="Search the Library"
            class="header-search__input"
            tabindex="-1"
          />
          <button
            type="submit"
            class="header-search__submit"
            aria-label="Submit search"
            tabindex="-1"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="11" cy="11" r="7"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </button>
        </form>
      </div>
    </nav>

    {/* Mobile controls — visible below lg. Search input + hamburger.
        Hamburger opens a full overlay with the complete nav. */}
    <div class="flex items-center gap-1 lg:hidden">
      <form
        action="/search/"
        method="get"
        role="search"
        class="header-search header-search--mobile"
        aria-label="Search the Library"
      >
        <label class="sr-only" for="header-search-input-mobile">Search the Library</label>
        <input
          id="header-search-input-mobile"
          type="search"
          name="q"
          placeholder="Search…"
          autocomplete="off"
          spellcheck="false"
          aria-label="Search the Library"
          class="header-search__input header-search__input--mobile"
        />
        <button
          type="submit"
          class="header-search__submit header-search__submit--mobile"
          aria-label="Submit search"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </button>
      </form>
      <button
        id="mobile-nav-toggle"
        type="button"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav-overlay"
        class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded text-slate-700 hover:bg-slate-100"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<div
  id="mobile-nav-overlay"
  class="mobile-nav-overlay"
  data-state="closed"
  aria-hidden="true"
>
  <div class="mobile-nav-overlay__scrim" data-mobile-nav-scrim></div>
  <nav
    class="mobile-nav-overlay__panel"
    aria-label="Site navigation"
    data-mobile-nav-panel
  >
    <div class="mobile-nav-overlay__header">
      <span class="mobile-nav-overlay__title">Menu</span>
      <button
        type="button"
        class="mobile-nav-overlay__close"
        data-mobile-nav-close
        aria-label="Close navigation menu"
      >×</button>
    </div>
    {/* v55 — mobile overlay continues to list every live destination
        inline. Order matches the desktop nav reading: front-of-house
        first (Start Here · Explore · Why), then the four live library
        rooms in a labeled group, then Contribute · About · Newsroom,
        then the More disclosure entries (Pro · Voices · Updates).
        Coming-soon rooms are intentionally omitted from mobile to keep
        the menu uncluttered. */}
    <ul class="mobile-nav-overlay__list">
      {NAV_LINKS.slice(0, 3).map((link) => (
        <li>
          <a href={link.href} class="mobile-nav-overlay__link">
            {link.icon && <NavIcon name={link.icon} />}
            <span>{link.label}</span>
          </a>
        </li>
      ))}
      <li class="mobile-nav-overlay__group-label" aria-hidden="true">Library rooms</li>
      {LIVE_LIBRARY_ROOMS.map((room) => (
        <li>
          <a href={room.href!} class="mobile-nav-overlay__link">
            <NavIcon name={room.icon} />
            <span>{room.label}</span>
          </a>
        </li>
      ))}
      {/* v56 — Coming Soon group in the mobile overlay. Lists all ten
          stub-page rooms inline so mobile readers see the planned scope
          directly, without a nested dropdown. */}
      <li class="mobile-nav-overlay__group-label" aria-hidden="true">Coming Soon</li>
      {COMING_SOON_LINKS.map((room) => (
        <li>
          <a href={room.href} class="mobile-nav-overlay__link mobile-nav-overlay__link--coming">
            <NavIcon name={room.icon} />
            <span>{room.label}</span>
          </a>
        </li>
      ))}
      <li class="mobile-nav-overlay__divider"></li>
      {NAV_LINKS.slice(3).map((link) => (
        <li>
          <a href={link.href} class="mobile-nav-overlay__link">
            {link.icon && <NavIcon name={link.icon} />}
            <span>{link.label}</span>
          </a>
        </li>
      ))}
      {MORE_LINKS.map((link) => (
        <li>
          <a href={link.href} class="mobile-nav-overlay__link">
            {link.icon && <NavIcon name={link.icon} />}
            <span>{link.label}</span>
          </a>
        </li>
      ))}
      <li class="mobile-nav-overlay__divider"></li>
      <li>
        <a
          id="library-card-link-mobile"
          href="/library-card/"
          class="library-card-link mobile-nav-overlay__link"
          data-default-href="/library-card/"
          data-default-label="Library Card"
          >Library Card</a
        >
      </li>
      <li>
        <a
          id="library-card-signout-mobile"
          href="/auth/sign-out"
          hidden
          class="library-card-signout mobile-nav-overlay__link mobile-nav-overlay__link--muted"
          >Sign out</a
        >
      </li>
    </ul>
  </nav>
</div>

<WalkingTour />

<style is:global>
  /* v50 — More-disclosure panel. Drops below the trigger, anchored
     right so it stays inside the viewport. */
  .header-more {
    position: relative;
  }
  .header-more__panel {
    position: absolute;
    top: 100%;
    right: 0;
    min-width: 11rem;
    margin-top: 0.25rem;
    padding: 0.35rem 0;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.12);
    z-index: 60;
    display: flex;
    flex-direction: column;
  }
  .header-more__link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 44px;
    padding: 0.45rem 0.85rem;
    font-size: 0.92rem;
    color: #1d4ed8;
    text-decoration: none;
    white-space: nowrap;
  }
  .header-more__link:hover {
    background: #f1f5f9;
    text-decoration: underline;
  }

  /* v55 — Rooms disclosure: divider between live rooms and coming-soon
     placeholders inside the dropdown panel. */
  .header-more__divider {
    height: 1px;
    background: #e5e7eb;
    margin: 0.35rem 0.5rem;
  }
  .header-more__link--coming-soon {
    color: #94a3b8;
    cursor: default;
    font-style: italic;
    text-decoration: none;
  }
  .header-more__link--coming-soon:hover {
    background: transparent;
    text-decoration: none;
  }
  .header-more__link--coming-soon small {
    margin-left: auto;
    padding-left: 0.5rem;
    font-size: 0.72rem;
    font-style: normal;
    color: #cbd5e1;
  }

  /* v55 — active-state marker on the Rooms ▾ trigger when the reader
     is on any library page. A subtle gold underline beneath the
     summary; matches the Library's accent palette. */
  .header-rooms--active {
    position: relative;
    font-weight: 600;
  }
  .header-rooms--active::after {
    content: "";
    position: absolute;
    bottom: 4px;
    left: 0.5rem;
    right: 0.5rem;
    height: 2px;
    background: var(--old-gold, #B88A2E);
    border-radius: 1px;
  }

  /* v55 — mobile-overlay group label for the "Library rooms" cluster.
     v56 — also used for the "Coming Soon" cluster below it. */
  .mobile-nav-overlay__group-label {
    padding: 0.6rem 1rem 0.2rem;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #94a3b8;
  }

  /* v56 — Coming Soon ▾ disclosure. Each room link in the dropdown
     renders italic + slate, signaling "future thing, click to see
     what's planned" without screaming "disabled." */
  [data-header-coming] .header-more__link {
    color: #475569;
  }
  [data-header-coming] .header-more__link span {
    font-style: italic;
  }
  [data-header-coming] .header-more__link:hover {
    color: #1d4ed8;
    background: #f1f5f9;
  }

  /* Mobile overlay equivalent — italic slate Coming Soon entries. */
  .mobile-nav-overlay__link--coming {
    color: #475569;
  }
  .mobile-nav-overlay__link--coming span {
    font-style: italic;
  }
  .mobile-nav-overlay__link--coming:hover {
    color: #1d4ed8;
  }

  /* v50 — collapsing search. The form sits at width 0 by default and
     expands inline when the magnifying-glass button is clicked or a
     keyboard shortcut fires. */
  .header-search-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .header-search-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid transparent;
    border-radius: 4px;
    background: transparent;
    color: #1e3a5f;
    cursor: pointer;
  }
  .header-search-icon:hover {
    background: #f1f5f9;
  }
  .header-search-icon:focus-visible {
    outline: 2px solid #1d4ed8;
    outline-offset: 1px;
  }
  .header-search-wrap[data-expanded='true'] .header-search-icon {
    display: none;
  }
  .header-search--desktop {
    overflow: hidden;
    width: 0;
    transition: width 150ms ease;
  }
  .header-search--desktop .header-search__input,
  .header-search--desktop .header-search__submit {
    visibility: hidden;
  }
  .header-search-wrap[data-expanded='true'] .header-search--desktop {
    width: 13.5rem;
  }
  .header-search-wrap[data-expanded='true'] .header-search--desktop .header-search__input,
  .header-search-wrap[data-expanded='true'] .header-search--desktop .header-search__submit {
    visibility: visible;
  }

  /* v38-era header search — shared input/button styling. */
  .header-search {
    display: inline-flex;
    align-items: stretch;
    gap: 0;
    min-height: 36px;
  }
  .header-search__input {
    min-width: 0;
    width: 11rem;
    padding: 0.35rem 0.6rem;
    font-size: 0.875rem;
    line-height: 1.3;
    border: 1px solid #cbd5e1;
    border-right: 0;
    border-top-left-radius: 4px;
    border-bottom-left-radius: 4px;
    background: #fff;
    color: #0f172a;
  }
  .header-search__input:focus {
    outline: 2px solid #1d4ed8;
    outline-offset: 1px;
    border-color: #1d4ed8;
  }
  .header-search__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    min-width: 40px;
    padding: 0 0.5rem;
    background: #1e3a5f;
    color: #ffd07a;
    border: 1px solid #1e3a5f;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    cursor: pointer;
  }
  .header-search__submit:hover {
    background: #16304f;
  }
  /* Mobile header search — compact, sits between hamburger and wordmark. */
  .header-search__input--mobile {
    width: 8rem;
    font-size: 0.85rem;
  }
  .header-search__submit--mobile {
    min-height: 44px;
    min-width: 44px;
  }
  @media (max-width: 380px) {
    .header-search__input--mobile {
      width: 6rem;
    }
  }

  /* v36 — full-overlay mobile navigation. */
  .mobile-nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 80;
    pointer-events: none;
    opacity: 0;
    transition: opacity 150ms ease;
  }
  .mobile-nav-overlay[data-state='open'] {
    pointer-events: auto;
    opacity: 1;
  }
  .mobile-nav-overlay__scrim {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.5);
  }
  .mobile-nav-overlay__panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(20rem, 88vw);
    background: #fff;
    border-left: 1px solid #e5e7eb;
    box-shadow: -8px 0 24px rgba(15, 23, 42, 0.12);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 200ms ease;
    overflow-y: auto;
  }
  .mobile-nav-overlay[data-state='open'] .mobile-nav-overlay__panel {
    transform: translateX(0);
  }
  .mobile-nav-overlay__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid #e5e7eb;
  }
  .mobile-nav-overlay__title {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #475569;
  }
  .mobile-nav-overlay__close {
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid #e5e7eb;
    background: #fff;
    border-radius: 4px;
    font-size: 1.5rem;
    line-height: 1;
    color: #1e3a5f;
    cursor: pointer;
  }
  .mobile-nav-overlay__close:hover {
    background: #f8fafc;
  }
  .mobile-nav-overlay__list {
    list-style: none;
    margin: 0;
    padding: 0.4rem 0;
    flex: 1 1 auto;
  }
  .mobile-nav-overlay__divider {
    height: 1px;
    background: #e5e7eb;
    margin: 0.4rem 0;
  }
  .mobile-nav-overlay__link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    min-height: 44px;
    padding: 0.6rem 1rem;
    color: #1d4ed8;
    text-decoration: none;
    font-size: 0.95rem;
  }
  .mobile-nav-overlay__link:hover {
    background: #f1f5f9;
    text-decoration: underline;
  }
  .mobile-nav-overlay__link--muted {
    color: #64748b;
  }
  body.mobile-nav-open {
    overflow: hidden;
  }
</style>

<script>
  // Header login-state hydration: when a Library Card holder is signed in,
  // the "Library Card" nav link rewrites to "My Library" and the hidden
  // "Sign out" link reveals.
  import { getBrowserSupabase } from '../lib/supabase';

  (async () => {
    const links = [
      document.getElementById('library-card-link'),
      document.getElementById('library-card-link-mobile'),
    ].filter((el): el is HTMLElement => el !== null);
    const signouts = [
      document.getElementById('library-card-signout'),
      document.getElementById('library-card-signout-mobile'),
    ].filter((el): el is HTMLElement => el !== null);
    if (links.length === 0 || signouts.length === 0) return;
    try {
      const supabase = getBrowserSupabase();
      const {
        data: { user },
      } = await supabase.auth.getUser();
      if (user) {
        for (const link of links) {
          link.setAttribute('href', '/my-library/');
          link.textContent = 'My Library';
        }
        for (const signout of signouts) {
          signout.removeAttribute('hidden');
        }
      }
    } catch (_) {
      // Silently leave the default logged-out state on any failure.
    }
  })();
</script>
<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    // ---- v36 — mobile-nav overlay ----
    const overlay = document.getElementById('mobile-nav-overlay');
    const toggleBtn = document.getElementById('mobile-nav-toggle');
    const closeBtn = overlay
      ? overlay.querySelector('[data-mobile-nav-close]')
      : null;
    const scrim = overlay
      ? overlay.querySelector('[data-mobile-nav-scrim]')
      : null;

    function setOverlay(open) {
      if (!overlay || !toggleBtn) return;
      overlay.setAttribute('data-state', open ? 'open' : 'closed');
      overlay.setAttribute('aria-hidden', open ? 'false' : 'true');
      toggleBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
      document.body.classList.toggle('mobile-nav-open', open);
      if (open) {
        const c = overlay.querySelector('[data-mobile-nav-close]');
        if (c && typeof c.focus === 'function') c.focus();
      }
    }

    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        const isOpen = overlay && overlay.getAttribute('data-state') === 'open';
        setOverlay(!isOpen);
      });
    }
    if (closeBtn) closeBtn.addEventListener('click', () => setOverlay(false));
    if (scrim) scrim.addEventListener('click', () => setOverlay(false));
    if (overlay) {
      overlay.addEventListener('click', (ev) => {
        const target =
          ev.target instanceof Element ? ev.target.closest('a') : null;
        if (target) setOverlay(false);
      });
    }

    // ---- v50/v55 — header disclosures: close on outside click + link nav ----
    // Both the "Rooms ▾" (v55) and "More ▾" (v50) disclosures share the
    // same UX contract: clicking outside closes; activating a link closes
    // so the destination renders without the panel still hanging open.
    const headerDisclosures = Array.from(
      document.querySelectorAll('[data-header-rooms], [data-header-coming], [data-header-more]'),
    );
    if (headerDisclosures.length > 0) {
      document.addEventListener('click', (ev) => {
        const t = ev.target;
        for (const d of headerDisclosures) {
          if (!d.hasAttribute('open')) continue;
          if (t instanceof Node && !d.contains(t)) {
            d.removeAttribute('open');
          }
        }
      });
      for (const d of headerDisclosures) {
        d.addEventListener('click', (ev) => {
          const a = ev.target instanceof Element ? ev.target.closest('a') : null;
          if (a) d.removeAttribute('open');
        });
      }
    }
    // Preserve the disclosure references for the Escape handler below.
    const moreDetails = document.querySelector('[data-header-more]');
    const roomsDetails = document.querySelector('[data-header-rooms]');
    const comingDetails = document.querySelector('[data-header-coming]');

    // ---- v50 — Collapsing desktop search ----
    const searchWrap = document.querySelector('[data-search-wrap]');
    const searchToggle = document.querySelector('[data-search-toggle]');
    const searchInput = document.getElementById('header-search-input');

    function expandSearch() {
      if (!searchWrap) return;
      searchWrap.setAttribute('data-expanded', 'true');
      if (searchInput) {
        searchInput.removeAttribute('tabindex');
        const submit = searchWrap.querySelector('.header-search__submit');
        if (submit) submit.removeAttribute('tabindex');
        // Defer focus so the visibility transition has applied.
        setTimeout(() => {
          if (typeof searchInput.focus === 'function') searchInput.focus();
        }, 0);
      }
    }
    function collapseSearch() {
      if (!searchWrap) return;
      searchWrap.removeAttribute('data-expanded');
      if (searchInput) {
        searchInput.setAttribute('tabindex', '-1');
        if (document.activeElement === searchInput && typeof searchInput.blur === 'function') {
          searchInput.blur();
        }
      }
    }

    if (searchToggle) {
      searchToggle.addEventListener('click', (ev) => {
        ev.preventDefault();
        expandSearch();
      });
    }
    if (searchInput) {
      searchInput.addEventListener('keydown', (ev) => {
        if (ev.key === 'Escape') {
          ev.preventDefault();
          collapseSearch();
        }
      });
    }

    // ---- v50 — Keyboard shortcuts ----
    // Cmd+K (Mac) and Ctrl+K (others) open the search input.
    // Ctrl+K conflicts with Chrome/Firefox address-bar shortcuts on
    // Win/Linux, so we also bind `/` (single-key, GitHub-style) as a
    // reliable cross-platform fallback. ESC anywhere closes the search.
    document.addEventListener('keydown', (ev) => {
      const isTypingTarget =
        ev.target instanceof HTMLElement &&
        (ev.target.tagName === 'INPUT' ||
          ev.target.tagName === 'TEXTAREA' ||
          ev.target.isContentEditable);

      // ESC: close overlay or collapse search.
      if (ev.key === 'Escape') {
        if (overlay && overlay.getAttribute('data-state') === 'open') {
          setOverlay(false);
          if (toggleBtn && typeof toggleBtn.focus === 'function') toggleBtn.focus();
          return;
        }
        if (roomsDetails && roomsDetails.hasAttribute('open')) {
          roomsDetails.removeAttribute('open');
          return;
        }
        if (comingDetails && comingDetails.hasAttribute('open')) {
          comingDetails.removeAttribute('open');
          return;
        }
        if (moreDetails && moreDetails.hasAttribute('open')) {
          moreDetails.removeAttribute('open');
          return;
        }
        if (searchWrap && searchWrap.getAttribute('data-expanded') === 'true') {
          collapseSearch();
          return;
        }
      }

      // Cmd+K / Ctrl+K — focus search (only fires when the browser
      // doesn't pre-empt the binding; we still preventDefault for
      // platforms where it does work).
      if ((ev.metaKey || ev.ctrlKey) && (ev.key === 'k' || ev.key === 'K')) {
        if (window.matchMedia && window.matchMedia('(min-width: 1024px)').matches) {
          ev.preventDefault();
          expandSearch();
        }
        return;
      }

      // `/` — open search (skip if typing in another input).
      if (ev.key === '/' && !isTypingTarget && !ev.metaKey && !ev.ctrlKey && !ev.altKey) {
        if (window.matchMedia && window.matchMedia('(min-width: 1024px)').matches) {
          ev.preventDefault();
          expandSearch();
        }
      }
    });

    // ---- v38-era — ?q= fallback highlight walker ----
    const params = new URLSearchParams(window.location.search);
    const q = (params.get('q') || '').trim();
    const onSearchPage = window.location.pathname === '/search/' ||
      window.location.pathname === '/search';
    if (q && !onSearchPage && !('fragmentDirective' in document)) {
      const root = document.querySelector('main');
      if (root) {
        const terms = q
          .split(/\s+/)
          .filter((t) => t.length > 1)
          .map((t) => t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
        if (terms.length > 0) {
          const re = new RegExp(`(${terms.join('|')})`, 'gi');
          const skip = new Set(['SCRIPT', 'STYLE', 'MARK', 'CODE', 'PRE']);
          const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
            acceptNode(node) {
              if (!node.parentElement) return NodeFilter.FILTER_REJECT;
              if (skip.has(node.parentElement.tagName)) return NodeFilter.FILTER_REJECT;
              return re.test(node.nodeValue || '')
                ? NodeFilter.FILTER_ACCEPT
                : NodeFilter.FILTER_REJECT;
            },
          });
          const targets = [];
          let n;
          while ((n = walker.nextNode())) targets.push(n);
          let firstMark = null;
          for (const node of targets) {
            const span = document.createElement('span');
            span.innerHTML = (node.nodeValue || '').replace(
              re,
              '<mark>$1</mark>',
            );
            if (!firstMark) firstMark = span.querySelector('mark');
            node.parentNode.replaceChild(span, node);
          }
          if (firstMark) {
            firstMark.scrollIntoView({ behavior: 'auto', block: 'center' });
          }
        }
      }
    }
  });
</script>

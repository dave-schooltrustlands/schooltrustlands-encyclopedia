---
// Right-rail dossier listing the five non-Reading rooms for a given state.
// Per Plan_v2.1 it sits on every state-scoped page across rooms; for now
// it's a skeleton — each row is "Coming later". As other rooms launch
// they'll hydrate the corresponding row with a real link + summary.
//
// Not wired into any page yet. Intentional: the consumer pages and the
// breadcrumb/RoomLayout pattern aren't designed yet, and threading this
// in across Atlas + Reading + the eventual Counting House is best done
// once when those decisions are made.

interface Props {
  iso: string; // lowercase, e.g. "us-or"
  name: string;
}

const { iso, name } = Astro.props;

const rooms = [
  { id: 'atlas', label: 'Atlas Room', status: 'live', href: '/atlas/' },
  { id: 'counting', label: 'Counting House', status: 'coming', href: null },
  { id: 'records', label: 'Records Room', status: 'coming', href: null },
  { id: 'court', label: 'Court Room', status: 'coming', href: null },
  { id: 'breach', label: 'Breach & Recovery', status: 'coming', href: null },
];
---

<aside
  class="rounded-lg border border-slate-200 bg-white p-4 text-sm shadow-sm"
  data-pagefind-ignore
  aria-labelledby={`dossier-${iso}-heading`}
>
  <h2
    id={`dossier-${iso}-heading`}
    class="text-xs font-semibold uppercase tracking-wide text-slate-500"
  >
    {name} across the library
  </h2>
  <ul class="mt-3 space-y-2">
    {rooms.map((room) => (
      <li class="flex items-baseline justify-between gap-3">
        <span class="font-medium text-slate-700">{room.label}</span>
        {room.status === 'live' && room.href ? (
          <a href={room.href} class="text-blue-700 underline hover:text-blue-900">
            Open →
          </a>
        ) : (
          <span class="text-slate-400">Coming later</span>
        )}
      </li>
    ))}
  </ul>
</aside>

---
// Right-rail dossier listing the six rooms for a given state. Atlas links
// to the cross-state map; the other rooms link to state-scoped routes
// where they exist. Counting House row is hydrated with a one-line
// financial summary derived from src/data/finance/states.json so the
// dossier doesn't drift from the canonical numbers.

import financeData from '../data/finance/states.json';

interface Props {
  iso: string; // lowercase, e.g. "us-or"
  name: string;
}

const { iso, name } = Astro.props;

type FinanceRecord = {
  stateIso: string;
  displayName: string;
  corpus: { value: number | null; confidence: string };
  distribution: { value: number | null; fiscalYear: string | null; confidence: string };
  transparency: { status: string };
  federalGrantAcres: { value: number };
};

const finance = (financeData as FinanceRecord[]).find((r) => r.stateIso === iso);

const usdShort = (n: number) => {
  if (n >= 1_000_000_000) return `$${(n / 1_000_000_000).toFixed(n >= 10_000_000_000 ? 0 : 1)}B`;
  if (n >= 1_000_000) return `$${(n / 1_000_000).toFixed(n >= 100_000_000 ? 0 : 1)}M`;
  return `$${n.toLocaleString('en-US')}`;
};

interface CountingSummary {
  text: string;
  awaitingDisclosure: boolean;
}

// v10 D.1 — return a structured summary instead of a regex-fragile string.
// `awaitingDisclosure` is true whenever the state has a federal trust but
// corpus and/or distribution figures are missing or marked
// awaiting-disclosure. Callers should check the boolean for ornament
// presence instead of pattern-matching the text.
function countingSummary(rec: FinanceRecord | undefined): CountingSummary {
  if (!rec) return { text: 'No financial data', awaitingDisclosure: false };
  if (rec.federalGrantAcres.value === 0) {
    return { text: 'State-derived; no federal trust', awaitingDisclosure: false };
  }
  const parts: string[] = [];
  let awaiting = false;
  if (rec.corpus.value !== null) {
    parts.push(`${usdShort(rec.corpus.value)} corpus`);
  } else if (rec.corpus.confidence === 'awaiting-disclosure') {
    parts.push('Awaiting corpus');
    awaiting = true;
  } else {
    awaiting = true;
  }
  if (rec.distribution.value !== null) {
    const fy = rec.distribution.fiscalYear ? ` FY${rec.distribution.fiscalYear}` : '';
    parts.push(`${usdShort(rec.distribution.value)} distributed${fy}`);
  } else if (rec.distribution.confidence === 'awaiting-disclosure') {
    parts.push('awaiting distribution');
    awaiting = true;
  } else {
    awaiting = true;
  }
  return {
    text: parts.length > 0 ? parts.join('; ') : 'Awaiting State Disclosure',
    awaitingDisclosure: awaiting,
  };
}

const counting = countingSummary(finance);

const rooms = [
  {
    id: 'reading',
    label: 'Reading Room',
    href: `/reading/${iso}/`,
    summary: 'State dossier',
    awaitingDisclosure: false,
    status: 'live' as const,
  },
  {
    id: 'atlas',
    label: 'Atlas',
    href: '/atlas/',
    summary: 'Find this state on the map',
    awaitingDisclosure: false,
    status: 'live' as const,
  },
  {
    id: 'counting',
    label: 'Counting House',
    href: `/counting/${iso}/`,
    summary: counting.text,
    awaitingDisclosure: counting.awaitingDisclosure,
    status: 'live' as const,
  },
  { id: 'records', label: 'Records Room', href: null, summary: null, awaitingDisclosure: false, status: 'coming' as const },
  { id: 'court', label: 'Court Room', href: null, summary: null, awaitingDisclosure: false, status: 'coming' as const },
  { id: 'breach', label: 'Breach & Recovery', href: null, summary: null, awaitingDisclosure: false, status: 'coming' as const },
];
---

<aside
  class="rounded-lg border border-slate-200 bg-white p-4 text-sm shadow-sm"
  data-pagefind-ignore
  aria-labelledby={`dossier-${iso}-heading`}
>
  <h2
    id={`dossier-${iso}-heading`}
    class="text-xs font-semibold uppercase tracking-wide text-slate-500"
  >
    {name} across the library
  </h2>
  <ul class="mt-3 space-y-3">
    {rooms.map((room) => (
      <li>
        <div class="flex items-baseline justify-between gap-3">
          <span class="font-medium text-slate-700">{room.label}</span>
          {room.status === 'live' && room.href ? (
            <a href={room.href} class="text-blue-700 underline hover:text-blue-900">
              Open →
            </a>
          ) : (
            <span class="text-slate-400">Coming later</span>
          )}
        </div>
        {room.summary && (
          <p class="mt-0.5 text-xs text-slate-500">
            {room.summary}
            {/* v10 D.1 — empty-shelf ornament keys off the structured
                awaitingDisclosure boolean from countingSummary(), not a
                regex against the rendered text. */}
            {room.id === 'counting' && room.awaitingDisclosure && (
              <img
                src="/ornaments/empty-shelf.svg"
                alt=""
                class="state-ornament"
                data-ornament="empty-shelf"
              />
            )}
          </p>
        )}
      </li>
    ))}
  </ul>
</aside>

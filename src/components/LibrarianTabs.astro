---
// Six-tab navigation row at the top of every /librarian/* page.
//
// v32: the tab set expanded from four to six (Reviews and Moderation added)
// and is now role-aware — a pure discussion_moderator sees only the two
// moderator tabs (Moderation + Discussions); librarian-tier roles see all
// six. The `role` prop is optional with a 'librarian' default so legacy
// pages that haven't yet been updated to pass it still render the full bar.
//
// Active tab is determined by the `current` prop (not by path matching) so
// nested routes like /librarian/applications/<id>/ keep the right tab lit.

interface Props {
  current:
    | 'tickets'
    | 'applications'
    | 'patrons'
    | 'reviews'
    | 'moderation'
    | 'discussions'
    | 'state-co-librarian'
    | 'institutional-formation';
  role?: 'librarian' | 'head_librarian' | 'admin' | 'discussion_moderator';
}

const { current, role = 'librarian' } = Astro.props;

const allTabs: Array<{
  key: Props['current'];
  label: string;
  href: string;
  /** When set, the tab is hidden unless the viewer's role is in the list. */
  roles?: Array<'librarian' | 'head_librarian' | 'admin' | 'discussion_moderator'>;
}> = [
  { key: 'tickets',                  label: 'Pending tickets',   href: '/librarian/' },
  { key: 'applications',             label: 'Applications',      href: '/librarian/applications/' },
  { key: 'patrons',                  label: 'Patrons',           href: '/librarian/patrons/' },
  { key: 'reviews',                  label: 'Reviews',           href: '/librarian/reviews/' },
  { key: 'moderation',               label: 'Moderation',        href: '/librarian/moderation/' },
  { key: 'discussions',              label: 'Discussions',       href: '/librarian/discussions/' },
  { key: 'state-co-librarian',       label: 'State Co-Lib',      href: '/librarian/state-co-librarian-applications/' },
  // v39 — Institutional-Formation feedback is for founding-officers only;
  // head_librarian and admin see it, ordinary librarians do not.
  { key: 'institutional-formation',  label: 'Institutional Formation', href: '/librarian/institutional-formation/', roles: ['head_librarian', 'admin'] },
];

// A pure moderator sees only Moderation + Discussions. Everyone else sees
// the bar filtered by per-tab roles (an absent `roles` list means all
// librarian-tier viewers see the tab).
const tabs =
  role === 'discussion_moderator'
    ? allTabs.filter((t) => t.key === 'moderation' || t.key === 'discussions')
    : allTabs.filter((t) => !t.roles || t.roles.includes(role));
---

<nav class="librarian-tabs" aria-label="Librarian dashboard sections">
  {tabs.map((t) => (
    <a
      href={t.href}
      class:list={['librarian-tab', current === t.key && 'librarian-tab--active']}
      aria-current={current === t.key ? 'page' : undefined}
    >
      {t.label}
    </a>
  ))}
</nav>

<style>
  .librarian-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--rule-border, #e5e7eb);
    margin: 0.5rem 0 1.25rem;
    overflow-x: auto;
  }
  .librarian-tab {
    padding: 0.55rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 600;
    color: #475569;
    text-decoration: none !important;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
  }
  .librarian-tab:hover {
    color: var(--deep-navy, #1e3a5f);
  }
  .librarian-tab--active {
    color: var(--deep-navy, #1e3a5f);
    border-bottom-color: var(--deep-navy, #1e3a5f);
  }
</style>

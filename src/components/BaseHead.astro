---
// Shared <head> meta block. Every page passes its own title + description;
// charset/viewport/og: tags are uniform across the site (per-page OG
// templates are Tier 3 in the Visual Rebuild Handoff).
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const SITE_URL = 'https://schooltrustlands.net';
const OG_TITLE =
  'Schools of the Republic — A public library of America\'s school trust lands';
const OG_DESCRIPTION =
  'America gave land to its schools. This is the ledger of what happened next.';
const OG_IMAGE = `${SITE_URL}/og-default.png`;
---
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />
<title>{title}</title>
{description && <meta name="description" content={description} />}

<meta property="og:title" content={OG_TITLE} />
<meta property="og:description" content={OG_DESCRIPTION} />
<meta property="og:image" content={OG_IMAGE} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:type" content="website" />
<meta name="twitter:card" content="summary_large_image" />

---
// v63 — Cross-site bridge to coalition surfaces (schooltrustlands.net,
// orww.org). Visual register tilts toward the Coalition's cleaner /
// more modern look (forest-green accent, sans-serif) so the reader
// registers the cross-site move before they click through. Sized to be
// noticeable but not dominant — typically placed near the hero of a
// substrate-mate page, not in the footer of every page.
interface Props {
  href: string;
  label: string;
  sublabel: string;
  cta: string;
  /** Optional override of the small site-name tag rendered above the label. */
  site?: string;
  /** Optional rel; defaults to "noopener". */
  rel?: string;
}

const { href, label, sublabel, cta, site, rel = 'noopener' } = Astro.props;

// Infer a site-name tag from the href if the caller didn't supply one.
let inferredSite = site;
if (!inferredSite) {
  try {
    const u = new URL(href);
    inferredSite = u.hostname.replace(/^www\./, '');
  } catch {
    inferredSite = '';
  }
}
---
<aside class="cross-site-bridge" data-cross-site-bridge>
  <div class="bridge-inner">
    {inferredSite && <p class="bridge-site">{inferredSite} →</p>}
    <p class="bridge-label">{label}</p>
    <p class="bridge-sublabel">{sublabel}</p>
    <p class="bridge-cta">
      <a href={href} rel={rel}>{cta}</a>
    </p>
  </div>
</aside>

<style>
  .cross-site-bridge {
    margin: 1.5rem 0;
    border: 1px solid #d8e1d6;
    border-left: 4px solid #2f5d3a;
    border-radius: 4px;
    background: #f7faf6;
    padding: 0;
    font-family: var(--font-sans, system-ui, sans-serif);
  }
  .bridge-inner {
    padding: 0.9rem 1.1rem;
  }
  .bridge-site {
    margin: 0 0 0.25rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #2f5d3a;
  }
  .bridge-label {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    font-weight: 600;
    color: #14281c;
    line-height: 1.3;
  }
  .bridge-sublabel {
    margin: 0 0 0.6rem;
    font-size: 0.88rem;
    line-height: 1.5;
    color: #3a4a3f;
  }
  .bridge-cta {
    margin: 0;
    font-size: 0.92rem;
  }
  .bridge-cta a {
    color: #1f4429;
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 600;
  }
  .bridge-cta a:hover {
    color: #0f2818;
  }
</style>

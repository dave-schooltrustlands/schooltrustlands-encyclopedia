---
/**
 * LibraryV1Banner — discoverability surface for the visual-density slider.
 *
 * Visible at the top of every page (just below the header) when
 * body.mode-library is set, UNLESS localStorage
 * `library-v1-banner-dismissed` is "permanent". The "Dismiss for now"
 * button hides the banner for the current page only via sessionStorage;
 * "Don't show again" writes the permanent localStorage flag.
 *
 * Style: small, dignified — linen-card background, slate text, gold left
 * rule, max-width 65ch centered. Defined in mode-library.css. NOT loud.
 *
 * The CSS hides the banner outside Library Mode, so this component is
 * safe to mount in BaseLayout regardless of which mode is active.
 *
 * v10 copy revision: post-IllustratedLobby retirement, the banner reframes
 * itself as a pointer to the View slider in the header — the affordance
 * that lets a reader switch out of Library Mode at any time.
 */
---

<div class="library-mode-banner" data-state="visible">
  <p>
    <strong>Library Mode</strong> is the default visual register. The
    <em>View</em> slider in the header lets you switch to <strong>Reference Mode</strong> —
    text-forward, fast, accessible — at any time.
  </p>
  <div class="lmb-actions">
    <button type="button" class="lmb-dismiss-session">Dismiss for now</button>
    <button type="button" class="lmb-dismiss-permanent">Don't show again</button>
  </div>
</div>

<script is:inline>
  (function () {
    const LS_KEY = 'library-v1-banner-dismissed';
    const SS_KEY = 'library-v1-banner-session-dismissed';
    const banner = document.querySelector('.library-mode-banner');
    if (!banner) return;

    function hide() {
      banner.setAttribute('data-state', 'hidden');
    }

    // Apply persisted dismissal state on load.
    try {
      if (localStorage.getItem(LS_KEY) === 'permanent') {
        hide();
        return;
      }
    } catch (_) {
      /* localStorage unavailable; proceed showing the banner */
    }
    try {
      if (sessionStorage.getItem(SS_KEY) === '1') {
        hide();
        return;
      }
    } catch (_) {
      /* sessionStorage unavailable; proceed showing the banner */
    }

    const sessionBtn = banner.querySelector('.lmb-dismiss-session');
    const permBtn = banner.querySelector('.lmb-dismiss-permanent');

    if (sessionBtn) {
      sessionBtn.addEventListener('click', function () {
        try {
          sessionStorage.setItem(SS_KEY, '1');
        } catch (_) {
          /* ignore */
        }
        hide();
      });
    }
    if (permBtn) {
      permBtn.addEventListener('click', function () {
        try {
          localStorage.setItem(LS_KEY, 'permanent');
        } catch (_) {
          /* ignore */
        }
        hide();
      });
    }
  })();
</script>

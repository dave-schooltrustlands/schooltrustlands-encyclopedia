---
/**
 * IllustratedLobby — Library Mode v1 home-page hero.
 *
 * Pure inline SVG (no external PNG dependency in v1). Renders a 16:9
 * lobby scene: warm-cream wall with a thin gold crown rule, the three-
 * panel thesis poster hung center-wall, six labeled doorways across the
 * bottom — each a real <a> link into a Library room. Below the SVG sit
 * the "Show me around the Library" CTA (wires to WalkingTour via the
 * data-open-walking-tour attribute) and the one-line thesis paragraph
 * preserved from the existing home-page hero.
 *
 * Visibility is controlled by mode-library.css: the .illustrated-lobby
 * wrapper only renders inside body.mode-library. Reference and Standard
 * modes keep the existing index.astro hero untouched.
 */

interface DoorSpec {
  label: string;
  href: string;
  stripe: string; // CSS color or var() reference
  ariaLabel: string;
}

const doors: DoorSpec[] = [
  {
    label: 'Reading Room',
    href: '/reading/',
    stripe: '#F0E6CD',
    ariaLabel: 'Enter the Reading Room',
  },
  {
    label: 'Atlas',
    href: '/atlas/',
    stripe: 'var(--sage)',
    ariaLabel: 'Enter the Atlas',
  },
  {
    label: 'Counting House',
    href: '/counting/',
    stripe: 'var(--old-gold)',
    ariaLabel: 'Enter the Counting House',
  },
  {
    label: 'Map Room',
    href: '/maps/',
    stripe: '#4A6E8A',
    ariaLabel: 'Enter the Map Room',
  },
  {
    label: 'Newsroom',
    href: '/newsroom/',
    stripe: '#475569',
    ariaLabel: 'Enter the Newsroom',
  },
  {
    label: 'Voices',
    href: '/voices/',
    stripe: 'var(--oxblood)',
    ariaLabel: 'Enter Voices',
  },
];

// SVG layout math: 1600x900 viewBox.
// Doors live in the lower 60% (y=420..820). Six doors, evenly spaced.
const doorAreaTop = 430;
const doorAreaBottom = 830;
const doorWidth = 180;
const doorHeight = doorAreaBottom - doorAreaTop;
const sideMargin = 80;
const usableWidth = 1600 - sideMargin * 2;
const gap = (usableWidth - doors.length * doorWidth) / (doors.length - 1);
---

<section class="illustrated-lobby" aria-label="Library lobby — choose a room">
  <div class="lobby-svg-wrap">
    <svg
      class="lobby-svg"
      viewBox="0 0 1600 900"
      role="img"
      aria-labelledby="lobby-title lobby-desc"
      preserveAspectRatio="xMidYMid meet"
    >
      <title id="lobby-title">America's School Trust Library — Lobby</title>
      <desc id="lobby-desc">
        An illustrated lobby with a three-panel thesis poster hung above
        the entrances and six labeled doors leading to the Reading Room,
        Atlas, Counting House, Map Room, Newsroom, and Voices.
      </desc>

      <!-- Wall + ceiling. Warm-cream backdrop with a thin gold crown rule. -->
      <rect x="0" y="0" width="1600" height="900" fill="#F5EFDF" />
      <rect x="0" y="0" width="1600" height="36" fill="#EDE3CA" />
      <rect x="0" y="34" width="1600" height="2" fill="var(--old-gold)" opacity="0.65" />
      <rect x="0" y="40" width="1600" height="1" fill="var(--old-gold)" opacity="0.35" />

      <!-- Floor line and floor shadow. -->
      <rect x="0" y="830" width="1600" height="70" fill="#E8DEC4" />
      <rect x="0" y="830" width="1600" height="2" fill="var(--rule-border)" />
      <rect x="0" y="828" width="1600" height="6" fill="rgba(31,42,68,0.06)" />

      <!-- Three-panel thesis poster. Centered above the doors.
           Total poster width 1080, height 280. Center = (800, 230). -->
      <g aria-hidden="true">
        <!-- Outer gold frame -->
        <rect
          x="258"
          y="86"
          width="1084"
          height="284"
          fill="none"
          stroke="var(--old-gold)"
          stroke-width="3"
        />
        <rect
          x="262"
          y="90"
          width="1076"
          height="276"
          fill="#FFFDF7"
          stroke="var(--old-gold)"
          stroke-width="1"
          opacity="0.95"
        />
        <!-- Three panel dividers -->
        <line x1="620" y1="100" x2="620" y2="356" stroke="var(--rule-border)" stroke-width="1" />
        <line x1="980" y1="100" x2="980" y2="356" stroke="var(--rule-border)" stroke-width="1" />

        <!-- Panel 1: 1785 -->
        <text
          x="441"
          y="200"
          text-anchor="middle"
          font-family="Source Serif 4, Georgia, serif"
          font-weight="900"
          font-size="78"
          fill="var(--deep-navy)"
        >1785</text>
        <text
          x="441"
          y="252"
          text-anchor="middle"
          font-family="Inter, system-ui, sans-serif"
          font-weight="500"
          font-size="22"
          fill="var(--ink)"
        >the experiment begins</text>

        <!-- Panel 2: 240 years -->
        <text
          x="800"
          y="200"
          text-anchor="middle"
          font-family="Source Serif 4, Georgia, serif"
          font-weight="900"
          font-size="68"
          fill="var(--deep-navy)"
        >240 years</text>
        <text
          x="800"
          y="252"
          text-anchor="middle"
          font-family="Inter, system-ui, sans-serif"
          font-weight="500"
          font-size="22"
          fill="var(--ink)"
        >of drift</text>

        <!-- Panel 3: 2026 -->
        <text
          x="1160"
          y="200"
          text-anchor="middle"
          font-family="Source Serif 4, Georgia, serif"
          font-weight="900"
          font-size="78"
          fill="var(--deep-navy)"
        >2026</text>
        <text
          x="1160"
          y="246"
          text-anchor="middle"
          font-family="Inter, system-ui, sans-serif"
          font-weight="500"
          font-size="20"
          fill="var(--ink)"
        >the architects of the next</text>
        <text
          x="1160"
          y="272"
          text-anchor="middle"
          font-family="Inter, system-ui, sans-serif"
          font-weight="500"
          font-size="20"
          fill="var(--ink)"
        >century's trusts</text>
      </g>

      <!-- Doors. Each door is wrapped in <a> with an aria-label and href. -->
      {doors.map((d, i) => {
        const x = sideMargin + i * (doorWidth + gap);
        const labelPlateY = doorAreaTop - 28;
        const stripeY = doorAreaTop + 4;
        const doorBodyY = doorAreaTop + 18;
        const doorBodyHeight = doorHeight - 22;
        const cx = x + doorWidth / 2;
        return (
          <a
            href={d.href}
            class="lobby-door"
            aria-label={d.ariaLabel}
          >
            <g class="door">
              {/* Engraved gold label plaque above the door */}
              <rect
                x={x - 4}
                y={labelPlateY - 18}
                width={doorWidth + 8}
                height={26}
                fill="#F0E2BA"
                stroke="var(--old-gold)"
                stroke-width="1"
              />
              <text
                x={cx}
                y={labelPlateY}
                text-anchor="middle"
                font-family="Source Serif 4, Georgia, serif"
                font-weight="700"
                font-size="18"
                fill="var(--deep-navy)"
                letter-spacing="0.5"
              >{d.label}</text>

              {/* Accent color stripe at top of door */}
              <rect
                x={x}
                y={stripeY}
                width={doorWidth}
                height={14}
                fill={d.stripe}
                rx="2"
              />

              {/* Door body — rounded-top tall rectangle with a slight inner panel */}
              <rect
                x={x}
                y={doorBodyY}
                width={doorWidth}
                height={doorBodyHeight}
                fill="#3E5168"
                rx="6"
              />
              <rect
                x={x + 14}
                y={doorBodyY + 14}
                width={doorWidth - 28}
                height={doorBodyHeight - 28}
                fill="#4A6079"
                rx="3"
              />
              {/* Door panel center crease */}
              <line
                x1={cx}
                y1={doorBodyY + 28}
                x2={cx}
                y2={doorBodyY + doorBodyHeight - 28}
                stroke="#2C3D52"
                stroke-width="1.5"
                opacity="0.7"
              />
              {/* Doorknob */}
              <circle
                cx={x + doorWidth - 24}
                cy={doorBodyY + doorBodyHeight / 2}
                r="4"
                fill="var(--old-gold)"
              />

              {/* Floor shadow under door */}
              <ellipse
                cx={cx}
                cy={doorAreaBottom + 2}
                rx={doorWidth / 2 - 6}
                ry="4"
                fill="rgba(31,42,68,0.18)"
              />
            </g>
          </a>
        );
      })}
    </svg>
  </div>

  <div class="lobby-cta-row">
    <button
      type="button"
      class="lobby-tour-cta"
      data-open-walking-tour
      aria-label="Show me around the Library"
    >
      Show me around the Library
    </button>
  </div>

  <p class="lobby-thesis">
    Lands and funds set aside since 1785 to support America's public K-12 schools.
  </p>
</section>

---
// A Forever Gift campus pass: the Library is now framed as the Record
// pillar of the schooltrusts.org family, not as an Eighth Anchor
// Institute campus building.
import ReferenceDeskFooter from './ReferenceDeskFooter.astro';
import FeedbackLink from './FeedbackLink.astro';
import CorrectionLink from './CorrectionLink.astro';
---
<footer data-pagefind-ignore class="site-footer">
  <ReferenceDeskFooter />
  <FeedbackLink />
  <CorrectionLink />
  <div class="footer-credit">
    <p>
      <strong>America's School Trust Library</strong> is the Record pillar of
      <a href="https://schooltrusts.org" rel="noopener">A Forever Gift</a>:
      the public archive of school-trust law, history, accounting, and case
      materials. The family map lives at schooltrusts.org:
      <a href="https://schooltrusts.org/record" rel="noopener">the Record</a>,
      <a href="https://schooltrusts.org/advocates" rel="noopener">the Advocates</a>,
      and <a href="https://schooltrusts.org/renewal" rel="noopener">the Renewal</a>.
    </p>
    <p class="footer-pro-links">
      Institutional documentation: <a href="/pro/governance/">Governance</a> ·
      <a href="/pro/editorial-standards/">Editorial Standards</a> ·
      <a href="/pro/">Pro</a>.
    </p>
    <p class="footer-about-links">
      For readers: <a href="/about/contributing/">Contributing</a> ·
      <a href="/about/founder/">From the Founder</a> ·
      <a href="/about/cite/">How to Cite</a> ·
      <a href="/about/rights/">Rights &amp; Takedown</a> ·
      <a href="/about/corrections/">Corrections</a> ·
      <a href="/about/becoming/">Building This Library</a>.
    </p>
    <p class="footer-prototype-disclosure">
      <em>Prototype build — imagery and design under iterative refinement.
      Final visual identity to be reviewed before broader release.</em>
    </p>
  </div>
  <div class="footer-meta">
    <p>
      Library substrate · Schools of the Republic · Stewards of the Republic ·
      Architecture per Plan_v2.1 · Oregon History dossier (2026-05-17) ·
      Court Room Case File (2026-05-17) · Founders' Cabinet (2026-05-17) ·
      Fiduciary Doctrine reference (2026-05-17) · Site rebuilt May 2026.
    </p>
    <p>
      Content licensed CC BY-SA 4.0 except where noted. Citation guidance and corrections:
      <a href="/about/cite/">/about/cite</a>. Source repository:
      <a href="https://github.com/dave-schooltrustlands/schooltrustlands-encyclopedia">GitHub</a>.
    </p>
    <p>
      Active litigation: <em>Advocates for School Trust Lands v. State of Oregon</em>,
      Coos County Circuit Court 24CV38372, Oregon Court of Appeals (2026).
      <a href="/court/oregon-current-case/">Case docket</a>.
    </p>
    {/* v9 D.2 — small footer seal mark. Library Mode reveals; Reference
        and Standard hide. The image lands separately Cowork-side; until
        then onerror hides the broken-image glyph. Placed at the very
        bottom of footer-meta so Gamma's reference-desk-footer block
        above is unaffected. */}
    <p class="library-seal-footer-wrap">
      <button
        type="button"
        class="library-seal-button"
        data-seal-trigger
        aria-label="View library seal larger"
      >
        <img
          src="/seal/library-seal-v1.png"
          alt="America's School Trust Library seal"
          class="library-seal library-seal--footer"
          onerror="this.style.display='none'"
        />
      </button>
    </p>
  </div>
</footer>

---
import BaseHead from '../components/BaseHead.astro';
import EAIUtilityBar from '../components/EAIUtilityBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PrepublicationFooter from '../components/PrepublicationFooter.astro';
import RoomBanner from '../components/RoomBanner.astro';
import RoomOrnament from '../components/library/RoomOrnament.astro';
import SealLightbox from '../components/library/SealLightbox.astro';

interface Props {
  title: string;
  description?: string;
  sourceId?: string;
  // Optional banner for editorial surfaces (Voices, Newsroom) that
  // sit on BaseLayout rather than RoomLayout. v11 B.1 — banner mount
  // hoisted out of per-page bodies into the layout so the contract
  // mirrors RoomLayout's slot-above-h1 placement without per-page
  // re-mounting. Pages on BaseLayout that have no banner simply
  // omit the prop.
  // v12 BETA — `room` also drives data-room (per-room palette) and
  // RoomOrnament mounting, mirroring RoomLayout's contract.
  room?: 'voices' | 'newsroom';
  // v39 — page-level override for the footer Submit-Feedback kind.
  // /about/becoming/ sets 'institutional_formation' so submissions
  // route to the founding-officers queue. Other pages leave it unset
  // and the modal writes the default 'general' kind.
  feedbackKind?: 'general' | 'institutional_formation';
}

const { title, description, sourceId, room, feedbackKind } = Astro.props;

const ornamentShapeByRoom: Record<NonNullable<Props['room']>, 'mic' | 'newspaper'> = {
  voices: 'mic',
  newsroom: 'newspaper',
};
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description}>
      <slot name="head" />
    </BaseHead>
  </head>
  <body
    class="min-h-screen bg-archive-paper text-ink mode-library"
    data-source-id={sourceId}
    data-room={room}
    data-feedback-kind={feedbackKind}
  >
    <EAIUtilityBar />
    <Header />
    <main class="mx-auto max-w-prose p-4 sm:p-8 room-main">
      {room && <RoomOrnament shape={ornamentShapeByRoom[room]} />}
      {room && <RoomBanner room={room} />}
      <slot />
    </main>
    <PrepublicationFooter />
    <Footer />
    <SealLightbox />
  </body>
</html>

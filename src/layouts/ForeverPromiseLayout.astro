---
// Private review-edition layout for THE FOREVER PROMISE.
// Self-contained on purpose: no site Header/Footer, no analytics beyond the
// site's own, no links out to (or in from) public navigation. noindex everywhere.
interface Props {
  title: string;
  eyebrow?: string;
  kind?: string;
  pageSlug?: string;   // enables the suggest-a-change apparatus when set
  suggest?: boolean;
}
const { title, eyebrow = '', kind = 'page', pageSlug = '', suggest = false } = Astro.props;
const BASE = '/writing/forever-promise';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow, noarchive" />
  <title>{title} · The Forever Promise</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Public+Sans:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />
</head>
<body data-kind={kind}>
  <a class="fp-skip" href="#fp-reading">Skip to the book</a>
  <nav class="fp-bar">
    <span class="fp-bar-brand">
      <a class="fp-bar-title" href={`${BASE}/`}>The Forever Promise</a>
      <span class="fp-bar-tag">Advance review copy</span>
    </span>
    <span class="fp-bar-links">
      <a href={`${BASE}/`}>Contents</a>
      <a href={`${BASE}/figures/`}>Figures</a>
      <a href={`${BASE}/how-this-works/`}>How to help</a>
      {suggest && <button class="fp-review-toggle" type="button" aria-pressed="false">Review notes</button>}
    </span>
    <span class="fp-progress" aria-hidden="true"><span></span></span>
  </nav>
  <main class="fp-main" id="fp-reading">
    <slot />
  </main>
  <footer class="fp-foot">
    <p>Advance review copy — July 2026. Not for sale or citation.</p>
    <p>America's School Trust Library · private reading room for the review crew</p>
  </footer>

  <script is:inline>
    (function () {
      var root = document.documentElement;
      var progress = document.querySelector('.fp-progress span');
      function paintProgress() {
        if (!progress) return;
        var available = root.scrollHeight - window.innerHeight;
        var ratio = available > 0 ? Math.min(1, Math.max(0, window.scrollY / available)) : 0;
        progress.style.transform = 'scaleX(' + ratio + ')';
      }
      paintProgress();
      window.addEventListener('scroll', paintProgress, { passive: true });
      window.addEventListener('resize', paintProgress);

      var toggle = document.querySelector('.fp-review-toggle');
      if (!toggle) return;
      function setReview(on) {
        document.body.classList.toggle('fp-review-mode', on);
        toggle.setAttribute('aria-pressed', on ? 'true' : 'false');
      }
      setReview(sessionStorage.getItem('fp_review_mode') === 'on');
      toggle.addEventListener('click', function () {
        var on = !document.body.classList.contains('fp-review-mode');
        sessionStorage.setItem('fp_review_mode', on ? 'on' : 'off');
        setReview(on);
      });
    })();
  </script>

  {suggest && (
    <script is:inline define:vars={{ pageSlug }}>
      (function () {
        var page = pageSlug;
        var openBox = null;
        function el(tag, cls, text) { var e = document.createElement(tag); if (cls) e.className = cls; if (text) e.textContent = text; return e; }
        function closeBox() { if (openBox) { openBox.remove(); openBox = null; } }
        function snippetOf(p) {
          var t = (p.innerText || '').replace(/\s+/g, ' ').trim();
          return t.length > 240 ? t.slice(0, 240) + '…' : t;
        }
        function buildForm(anchor, pid, snippet, kind) {
          closeBox();
          var box = el('div', 'fp-sug-box');
          var head = el('p', 'fp-sug-head', kind === 'general' ? 'A note on this whole section' : 'Suggest a change');
          box.appendChild(head);
          if (kind !== 'general') {
            var q = el('p', 'fp-sug-quote', '“' + snippet + '”');
            box.appendChild(q);
          }
          var nameLab = el('label', 'fp-sug-label', 'Your name');
          var name = el('input', 'fp-sug-name'); name.type = 'text';
          name.value = localStorage.getItem('fp_name') || '';
          var sugLab = el('label', 'fp-sug-label', kind === 'general' ? 'Your note' : 'What would you change, and to what?');
          var ta = el('textarea', 'fp-sug-text'); ta.rows = 4;
          var row = el('div', 'fp-sug-row');
          var send = el('button', 'fp-sug-send', 'Send to the writing crew'); send.type = 'button';
          var cancel = el('button', 'fp-sug-cancel', 'Cancel'); cancel.type = 'button';
          row.appendChild(send); row.appendChild(cancel);
          box.appendChild(nameLab); box.appendChild(name);
          box.appendChild(sugLab); box.appendChild(ta);
          box.appendChild(row);
          cancel.addEventListener('click', closeBox);
          send.addEventListener('click', function () {
            var suggestion = ta.value.trim();
            if (!suggestion) { ta.focus(); return; }
            localStorage.setItem('fp_name', name.value.trim());
            send.disabled = true; send.textContent = 'Sending…';
            fetch('/api/fp-suggest', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ page: page, pid: pid, snippet: snippet, name: name.value.trim(), suggestion: suggestion, kind: kind }),
            }).then(function (r) { return r.ok ? r.json() : Promise.reject(r.status); }).then(function () {
              box.innerHTML = '';
              box.appendChild(el('p', 'fp-sug-done', 'Received — thank you. The writing crew will fold this into the next draft.'));
              setTimeout(closeBox, 4000);
            }).catch(function () {
              send.disabled = false; send.textContent = 'Send to the writing crew';
              var err = box.querySelector('.fp-sug-err') || box.insertBefore(el('p', 'fp-sug-err'), row);
              err.textContent = 'That didn’t go through — please try once more, or copy your note and email it to the crew.';
            });
          });
          anchor.insertAdjacentElement('afterend', box);
          openBox = box;
          ta.focus();
        }
        var art = document.querySelector('article.fp-body');
        if (art) {
          var ps = art.querySelectorAll('p[data-pid]');
          ps.forEach(function (p, index) {
            var b = el('button', 'fp-sug-btn', '✎');
            b.type = 'button';
            b.title = 'Suggest a change to this paragraph';
            b.setAttribute('aria-label', 'Suggest a change to paragraph ' + (index + 1) + ': ' + snippetOf(p).slice(0, 64));
            p.appendChild(b);
            b.addEventListener('click', function () { buildForm(p, p.getAttribute('data-pid'), snippetOf(p), 'paragraph'); });
          });
        }
        var gen = document.getElementById('fp-general-open');
        if (gen) gen.addEventListener('click', function () { buildForm(gen, 'general', '', 'general'); });
      })();
    </script>
  )}
</body>
</html>

<style is:global>
  :root {
    --fp-ink: #1a1a2e; --fp-navy: #1b3252; --fp-deep: #14243c;
    --fp-gold: #a87f2c; --fp-gold-dark: #765719; --fp-cream: #f5f1e8; --fp-linen: #fffdf7;
    --fp-rule: #d8d1c2; --fp-serif: 'EB Garamond', Georgia, serif;
    --fp-sans: 'Public Sans', system-ui, sans-serif;
  }
  html { background: var(--fp-linen); scroll-behavior: smooth; }
  body { margin: 0; color: var(--fp-ink); font-family: var(--fp-serif);
    background:
      linear-gradient(90deg, rgba(27,50,82,.018) 1px, transparent 1px) 0 0 / 4rem 4rem,
      var(--fp-linen); }
  .fp-skip { position: fixed; z-index: 100; left: 1rem; top: -5rem; background: #fff; color: var(--fp-deep);
    font-family: var(--fp-sans); font-weight: 700; padding: .7rem 1rem; border: 2px solid var(--fp-gold); }
  .fp-skip:focus { top: 1rem; }

  .fp-bar { position: sticky; top: 0; z-index: 40; display: flex; align-items: center; gap: 1rem;
    background: rgba(20,36,60,.985); color: var(--fp-cream); min-height: 2.75rem; padding: 0 1.4rem;
    box-shadow: 0 1px 0 rgba(255,255,255,.08); font-family: var(--fp-sans); }
  .fp-bar-brand { display: flex; align-items: baseline; gap: .95rem; min-width: 0; }
  .fp-bar-title { color: var(--fp-cream); text-decoration: none; font-family: var(--fp-serif); font-style: italic; font-size: 1.05rem; white-space: nowrap; }
  .fp-bar-tag { font-size: 0.59rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: #c9a85b; white-space: nowrap; }
  .fp-bar-links { margin-left: auto; display: flex; align-items: center; gap: 1.05rem; }
  .fp-bar-links a, .fp-review-toggle { color: #e8e2d4; text-decoration: none; font: 500 0.75rem/1 var(--fp-sans);
    letter-spacing: 0.025em; border: 0; border-bottom: 1px solid transparent; background: none; padding: .45rem 0; cursor: pointer; }
  .fp-bar-links a:hover, .fp-bar-links a:focus-visible, .fp-review-toggle:hover, .fp-review-toggle:focus-visible {
    color: #fff; border-bottom-color: var(--fp-gold); outline: none; }
  .fp-review-toggle[aria-pressed='true'] { color: #fff; border-bottom-color: #c9a85b; }
  .fp-progress { position: absolute; height: 2px; left: 0; right: 0; bottom: -2px; overflow: hidden; background: rgba(255,255,255,.06); }
  .fp-progress span { display: block; width: 100%; height: 100%; background: var(--fp-gold); transform: scaleX(0); transform-origin: left center; }

  .fp-main { max-width: 46rem; margin: 0 auto; padding: 3.4rem 1.4rem 5rem; }
  body[data-kind='home'] .fp-main { max-width: 76rem; padding-top: 3.2rem; }

  .fp-eyebrow { font-family: var(--fp-sans); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--fp-gold); margin: 0 0 0.55rem; }
  .fp-eyebrow::before { content: ''; display: block; width: 3.2rem; border-top: 2px solid var(--fp-gold); margin-bottom: 0.55rem; }
  h1.fp-title { font-family: var(--fp-serif); font-style: italic; font-weight: 600; color: var(--fp-navy);
    font-size: 2.15rem; line-height: 1.2; margin: 0 0 0.4rem; }
  .fp-titlemeta { font-family: var(--fp-sans); font-size: 0.78rem; color: #6b6455; margin: 0.4rem 0 0; }
  .fp-chapter-head { padding-bottom: 1.4rem; border-bottom: 1px solid rgba(216,209,194,.72); }
  .fp-chapter-deck { max-width: 35rem; margin: .8rem 0 .7rem; color: #4f493f; font-size: 1.22rem; line-height: 1.45; font-style: italic; }

  article.fp-body { margin-top: 2.4rem; font-size: 1.16rem; line-height: 1.72; }
  article.fp-body p { margin: 0 0 1.05em; position: relative; }
  article.fp-body h2 { font-family: var(--fp-serif); font-weight: 600; color: var(--fp-navy); font-size: 1.5rem; line-height: 1.3; margin: 2.2em 0 0.7em; }
  article.fp-body h3 { font-family: var(--fp-serif); font-style: italic; font-weight: 600; color: var(--fp-navy); font-size: 1.22rem; margin: 1.9em 0 0.6em; }
  article.fp-body blockquote { margin: 1.4em 0 1.4em 0.2em; padding: 0.1em 0 0.1em 1.1em; border-left: 1px solid var(--fp-navy);
    font-style: italic; color: #2a2a40; }
  article.fp-body blockquote em { font-style: normal; }
  article.fp-body hr { border: none; text-align: center; margin: 2.2em 0; }
  article.fp-body hr::after { content: '❦'; color: var(--fp-gold); font-size: 1.05rem; }
  article.fp-body a { color: var(--fp-navy); text-decoration: underline; text-decoration-color: rgba(27,50,82,0.4); text-underline-offset: 2px; }
  article.fp-body a:hover { text-decoration-color: var(--fp-gold); }
  article.fp-body table { border-collapse: collapse; font-family: var(--fp-sans); font-size: 0.86rem; line-height: 1.5; margin: 1.6em 0; width: 100%; }
  article.fp-body th { text-align: left; background: var(--fp-cream); color: var(--fp-deep); font-weight: 700; }
  article.fp-body th, article.fp-body td { border: 1px solid var(--fp-rule); padding: 0.45rem 0.6rem; vertical-align: top; }
  article.fp-body sup.footnote-ref a { text-decoration: none; color: var(--fp-gold); font-family: var(--fp-sans); font-size: 0.72em; }
  .footnotes-sep { display: none; }
  section.footnotes { margin-top: 3rem; border-top: 1px solid var(--fp-rule); padding-top: 1.2rem; font-size: 0.95rem; line-height: 1.6; color: #3a3a4e; }
  section.footnotes ol { padding-left: 1.4rem; }
  section.footnotes li { margin-bottom: 0.55em; }
  a.footnote-backref { text-decoration: none; }

  /* Image plates: wider than the prose, like the color signatures in a large-format book. */
  .fp-fig { display: block; box-sizing: border-box; width: min(61rem, calc(100vw - 3rem)); margin: 3.3rem 50%;
    transform: translateX(-50%); background: #f2eee4; border: 1px solid #d5cbb8; padding: 1rem 1rem 1.1rem;
    box-shadow: 0 1.25rem 3rem rgba(20,36,60,.065); }
  .fp-fig-eyebrow { display: block; font-family: var(--fp-sans); font-size: 0.69rem; font-weight: 700; letter-spacing: 0.18em;
    color: var(--fp-gold-dark); margin: .15rem .25rem .75rem; }
  .fp-fig-art { display: block; background: var(--fp-linen); border: 1px solid #ddd5c7; margin-bottom: 1rem; overflow: hidden; }
  .fp-fig-image { display: block; position: relative; }
  .fp-fig-image::after { content: 'Open full size'; position: absolute; right: .7rem; bottom: .65rem; padding: .35rem .5rem;
    background: rgba(20,36,60,.88); color: #fff; font: 600 .62rem/1 var(--fp-sans); letter-spacing: .05em;
    opacity: 0; transform: translateY(.25rem); transition: opacity .16s, transform .16s; }
  .fp-fig-image:hover::after, .fp-fig-image:focus-visible::after { opacity: 1; transform: none; }
  .fp-fig-art img { display: block; width: 100%; height: auto; }
  .fp-fig-hold { display: flex; align-items: center; justify-content: center; text-align: center; min-height: 7.5rem; padding: 1.4rem 1.2rem;
    font-family: var(--fp-sans); font-size: 0.92rem; color: var(--fp-navy); }
  .fp-fig-cap { display: block; max-width: 49rem; margin: 0 .25rem; font-family: var(--fp-serif); font-size: 1rem; line-height: 1.48; color: #292936; }
  .fp-fig-cap.fp-fig-desc { font-style: italic; color: #55554f; }
  .fp-fig-status { display: inline-block; margin: .8rem .25rem 0; padding: .26rem .45rem; border: 1px solid #dacba7;
    background: rgba(255,253,247,.68); font-family: var(--fp-sans); font-size: 0.63rem; line-height: 1.25; letter-spacing: 0.035em; color: #75674a; }
  .fp-fig-status::before { content: 'PROOF · '; color: var(--fp-gold-dark); font-weight: 700; }
  .fp-fig-link { display: inline-block; margin: .8rem .25rem 0 .65rem; font-family: var(--fp-sans); font-size: 0.7rem; font-weight: 600; color: var(--fp-navy); text-decoration: none; border-bottom: 1px solid var(--fp-gold); }
  .fp-fig-link:hover { color: var(--fp-gold); }
  .fp-fig[data-figure-state='awaiting'] { width: min(46rem, calc(100vw - 3rem)); box-shadow: none; }
  .fp-fig[data-figure-state='placeholder'] { background: #f4f0e7; }
  a.fp-callout { color: var(--fp-navy); text-decoration: underline dotted; text-decoration-color: var(--fp-gold); text-underline-offset: 2px; }

  /* Prev / next */
  .fp-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 0.9rem; margin-top: 3.2rem; font-family: var(--fp-sans); }
  .fp-nav a { display: block; background: var(--fp-cream); border: 1px solid var(--fp-rule); padding: 0.8rem 1rem; text-decoration: none; color: var(--fp-navy); }
  .fp-nav a:hover { border-color: var(--fp-gold); }
  .fp-nav .lab { display: block; font-size: 0.66rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--fp-gold); margin-bottom: 0.25rem; }
  .fp-nav .ttl { font-family: var(--fp-serif); font-style: italic; font-size: 1.02rem; }
  .fp-nav .next { text-align: right; grid-column: 2; }

  /* Broadside (the Muster) */
  body[data-kind='muster'] article.fp-body { background: var(--fp-cream); border: 3px double var(--fp-navy); outline: 1px solid var(--fp-rule);
    padding: 2.4rem 2rem; text-align: center; }
  body[data-kind='muster'] article.fp-body p { margin-bottom: 1.2em; }
  body[data-kind='muster'] article.fp-body strong { font-family: var(--fp-sans); letter-spacing: 0.12em; color: var(--fp-navy); }

  /* Part opener */
  body[data-kind='part'] .fp-opener { position: relative; overflow: hidden; background: var(--fp-deep); color: var(--fp-cream);
    border: 1px solid #0e1d32; padding: clamp(2.5rem, 7vw, 5.8rem) clamp(1.6rem, 6vw, 4rem); margin: 0 -5rem 3.5rem;
    box-shadow: 0 1.6rem 3.8rem rgba(20,36,60,.13); }
  body[data-kind='part'] .fp-opener::after { content: ''; position: absolute; width: 21rem; height: 21rem; right: -7rem; bottom: -8rem;
    opacity: .22; background:
      linear-gradient(rgba(255,255,255,.55) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.55) 1px, transparent 1px);
    background-size: 3.5rem 3.5rem; transform: rotate(-7deg); }
  body[data-kind='part'] .fp-opener .fp-eyebrow { color: #c9a85b; position: relative; z-index: 1; }
  body[data-kind='part'] .fp-opener .fp-eyebrow::before { border-color: #c9a85b; }
  body[data-kind='part'] h1.fp-title { position: relative; z-index: 1; max-width: 34rem; color: #fffaf0; font-size: clamp(2.7rem, 6vw, 4.8rem); line-height: .98; }
  body[data-kind='part'] .fp-titlemeta { position: relative; z-index: 1; color: #d2c9b7; margin-top: 1.1rem; }
  body[data-kind='part'] .fp-titlemeta a { color: #fff; }
  body[data-kind='part'] .fp-opener-art-led { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0; box-shadow: none; }
  body[data-kind='part'] .fp-opener-art-led + article.fp-body { margin-top: 0; }
  body[data-kind='part'] article.fp-body > h2:first-child { display: none; }
  body[data-kind='part'] article.fp-body > .fp-fig:first-of-type { margin-top: 0; }
  body[data-kind='part'] article.fp-body > .fp-fig:first-of-type .fp-fig-eyebrow,
  body[data-kind='part'] article.fp-body > .fp-fig:first-of-type .fp-fig-cap,
  body[data-kind='part'] article.fp-body > .fp-fig:first-of-type .fp-fig-status,
  body[data-kind='part'] article.fp-body > .fp-fig:first-of-type .fp-fig-link { display: none; }
  body[data-kind='part'] article.fp-body > .fp-fig:first-of-type .fp-fig-art { margin-bottom: 0; }

  /* Suggest apparatus */
  .fp-sug-btn { position: static; display: inline-block; margin-left: 0.45rem; padding: 0 0.3rem; border: none; background: none;
    color: var(--fp-gold); font-size: 0.85em; line-height: 1; cursor: pointer; opacity: 0; transition: opacity 0.15s; vertical-align: baseline; }
  body.fp-review-mode article.fp-body p:hover .fp-sug-btn,
  body.fp-review-mode .fp-sug-btn:focus { opacity: 0.9; }
  body:not(.fp-review-mode) .fp-sug-btn { display: none; }
  @media (hover: none) { body.fp-review-mode .fp-sug-btn { opacity: 0.72; } }
  .fp-sug-box { background: var(--fp-linen); border: 1px solid var(--fp-gold); border-left-width: 3px; padding: 1rem 1.1rem; margin: 0.8rem 0 1.4rem; font-family: var(--fp-sans); }
  .fp-sug-head { margin: 0 0 0.5rem; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--fp-navy); }
  .fp-sug-quote { margin: 0 0 0.7rem; font-family: var(--fp-serif); font-style: italic; font-size: 0.95rem; color: #55555f; }
  .fp-sug-label { display: block; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #6b6455; margin: 0.7rem 0 0.25rem; }
  .fp-sug-name, .fp-sug-text { width: 100%; box-sizing: border-box; border: 1px solid var(--fp-rule); border-radius: 3px; background: #fff;
    font-family: var(--fp-sans); font-size: 0.92rem; padding: 0.45rem 0.55rem; }
  .fp-sug-row { display: flex; gap: 0.6rem; margin-top: 0.8rem; }
  .fp-sug-send { background: var(--fp-navy); color: var(--fp-linen); border: none; border-radius: 3px; padding: 0.5rem 0.9rem; font-family: var(--fp-sans); font-weight: 700; font-size: 0.8rem; cursor: pointer; }
  .fp-sug-send:hover { background: var(--fp-deep); }
  .fp-sug-cancel { background: none; border: 1px solid var(--fp-rule); border-radius: 3px; padding: 0.5rem 0.9rem; font-size: 0.8rem; color: #6b6455; cursor: pointer; }
  .fp-sug-done { margin: 0; font-size: 0.92rem; color: #2f6f4e; font-weight: 600; }
  .fp-sug-err { margin: 0.5rem 0 0; font-size: 0.8rem; color: #7a2e2e; }
  .fp-general { display: none; margin-top: 3rem; border-top: 1px solid var(--fp-rule); padding-top: 1.4rem; }
  body.fp-review-mode .fp-general { display: block; }
  .fp-general p { font-size: 1rem; font-style: italic; color: #55554f; }
  #fp-general-open { background: none; border: 1px solid var(--fp-gold); border-radius: 3px; color: var(--fp-navy);
    font-family: var(--fp-sans); font-size: 0.82rem; font-weight: 600; padding: 0.55rem 1rem; cursor: pointer; }
  #fp-general-open:hover { background: var(--fp-cream); }

  .fp-foot { border-top: 1px solid var(--fp-rule); margin-top: 2rem; padding: 1.6rem 1.4rem 2.4rem; text-align: center;
    font-family: var(--fp-sans); font-size: 0.74rem; color: #8a8272; }
  .fp-foot p { margin: 0.2rem 0; }
  @media (max-width: 760px) {
    .fp-bar { align-items: stretch; flex-direction: column; gap: 0; padding: .5rem 1rem .55rem; }
    .fp-bar-brand { justify-content: space-between; gap: .75rem; }
    .fp-bar-links { width: 100%; margin: .3rem 0 0; justify-content: flex-start; gap: 1rem; overflow-x: auto; }
    .fp-bar-links a, .fp-review-toggle { display: inline-flex; align-items: center; min-height: 40px; padding-top: 0; padding-bottom: 0; white-space: nowrap; }
    .fp-main, body[data-kind='home'] .fp-main { padding: 2.2rem 1.25rem 4rem; }

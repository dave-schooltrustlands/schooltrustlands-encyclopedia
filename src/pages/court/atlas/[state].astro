---
// v3.2.1 — Per-state dossier under /court/atlas/{code}/. Static-generated
// from src/data/court-states.json with linked case annotations pulled
// from src/data/court-cases.json. Phase 2 substrate content for twelve
// states (AK, AZ, CO, ID, LA, MS, MT, NE, OK, SD, UT, WA) is loaded
// from the court-atlas collection and rendered as long-form dossier
// sections in place of the Phase 1 placeholders. v3.2.1 inlines the
// Notable AG opinions section from court-opinions.json (filtered by
// state) so the standalone /court/opinions/ page can collapse.
import { getCollection } from 'astro:content';
import RoomLayout from '../../../layouts/RoomLayout.astro';
import statesData from '../../../data/court-states.json';
import casesData from '../../../data/court-cases.json';
import opinionsData from '../../../data/court-opinions.json';

type StateRecord = {
  name: string;
  enablingAct: string;
  enablingActYear: number;
  trustFundCurrentValue: number | null;
  trustFundAsOf: string | null;
  agOpinionCount: number;
  keyCases: string[];
  trustIntegrityGrade:
    | 'pending'
    | 'intact-and-funded'
    | 'breached-and-recovered'
    | 'breached-and-uncorrected'
    | 'under-review';
  summary: string;
  advocacyContact: string;
};

type CaseRecord = {
  caseName: string;
  citation: string;
  court: string;
  year: number;
  holding: string;
  whyItMatters: string;
  url?: string;
};

type OpinionRecord = {
  state: string;
  citation: string;
  year: number;
  issueTags: string[];
  summary: string;
  pdfUrl: string | null;
};

const states = statesData as Record<string, StateRecord>;
const cases = casesData as Record<string, CaseRecord>;
const opinions = opinionsData as Record<string, OpinionRecord>;

export async function getStaticPaths() {
  const stateCodes = Object.keys(statesData as Record<string, unknown>);
  const dossiers = await getCollection('court-atlas');
  return stateCodes.map((code) => {
    const dossier = dossiers.find(
      (d) => d.data.stateCode.toUpperCase() === code.toUpperCase(),
    );
    return {
      params: { state: code.toLowerCase() },
      props: { code, dossierSlug: dossier?.slug ?? null },
    };
  });
}

const { code, dossierSlug } = Astro.props as {
  code: string;
  dossierSlug: string | null;
};
const state = states[code];
const dossier = dossierSlug
  ? (await getCollection('court-atlas')).find((d) => d.slug === dossierSlug)
  : null;
const DossierContent = dossier ? (await dossier.render()).Content : null;

// Cross-link map: for the per-state Key cases that have annotated
// per-case pages in /court/case-file/, emit a clickable link to that
// page. Slug values match the filenames in src/content/court-cases/
// (with the numeric prefix stripped).
const KEY_CASE_TO_ANNOTATION_SLUG: Record<string, string> = {
  'vincennes-univ-v-indiana-1852': 'vincennes-univ-v-indiana-1852',
  'lassen-v-arizona-1967': 'lassen-v-arizona-1967',
  'andrus-v-utah-1980': 'andrus-v-utah-1980',
  'asarco-v-kadish-1989': 'asarco-v-kadish-1989',
  'united-states-v-new-mexico-1976': 'united-states-v-new-mexico-1976',
  'pettibone-v-mt-1985': 'pettibone-v-mt-1985',
  'skamania-v-state-1984': 'skamania-v-state-1984',
  'ebke-v-neb-1951': 'ebke-v-neb-1951',
  'nigh-v-okla-1982': 'nigh-v-okla-1982',
  'idaho-watersheds-1999': 'idaho-watersheds-1999',
  'national-parks-v-utah-1990': 'npca-v-utah-1993',
};

const GRADE_LABEL: Record<StateRecord['trustIntegrityGrade'], string> = {
  'intact-and-funded': 'Intact and funded',
  'breached-and-recovered': 'Breached and recovered',
  'breached-and-uncorrected': 'Breached and uncorrected',
  'under-review': 'Under review',
  pending: 'Pending — Phase 2',
};

function fmtFund(n: number | null): string {
  if (n === null) return 'Pending';
  const billions = n / 1_000_000_000;
  return billions >= 1 ? `$${billions.toFixed(1).replace(/\.0$/, '')} billion` : `$${(n / 1_000_000).toFixed(0)} million`;
}

const keyCases = state.keyCases
  .map((key) => ({ key, record: cases[key] }))
  .filter((c): c is { key: string; record: CaseRecord } => Boolean(c.record));

// AG opinions filtered to this state, oldest first. As of v3.2.1 only
// Oregon has opinions in substrate (six of them); other states show
// the placeholder until Phase 4 sourcing fans out.
const stateOpinions = Object.values(opinions)
  .filter((o) => o.state === code)
  .sort((a, b) => a.year - b.year);
---
<RoomLayout
  room="court"
  width="prose"
  title={state.name}
  subtitle={`Per-state dossier — Enabling Act, fund, AG opinions, key cases, trust-integrity grade.`}
  sourceId={`court-atlas-${code.toLowerCase()}`}
  parents={[{ label: 'The Atlas', href: '/court/atlas/' }]}
>
  <article class="prose prose-slate max-w-none mt-8 prose-a:text-blue-700 prose-a:underline">
    <span class="eyebrow">Court Room · The Atlas · {state.name}</span>

    <aside class="preview-banner" role="note">
      <strong>First-draft preview.</strong>{' '}
      {DossierContent ? (
        <>
          Per-state dossier seeded from Phase 2 long-form substrate.
          Phase 3 cross-AI review and Phase 4 revision are still pending.
        </>
      ) : (
        <>
          Per-state dossier seeded from Phase 0/1 substrate (Margaret
          Bird's compilation, OASTL legal record, ASTL research). Phase 2
          long-form content under development.
        </>
      )}{' '}
      ← <a href="/court/atlas/">Back to the Atlas</a>.
    </aside>

    <section class={`dossier-card grade-${state.trustIntegrityGrade}`}>
      <header class="dossier-card__header">
        <h2 class="dossier-card__title">At a glance</h2>
        <span class="dossier-card__grade">Trust integrity: {GRADE_LABEL[state.trustIntegrityGrade]}</span>
      </header>
      <dl class="dossier-facts">
        <dt>Enabling Act</dt>
        <dd>{state.enablingAct}</dd>
        <dt>Trust fund value</dt>
        <dd>{fmtFund(state.trustFundCurrentValue)}{state.trustFundAsOf ? ` (as of ${state.trustFundAsOf})` : ''}</dd>
        <dt>AG opinions in substrate</dt>
        <dd>{stateOpinions.length > 0 ? stateOpinions.length : 'Pending — Phase 4 sourcing'}</dd>
        <dt>Key cases</dt>
        <dd>{keyCases.length}</dd>
        <dt>Advocacy contact</dt>
        <dd>{state.advocacyContact}</dd>
      </dl>
    </section>

    {DossierContent ? (
      <section class="phase2-dossier">
        <DossierContent />
        {keyCases.filter((c) => KEY_CASE_TO_ANNOTATION_SLUG[c.key]).length > 0 && (
          <aside class="dossier-crosslinks" aria-label="Annotated in the Case File">
            <h3>Annotated in the Case File</h3>
            <ul>
              {keyCases
                .filter((c) => KEY_CASE_TO_ANNOTATION_SLUG[c.key])
                .map((c) => (
                  <li>
                    <a href={`/court/case-file/${KEY_CASE_TO_ANNOTATION_SLUG[c.key]}/`}>
                      <em>{c.record.caseName}</em>
                    </a>
                    {c.record.citation && (
                      <span class="case-citation"> — {c.record.citation} ({c.record.year})</span>
                    )}
                  </li>
                ))}
            </ul>
          </aside>
        )}
      </section>
    ) : (
      <>
        <h2>Why this state matters</h2>
        <p>{state.summary}</p>

        {keyCases.length > 0 && (
          <>
            <h2>Key cases</h2>
            <ul class="case-list">
              {keyCases.map((c) => {
                const annotationSlug = KEY_CASE_TO_ANNOTATION_SLUG[c.key];
                return (
                  <li>
                    <h3>
                      {annotationSlug ? (
                        <a href={`/court/case-file/${annotationSlug}/`}>
                          <em>{c.record.caseName}</em>
                        </a>
                      ) : (
                        <em>{c.record.caseName}</em>
                      )}
                      {c.record.citation && <span class="case-citation">, {c.record.citation}</span>}
                      <span class="case-year"> ({c.record.year})</span>
                    </h3>
                    <p><strong>Holding.</strong> {c.record.holding}</p>
                    <p><strong>Why it matters.</strong> {c.record.whyItMatters}</p>
                    {c.record.url && (
                      <p>
                        <a href={c.record.url} rel="noopener" target="_blank">Read the opinion →</a>
                      </p>
                    )}
                  </li>
                );
              })}
            </ul>
          </>
        )}

        <h2>Notable AG opinions</h2>
        {stateOpinions.length > 0 ? (
          <div class="opinion-list">
            {stateOpinions.map((o) => (
              <article class="opinion-card">
                <header class="opinion-card__header">
                  <span class="opinion-card__year">{o.year}</span>
                  <h3 class="opinion-card__citation">{o.citation}</h3>
                </header>
                {o.issueTags && o.issueTags.length > 0 && (
                  <ul class="opinion-card__tags">
                    {o.issueTags.map((t) => (
                      <li>{t.replace(/-/g, ' ')}</li>
                    ))}
                  </ul>
                )}
                <p class="opinion-card__summary">{o.summary}</p>
                {o.pdfUrl && (
                  <p>
                    <a href={o.pdfUrl} rel="noopener" target="_blank">PDF →</a>
                  </p>
                )}
              </article>
            ))}
          </div>
        ) : (
          <p>
            AG opinions for {state.name} are being sourced in Phase 4 —
            see the <a href="/court/atlas/">Atlas index</a> for a
            campus-wide search.
          </p>
        )}
      </>
    )}

    <hr class="archival-divider" />

    <p style="font-size: 0.9rem; color: var(--ink); opacity: 0.7;">
      {DossierContent
        ? 'First-draft preview. Phase 2 substrate; Phase 3 cross-AI review and Phase 4 revision still pending.'
        : 'First-draft preview. Substrate sources: Margaret Bird, Trust Land Case Quotes by Topic (2021); OASTL legal.md (2026-05-16); ASTL thematic research (2026-05-17). Phase 2 will deepen this dossier.'}
    </p>
  </article>
</RoomLayout>

<style>
  .preview-banner {
    border-left: 4px solid var(--old-gold, #B88A2E);
    background: rgba(184, 138, 46, 0.08);
    padding: 0.75rem 1rem;
    margin: 1rem 0 1.5rem;
    font-size: 0.95rem;
  }
  .dossier-card {
    margin: 1rem 0 1.75rem;
    padding: 1rem 1.2rem 1.1rem;
    border: 1px solid #cbd5e1;
    border-left-width: 4px;
    border-radius: 6px;
    background: #fff;
  }
  .dossier-card.grade-intact-and-funded         { border-left-color: #166534; }
  .dossier-card.grade-breached-and-recovered    { border-left-color: #B88A2E; }
  .dossier-card.grade-breached-and-uncorrected  { border-left-color: #9b2c2c; }
  .dossier-card.grade-under-review              { border-left-color: #1e3a5f; }
  .dossier-card.grade-pending                   { border-left-color: #94a3b8; }
  .dossier-card__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.55rem;
  }
  .dossier-card__title {
    margin: 0;
    font-size: 1.05rem;
    color: #0f172a;
  }
  .dossier-card__grade {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #475569;
  }
  .dossier-facts {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 0.35rem 0.85rem;
    margin: 0;
  }
  .dossier-facts dt {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #475569;
  }
  .dossier-facts dd {
    margin: 0;
    color: #1f2937;
  }
  @media (max-width: 480px) {
    .dossier-facts {
      grid-template-columns: 1fr;
      gap: 0.1rem 0;
    }
    .dossier-facts dt { margin-top: 0.4rem; }
  }
  .case-list {
    list-style: none;
    padding-left: 0;
    margin: 0.5rem 0 1.5rem;
  }
  .case-list > li {
    margin: 0.5rem 0 1.1rem;
    padding-left: 0.6rem;
    border-left: 2px solid #cbd5e1;
  }
  .case-list h3 {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    line-height: 1.3;
  }
  .case-citation { font-style: normal; color: #334155; }
  .case-year { color: #475569; font-style: normal; }
  .phase2-dossier {
    margin: 0.5rem 0 1rem;
  }
  .phase2-dossier h2 {
    margin-top: 1.6rem;
    font-size: 1.15rem;
    color: #0f172a;
  }
  .phase2-dossier h3 {
    margin-top: 1.1rem;
    font-size: 1rem;
    color: #1e3a5f;
  }
  .dossier-crosslinks {
    margin: 1.5rem 0 0.5rem;
    padding: 0.85rem 1rem;
    border-left: 4px solid #1e3a5f;
    background: #f8fafc;
    font-size: 0.93rem;
  }
  .dossier-crosslinks h3 {
    margin: 0 0 0.5rem;
    font-size: 0.95rem;
    color: #1e3a5f;
    font-family: var(--font-sans);
    letter-spacing: 0.04em;
  }
  .dossier-crosslinks ul {
    margin: 0;
    padding-left: 1.1rem;
  }
  .dossier-crosslinks .case-citation {
    color: #475569;
    font-size: 0.88rem;
  }

  /* v3.2.1 — Notable AG opinions list (mirrors the standalone Opinions
     Library cards that the /court/opinions/ page used to render). */
  .opinion-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin: 0.5rem 0 1.5rem;
  }
  .opinion-card {
    padding: 0.85rem 1rem 0.95rem;
    border: 1px solid #cbd5e1;
    border-left: 4px solid #1e3a5f;
    border-radius: 6px;
    background: #fff;
  }
  .opinion-card__header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.3rem;
    flex-wrap: wrap;
  }
  .opinion-card__year {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 700;
    color: #1e3a5f;
  }
  .opinion-card__citation {
    margin: 0;
    font-size: 1rem;
    color: #0f172a;
    line-height: 1.3;
  }
  .opinion-card__tags {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .opinion-card__tags li {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.12rem 0.45rem;
    background: rgba(30, 58, 95, 0.08);
    border-radius: 999px;
    color: #1e3a5f;
  }
  .opinion-card__summary {
    margin: 0.3rem 0 0.35rem;
    color: #1f2937;
    font-size: 0.93rem;
    line-height: 1.5;
  }
</style>

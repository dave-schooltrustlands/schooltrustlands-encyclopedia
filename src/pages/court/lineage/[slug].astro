---
// v3.1 — Per-milestone Lineage essay page. Renders a single
// court-lineage collection entry as a long-form first-draft essay.
// Phase 3 (cross-AI review) and Phase 4 (revision) are still pending;
// inline [CITE PENDING] flags surface as italic notes via .cite-pending.
import { getCollection, type CollectionEntry } from 'astro:content';
import RoomLayout from '../../../layouts/RoomLayout.astro';

type Props = { entry: CollectionEntry<'court-lineage'> };

export async function getStaticPaths() {
  const entries = await getCollection('court-lineage');
  return entries.map((entry) => ({
    params: { slug: entry.slug.replace(/^\d+-/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props as Props;
const { Content } = await entry.render();
const all = (await getCollection('court-lineage')).sort(
  (a, b) => a.data.order - b.data.order,
);
const currentIdx = all.findIndex((e) => e.slug === entry.slug);
const prev = currentIdx > 0 ? all[currentIdx - 1] : null;
const next = currentIdx < all.length - 1 ? all[currentIdx + 1] : null;
const slugify = (s: string) => s.replace(/^\d+-/, '');
---
<RoomLayout
  room="court"
  width="prose"
  title={entry.data.title}
  subtitle={`The Lineage · ${entry.data.year}`}
  sourceId={`court-lineage-${entry.slug}`}
  parents={[{ label: 'The Lineage', href: '/court/lineage/' }]}
>
  <article class="prose prose-slate max-w-none mt-8 prose-a:text-blue-700 prose-a:underline lineage-essay">
    <span class="eyebrow">Court Room · The Lineage · {entry.data.year}</span>

    <p class="back-link">← <a href="/court/lineage/">Back to The Lineage</a></p>

    <Content />

    <nav class="essay-nav" aria-label="Lineage prev/next">
      {prev && (
        <a class="essay-nav__prev" href={`/court/lineage/${slugify(prev.slug)}/`}>
          <span class="essay-nav__dir">← Previous</span>
          <span class="essay-nav__title">{prev.data.title}</span>
        </a>
      )}
      {next && (
        <a class="essay-nav__next" href={`/court/lineage/${slugify(next.slug)}/`}>
          <span class="essay-nav__dir">Next →</span>
          <span class="essay-nav__title">{next.data.title}</span>
        </a>
      )}
    </nav>

    <hr class="archival-divider" />

    <aside class="preview-banner" role="note">
      <strong>First-draft preview.</strong> Phase 3 cross-AI review and
      Phase 4 revision are still pending. Inline citations marked
      <span class="cite-pending">[CITE PENDING]</span> remain to be
      verified.
    </aside>
  </article>
</RoomLayout>

<style is:global>
  .lineage-essay [data-astro-cid] p:has(span.cite-pending) { display: block; }
  .lineage-essay :is(p, li) :is(em) { font-style: italic; }
</style>

<style>
  .back-link {
    margin: 0 0 1.25rem;
    font-size: 0.95rem;
  }
  .preview-banner {
    border-left: 4px solid var(--old-gold, #B88A2E);
    background: rgba(184, 138, 46, 0.08);
    padding: 0.75rem 1rem;
    margin: 1.25rem 0 0;
    font-size: 0.92rem;
  }
  .cite-pending {
    font-style: italic;
    color: #6b4a0f;
    font-size: 0.88em;
  }
  .essay-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin: 2rem 0 1rem;
    flex-wrap: wrap;
  }
  .essay-nav a {
    flex: 1 1 240px;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem 1rem;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    background: #fff;
    text-decoration: none;
    color: inherit;
  }
  .essay-nav__next { text-align: right; }
  .essay-nav__dir {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #475569;
  }
  .essay-nav__title {
    font-size: 0.95rem;
    color: #1e3a5f;
  }
</style>

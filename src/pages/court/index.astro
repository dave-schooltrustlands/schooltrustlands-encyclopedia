---
// v3.2.1 — Court Room lobby. Four subsection cards (Lineage, Atlas,
// Case File, Reading Wing). The standalone Opinions Library was
// collapsed into per-state dossiers under the Atlas — AG opinions
// belong where users actually look for them. /court/opinions/ still
// resolves to an explanation stub so older bookmarks don't 404.
import RoomLayout from '../../layouts/RoomLayout.astro';

const subsections = [
  {
    href: '/court/lineage/',
    title: 'The Lineage',
    description:
      'Doctrinal evolution of trust law from English equity to American school trust — Magna Carta, Statute of Uses, Lord Hardwicke, the 1785 Land Ordinance, state Enabling Acts, and the modern Uniform Trust Code.',
    eyebrow: 'Doctrine · timeline',
  },
  {
    href: '/court/atlas/',
    title: 'The Atlas',
    description:
      'Map of the trust-lands states, with per-state dossiers — Enabling Act citation, current fund value, AG opinions, key cases, and a trust-integrity grade.',
    eyebrow: 'Per-state · 20 dossiers',
  },
  {
    href: '/court/case-file/',
    title: 'The Case File',
    description:
      'Annotated Supreme Court cases, binding state-supreme-court precedents, and the active Oregon filings — statutes, AG opinions, official correspondence, litigation history, and expert declarations.',
    eyebrow: 'Cases · annotated',
  },
  {
    href: '/court/reading-wing/',
    title: 'The Reading Wing',
    description:
      'Long-form nationwide perspective essays on school trust law — how America created the school trust, how the trust was broken, what Utah did differently, and the forever-fiduciary question.',
    eyebrow: 'Essays · nationwide',
  },
];
---
<RoomLayout
  room="court"
  width="full"
  title="Court Room"
  subtitle="Where school trust law is studied, cited, and put to work."
  sourceId="court-lobby"
>
  <article class="prose prose-slate max-w-none mt-8 prose-a:text-blue-700 prose-a:underline">
    <div class="court-mark-row">
      <svg
        class="court-mark"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 60 60"
        width="60"
        height="60"
        role="img"
        aria-label="Court Room visual mark: three pillars on a rule"
      >
        <title>Court Room visual mark</title>
        <line x1="6" y1="50" x2="54" y2="50" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        <rect x="12" y="14" width="5" height="32" fill="currentColor" />
        <rect x="27.5" y="14" width="5" height="32" fill="currentColor" />
        <rect x="43" y="14" width="5" height="32" fill="currentColor" />
        <line x1="9" y1="14" x2="51" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
      <span class="eyebrow">Court Room · Lobby</span>
    </div>

    <p>
      The Court Room holds the legal record of America's school trust lands.
      It is the room where the doctrinal lineage of trust law — Magna Carta
      to the Statute of Uses to the modern Uniform Trust Code — meets the
      twenty trust-lands states, the binding precedents that govern them,
      and the Attorney General opinions that interpret their enabling acts.
      It is also the room where Oregon's active litigation is followed in
      detail, because Oregon is presently the country's live test case for
      school-trust accountability.
    </p>

    <aside class="how-to-use" role="note">
      <h2 style="margin: 0 0 0.4rem; font-size: 1.05rem;">How to use this room</h2>
      <p style="margin: 0;">
        Four doors. <strong><a href="/court/lineage/">The Lineage</a></strong>
        traces the doctrine from English equity to the Uniform Trust Code —
        fourteen waypoints with primary-source links. <strong><a href="/court/atlas/">The Atlas</a></strong>
        is the per-state dossier — enabling act, fund value, AG opinions,
        key cases, trust-integrity grade. <strong><a href="/court/case-file/">The Case File</a></strong>
        annotates twenty-one canonical precedents (SCOTUS, U.S. Courts of
        Appeals, binding state-supreme courts) plus Oregon's complete
        statutory and litigation record. <strong><a href="/court/reading-wing/">The Reading Wing</a></strong>
        is long-form national essays — how the trust was created, how it
        was broken, what Utah did differently. Start at the Lineage for
        history, the Atlas for a particular state, the Case File for a
        particular case, the Reading Wing for the argument.
      </p>
    </aside>

    <p>
      Four subsections sit behind the doors below. Each is a first-draft
      preview: the architecture, the data, and substantive seeded
      content are in place. State Attorney General opinions live inside
      each state's dossier under <a href="/court/atlas/">The Atlas</a>,
      where they're most useful to a reader working on that state.
    </p>

    <section class="court-grid" aria-label="Court Room subsections">
      {subsections.map((s) => (
        <a class="court-card" href={s.href}>
          <span class="court-card__eyebrow">{s.eyebrow}</span>
          <h2 class="court-card__title">{s.title}</h2>
          <p class="court-card__desc">{s.description}</p>
          <span class="court-card__open">Open →</span>
        </a>
      ))}
    </section>

    <aside class="key-precedents" role="note">
      <h2 style="margin: 0 0 0.5rem; font-size: 1.05rem;">Key precedents at a glance</h2>
      <p style="margin: 0 0 0.6rem; font-size: 0.95rem;">
        Five anchors for the strict trust theory of school-trust lands.
        Each links into the full annotation in <a href="/court/case-file/">The Case File</a>.
      </p>
      <ul class="key-precedents-list">
        <li>
          <a href="/court/case-file/vincennes-univ-v-indiana-1852/"><em>Trustees of Vincennes University v. Indiana</em></a>,
          55 U.S. 268 (1852) — enabling-act grants create binding trusts
          that the state cannot legislate away.
        </li>
        <li>
          <a href="/court/case-file/cooper-v-roberts-1855/"><em>Cooper v. Roberts</em></a>,
          59 U.S. 173 (1855) — section-16 grants vest at admission "upon
          the unalterable condition" of trust for schools.
        </li>
        <li>
          <a href="/court/case-file/lassen-v-arizona-1967/"><em>Lassen v. Arizona</em></a>,
          385 U.S. 458 (1967) — the trust is "real, not illusory"; full
          compensation required for any taking.
        </li>
        <li>
          <a href="/court/case-file/skamania-v-state-1984/"><em>County of Skamania v. State</em></a>,
          102 Wn.2d 127 (1984) — undivided loyalty prevents the use of
          trust lands for unrelated public purposes.
        </li>
        <li>
          <a href="/court/case-file/branson-v-romer-1998/"><em>Branson School District v. Romer</em></a>,
          161 F.3d 619 (10th Cir. 1998) — federal courts enforce
          enabling-act compacts against state-constitutional changes.
        </li>
      </ul>
    </aside>

    <aside class="oregon-docket" role="note">
      <h2 style="margin: 0 0 0.5rem; font-size: 1.05rem;">Live Oregon docket</h2>
      <dl class="oregon-docket-facts">
        <dt>Case</dt>
        <dd><em>Advocates for School Trust Lands v. State of Oregon</em></dd>
        <dt>Trial court (2024 case)</dt>
        <dd>Coos County Circuit Court — 24CV38372</dd>
        <dt>Appellate (2023 case)</dt>
        <dd>Oregon Court of Appeals — A184055</dd>
        <dt>Last docket event</dt>
        <dd>January 28, 2026 — Court of Appeals standing victory; the appeal of the Coos County dismissal in <em>ASTL et al. v. State</em> (23CV39056) was decided in OASTL's favor on standing.</dd>
        <dt>Next expected step</dt>
        <dd>Remand to trial court for substantive merits proceedings; renewed Motion-to-Dismiss briefing in <em>Siuslaw v. State</em> (24CV38372) continues in parallel.</dd>
      </dl>
      <p style="margin: 0.5rem 0 0; font-size: 0.92rem;">
        Full docket and document repository at
        <a href="/court/oregon-current-case/">Oregon's Current Case →</a>
      </p>
    </aside>

    <aside class="cross-bridge" role="note">
      <strong>Quick reference at the Reference Desk; deep research in the
      Court Room.</strong> The six classic trustee duties under American
      trust law — undivided loyalty, preservation, prudence, productivity,
      exclusive control, and payment of income — are explained in plain
      language at the Reference Desk's
      <a href="/reference-desk/fiduciary-doctrine/">Fiduciary Doctrine</a>
      page. The case law applying those duties — Lassen, Skamania, Ebke,
      Nigh, Idaho Watersheds, Branson, Pettibone, and the live Oregon
      filings — lives in
      <a href="/court/case-file/">The Case File</a> below. The Atlas's
      five Trust Integrity grades are explained at the
      <a href="/court/atlas/methodology/">Trust Integrity Grade Methodology</a>
      page.
    </aside>

    <hr class="archival-divider" />

    <p style="font-size: 0.9rem; color: var(--ink); opacity: 0.7;">
      Phase 1 of the Court Room Expansion Build (2026-05-18). First-draft
      preview content in each subsection; long-form Phase 2 essays drop in
      the next week.
    </p>
  </article>
</RoomLayout>

<style>
  .court-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    margin: 1.75rem 0 1.5rem;
  }
  .court-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 1.25rem 1.1rem;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: border-color 120ms ease, box-shadow 120ms ease, transform 120ms ease;
  }
  .court-card:hover {
    border-color: var(--old-gold, #B88A2E);
    box-shadow: 0 4px 14px rgba(15, 23, 42, 0.08);
    transform: translateY(-1px);
    text-decoration: none;
  }
  .court-card__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #475569;
  }
  .court-card__title {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.25;
    color: #0f172a;
  }
  .court-card__desc {
    margin: 0;
    font-size: 0.95rem;
    color: #1f2937;
    flex: 1 1 auto;
  }
  .court-card__open {
    margin-top: 0.35rem;
    font-size: 0.92rem;
    color: #1d4ed8;
    font-weight: 600;
  }
  .cross-bridge {
    border-left: 4px solid var(--old-gold, #B88A2E);
    background: rgba(184, 138, 46, 0.08);
    padding: 0.85rem 1.1rem;
    margin: 1.5rem 0;
    font-size: 0.95rem;
  }
  .court-mark-row {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin: 0 0 0.5rem;
  }
  .court-mark {
    flex-shrink: 0;
    color: var(--old-gold, #B88A2E);
    opacity: 0.4;
  }
  @media (max-width: 480px) {
    .court-mark {
      width: 48px;
      height: 48px;
    }
  }
  .how-to-use {
    border: 1px solid #cbd5e1;
    border-left: 4px solid #1e3a5f;
    background: #f8fafc;
    padding: 0.85rem 1.1rem;
    margin: 1.25rem 0 1.5rem;
    font-size: 0.96rem;
  }
  .key-precedents {
    border: 1px solid #cbd5e1;
    border-left: 4px solid var(--old-gold, #B88A2E);
    background: #fffbf2;
    padding: 0.9rem 1.1rem;
    margin: 1.5rem 0;
    font-size: 0.95rem;
  }
  .key-precedents-list {
    margin: 0;
    padding-left: 1.1rem;
  }
  .key-precedents-list li {
    margin: 0.3rem 0;
    line-height: 1.4;
  }
  .oregon-docket {
    border: 1px solid #cbd5e1;
    border-left: 4px solid #7c2d12;
    background: #fff7ed;
    padding: 0.9rem 1.1rem;
    margin: 1.5rem 0;
    font-size: 0.95rem;
  }
  .oregon-docket-facts {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.25rem 0.9rem;
    margin: 0;
    font-size: 0.93rem;
  }
  .oregon-docket-facts dt {
    font-family: var(--font-sans);
    font-weight: 700;
    color: #475569;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.72rem;
    padding-top: 0.18rem;
  }
  .oregon-docket-facts dd {
    margin: 0;
    color: #1f2937;
  }
  @media (max-width: 520px) {
    .oregon-docket-facts {
      grid-template-columns: 1fr;
      gap: 0.05rem 0;
    }
    .oregon-docket-facts dd {
      margin-bottom: 0.45rem;
    }
  }
</style>

---
// v3.2.1 — The standalone Opinions Library was collapsed into per-state
// dossiers under the Atlas. AG opinions are now rendered inside each
// state's dossier at /court/atlas/{state}/ (filtered from
// court-opinions.json by state code). This page is kept as a brief
// explanation stub so older bookmarks and inbound links don't 404.
import RoomLayout from '../../../layouts/RoomLayout.astro';
---
<RoomLayout
  room="court"
  width="prose"
  title="The Opinions Library"
  subtitle="State Attorney General opinions now live inside each state's dossier."
  sourceId="court-opinions-stub"
  parents={[{ label: 'Court Room', href: '/court/' }]}
>
  <article class="prose prose-slate max-w-none mt-8 prose-a:text-blue-700 prose-a:underline">
    <span class="eyebrow">Court Room · The Opinions Library</span>

    <aside class="consolidation-banner" role="note">
      <strong>Consolidated into the Atlas.</strong> Attorney General
      opinions on school-trust governance now live inside each state's
      dossier — the place a reader working on a given state actually
      looks for them. The standalone Opinions Library page is closed.
    </aside>

    <p>
      Open <a href="/court/atlas/">The Atlas</a> to find AG opinions on
      file for any state. Oregon's six foundational opinions are in
      substrate today; the other nineteen trust-lands states show a
      placeholder until Phase 4 sourcing fans out from state Attorney
      General offices.
    </p>

    <p>
      <a href="/court/atlas/">Open the Atlas →</a>
    </p>

    <hr class="archival-divider" />

    <p style="font-size: 0.9rem; color: var(--ink); opacity: 0.7;">
      v3.2.1 (2026-05-18). The Court Room lobby now lists four
      subsections: Lineage, Atlas, Case File, Reading Wing. AG opinions
      are an attribute of a state, not a stand-alone room.
    </p>
  </article>
</RoomLayout>

<style>
  .consolidation-banner {
    border-left: 4px solid var(--old-gold, #B88A2E);
    background: rgba(184, 138, 46, 0.08);
    padding: 0.75rem 1rem;
    margin: 1rem 0 1.5rem;
    font-size: 0.95rem;
  }
</style>

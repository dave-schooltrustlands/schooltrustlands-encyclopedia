---
import { getCollection } from 'astro:content';
import RoomLayout from '../../../layouts/RoomLayout.astro';

// v3.1 — Phase 2 annotated precedent cases. The eleven SCOTUS and
// binding state-court annotations are rendered as a new section at
// the top of the Case File; the v65 substantive content (foundational
// provisions, ORS statutes, AG opinions, official correspondence,
// litigation, expert declarations) follows unchanged.
const cases = (await getCollection('court-cases')).sort(
  (a, b) => a.data.order - b.data.order,
);
const scotusCases = cases.filter((c) => c.data.court === 'SCOTUS');
const stateCases = cases.filter((c) => c.data.court === 'state-supreme');
const federalCircuitCases = cases.filter(
  (c) => c.data.court === 'federal-circuit',
);
const slugify = (s: string) => s.replace(/^\d+-/, '');
---

<RoomLayout
  room="court"
  title="The Case File"
  subtitle="Annotated SCOTUS cases, binding state-court precedents, and the active Oregon filings — statutes, AG opinions, official correspondence, litigation history, and expert declarations."
  width="prose"
  sourceId="court-case-file"
>
  <article class="prose prose-slate max-w-none mt-8 prose-a:text-blue-700 prose-a:underline">
    <span class="eyebrow">Court Room · Case File · Annotated Bibliography</span>

    <aside class="preview-banner" role="note">
      <strong>First-draft preview.</strong> The Case File is one of the
      Court Room's four subsections — Lineage, Atlas, Case File, Reading
      Wing. Deeper annotations and additional cases continue to land in
      each phase. ← <a href="/court/">Back to the Court Room lobby</a>.
    </aside>

    <p>
      The Court Room is the Library's doctrinal record: the case files, statutes,
      Attorney General opinions, official correspondence, expert declarations,
      and precedent court decisions that together describe how American trust law
      has been applied — and, in Oregon's case, contested — in the school trust
      lands context.
    </p>
    <p>
      What follows is an annotated bibliography of the trust-lands legal record.
      It is arranged as a historical-legal archive: neutral, chronological,
      citation-first. The annotations describe what each item is and what it
      holds; they do not advocate. For deep doctrinal treatment of the six
      classic trustee duties, see the Reference Desk's
      <a href="/reference-desk/fiduciary-doctrine/">Fiduciary Doctrine</a> page.
    </p>
    <p>
      For OASTL's litigation framing — the Smoking Gun, the Pincer Movement, and
      the current campaign — visit
      <a href="https://oastl.org/legal" rel="noopener" target="_blank">OASTL Legal Desk</a>.
    </p>


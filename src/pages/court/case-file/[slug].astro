---
// v3.1 — Per-case annotation page under /court/case-file/{slug}/.
// Renders one of the eleven Phase 2 annotated cases as a long-form
// first-draft entry. Phase 3 cross-AI review and Phase 4 revision
// are still pending.
import { getCollection, type CollectionEntry } from 'astro:content';
import RoomLayout from '../../../layouts/RoomLayout.astro';

type Props = { entry: CollectionEntry<'court-cases'> };

export async function getStaticPaths() {
  const entries = await getCollection('court-cases');
  return entries.map((entry) => ({
    params: { slug: entry.slug.replace(/^\d+-/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props as Props;
const { Content } = await entry.render();
---
<RoomLayout
  room="court"
  width="prose"
  title={entry.data.caseName}
  subtitle={`${entry.data.citation} · ${entry.data.courtsLabel ?? entry.data.court}`}
  sourceId={`court-case-${entry.slug}`}
  parents={[{ label: 'The Case File', href: '/court/case-file/' }]}
>
  <article class="prose prose-slate max-w-none mt-8 prose-a:text-blue-700 prose-a:underline case-annotation">
    <span class="eyebrow">Court Room · Case File · {entry.data.courtsLabel ?? entry.data.court}</span>

    <p class="back-link">← <a href="/court/case-file/#annotated-precedents">Back to the Case File</a></p>

    <p class="case-citation-line">
      <strong>Citation.</strong> {entry.data.citation}
      {entry.data.opinionUrl && (
        <>
          {' '}·{' '}
          <a href={entry.data.opinionUrl} rel="noopener" target="_blank">
            Read the full opinion →
          </a>
        </>
      )}
    </p>

    <Content />

    <hr class="archival-divider" />

    <aside class="preview-banner" role="note">
      <strong>First-draft preview.</strong> Phase 3 cross-AI review and
      Phase 4 revision are still pending.
    </aside>
  </article>
</RoomLayout>

<style>
  .back-link { margin: 0 0 0.75rem; font-size: 0.95rem; }
  .case-citation-line {
    margin: 0 0 1.25rem;
    padding: 0.6rem 0.9rem;
    background: #f8fafc;
    border-left: 3px solid #1e3a5f;
    font-size: 0.95rem;
  }
  .preview-banner {
    border-left: 4px solid var(--old-gold, #B88A2E);
    background: rgba(184, 138, 46, 0.08);
    padding: 0.75rem 1rem;
    margin: 1.25rem 0 0;
    font-size: 0.92rem;
  }
</style>

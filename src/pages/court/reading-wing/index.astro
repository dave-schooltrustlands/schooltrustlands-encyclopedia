---
// v3.1 — The Reading Wing. Seven long-form essays seeded from Phase 2
// substrate. Each essay card links to its own full-text page; Phase 3
// cross-AI review and Phase 4 revision are still pending.
import { getCollection } from 'astro:content';
import RoomLayout from '../../../layouts/RoomLayout.astro';

const essays = (await getCollection('court-reading-wing')).sort(
  (a, b) => a.data.order - b.data.order,
);
const slugify = (s: string) => s.replace(/^\d+-/, '');
---
<RoomLayout
  room="court"
  width="full"
  title="The Reading Wing"
  subtitle="Long-form nationwide perspective essays on school trust law."
  sourceId="court-reading-wing"
>
  <article class="prose prose-slate max-w-none mt-8 prose-a:text-blue-700 prose-a:underline">
    <span class="eyebrow">Court Room · The Reading Wing</span>

    <aside class="preview-banner" role="note">
      <strong>First-draft preview.</strong> Seven Phase 2 essays
      sit behind the cards below. Phase 3 cross-AI review and Phase 4
      revision are still pending. ← <a href="/court/">Back to the Court
      Room lobby</a>.
    </aside>

    <p>
      The Reading Wing is the long-form room at the back of the Court
      Room. The Case File is annotated; the Atlas is per-state (with
      each state's AG opinions inside its dossier). The Reading Wing
      is the place where the doctrinal arguments are put together at
      full length — for the reader who has already toured the rest of
      the room and wants the perspective behind it.
    </p>

    <section class="essay-grid" aria-label="Reading Wing essays">
      {essays.map((e) => (
        <a class="essay-card" href={`/court/reading-wing/${slugify(e.slug)}/`}>
          <span class="essay-card__eyebrow">Essay {e.data.order}</span>
          <h2 class="essay-card__title">{e.data.title}</h2>
          <p class="essay-card__preview">{e.data.preview}</p>
          <span class="essay-card__open">Read →</span>
        </a>
      ))}
    </section>

    <hr class="archival-divider" />

    <p style="font-size: 0.9rem; color: var(--ink); opacity: 0.7;">
      First-draft preview. Seven essays seeded from Phase 2 substrate;
      Phase 3 cross-AI review and Phase 4 revision still pending.
    </p>
  </article>
</RoomLayout>

<style>
  .preview-banner {
    border-left: 4px solid var(--old-gold, #B88A2E);
    background: rgba(184, 138, 46, 0.08);
    padding: 0.75rem 1rem;
    margin: 1rem 0 1.5rem;
    font-size: 0.95rem;
  }
  .essay-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1rem;
    margin: 1.75rem 0 1.5rem;
  }
  .essay-card {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1.1rem 1.2rem 1.05rem;
    border: 1px solid #cbd5e1;
    border-left: 4px solid var(--old-gold, #B88A2E);
    border-radius: 6px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: border-color 120ms ease, box-shadow 120ms ease, transform 120ms ease;
  }
  .essay-card:hover {
    border-color: var(--old-gold, #B88A2E);
    box-shadow: 0 4px 14px rgba(15, 23, 42, 0.08);
    transform: translateY(-1px);
    text-decoration: none;
  }
  .essay-card__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #475569;
  }
  .essay-card__title {
    margin: 0 0 0.2rem;
    font-size: 1.1rem;
    line-height: 1.3;
    color: #0f172a;
  }
  .essay-card__preview {
    margin: 0;
    font-size: 0.95rem;
    color: #1f2937;
    flex: 1 1 auto;
  }
  .essay-card__open {
    margin-top: 0.35rem;
    font-size: 0.92rem;
    color: #1d4ed8;
    font-weight: 600;
  }
</style>

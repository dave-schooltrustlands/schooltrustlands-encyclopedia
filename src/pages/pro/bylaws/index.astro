<ProLayout
  title="Charter · Pro · America's School Trust Library"
  description="The public charter of America's School Trust Library — name and identity, purpose, beneficiaries, editorial independence, officers, the planned Library Board, amendments, the independence transition, and dissolution."
  sourceId="pro-bylaws"
  pageLabel="Charter"

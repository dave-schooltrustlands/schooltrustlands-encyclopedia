---
// Site Update v39 — Institutional-Formation dashboard tab.
//
// Lists feedback rows where kind='institutional_formation'. Head-librarian-
// only surface: the requireLibrarian guard passes for any librarian-tier
// role, then we early-return 404 if the role is not head_librarian or admin.
// (The 404-not-403 contract matches the rest of the librarian dashboard.)

import BaseLayout from '../../../layouts/BaseLayout.astro';
import LibrarianTabs from '../../../components/LibrarianTabs.astro';
import { requireLibrarian, formatPatronNumber } from '../../../lib/librarian';

export const prerender = false;

const guard = await requireLibrarian(Astro);
if (!guard.ok) return guard.response;
const { supabase, role } = guard.context;

// Founding-officer surface: anything other than head_librarian / admin gets
// the same 404 a non-librarian would see.
if (role !== 'head_librarian' && role !== 'admin') {
  return new Response('Not Found', {
    status: 404,
    headers: { 'content-type': 'text/plain; charset=utf-8' },
  });
}

const { data: feedbackRaw } = await supabase
  .from('feedback')
  .select('id, ticket_number, page_url, subject, body, status, submitted_at, user_id')
  .eq('kind', 'institutional_formation')
  .order('submitted_at', { ascending: false });

const rows = feedbackRaw ?? [];

const userIds = Array.from(new Set(rows.map((r) => r.user_id)));
let profileMap = new Map<string, { display_name: string | null; patron_number: number | null }>();
if (userIds.length > 0) {
  const { data: profileRows } = await supabase
    .from('profiles')
    .select('id, display_name, patron_number')
    .in('id', userIds);
  for (const p of profileRows ?? []) {
    profileMap.set(p.id, {
      display_name: p.display_name ?? null,
      patron_number: p.patron_number ?? null,
    });
  }
}

const MONTHS_SHORT = [
  'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
  'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec',
];
function fmtDate(iso: string): string {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return '';
  return `${d.getUTCDate().toString().padStart(2, '0')} ${MONTHS_SHORT[d.getUTCMonth()]} ${d.getUTCFullYear()}`;
}
function summarize(text: string): string {
  const b = (text ?? '').trim();
  if (b.length <= 80) return b;
  return b.slice(0, 80).trimEnd() + '…';
}

const STATUS_LABEL: Record<string, string> = {
  new: 'New',
  in_review: 'In review',
  responded: 'Responded',
  archived: 'Archived',
};
---

<BaseLayout
  title="Institutional Formation · Librarian · America's School Trust Library"
  sourceId="librarian-institutional-formation"
>
  <article class="librarian-dashboard prose prose-slate max-w-none prose-a:text-blue-700 prose-a:underline">
    <h1>Institutional Formation</h1>
    <p class="role-line">
      Founding-officers' queue. Submissions land here from <a href="/about/becoming/">Building This Library</a>.
    </p>

    <LibrarianTabs current="institutional-formation" role={role} />

    {rows.length > 0 ? (
      <table class="dashboard-table">
        <thead>
          <tr>
            <th>Ticket</th>
            <th>Submitted</th>
            <th>Patron</th>
            <th>Status</th>
            <th>Subject / Excerpt</th>
            <th>Page</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => {
            const p = profileMap.get(r.user_id);
            const patronLabel = p
              ? `${(p.display_name ?? '').trim() || '—'} · № ${formatPatronNumber(p.patron_number)}`
              : '—';
            const summaryText =
              (r.subject && r.subject.trim().length > 0
                ? r.subject.trim()
                : r.body ?? '');
            return (
              <tr>
                <td>
                  <a href={`/librarian/tickets/${r.id}/`} class="ticket-link">
                    {r.ticket_number}
                  </a>
                </td>
                <td>{fmtDate(r.submitted_at)}</td>
                <td>{patronLabel}</td>
                <td>
                  <span class:list={['status-pill', `status-pill--${r.status}`]}>
                    {STATUS_LABEL[r.status] ?? r.status}
                  </span>
                </td>
                <td class="subject-cell">{summarize(summaryText)}</td>
                <td><a href={r.page_url}>{r.page_url}</a></td>
              </tr>
            );
          })}
        </tbody>
      </table>
    ) : (
      <p class="empty-state">
        No institutional-formation submissions yet. The queue fills from the
        Submit-Feedback control on <a href="/about/becoming/">/about/becoming/</a>.
      </p>
    )}
  </article>

  <style>
    .role-line {
      font-family: var(--font-sans);
      font-size: 0.85rem;
      color: #64748b;
      margin: -0.25rem 0 0.5rem;
    }
    .dashboard-table {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--font-sans);
      font-size: 0.92rem;
    }
    .dashboard-table th,
    .dashboard-table td {
      text-align: left;
      padding: 0.55rem 0.7rem;
      border-bottom: 1px solid var(--rule-border, #e5e7eb);
      vertical-align: top;
    }
    .dashboard-table th {
      background: var(--linen-card, #fafaf7);
      font-weight: 600;
      color: var(--deep-navy, #1e3a5f);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .ticket-link {
      font-family: var(--font-mono, ui-monospace, Menlo, monospace);
      font-size: 0.85rem;
      font-weight: 600;
    }
    .subject-cell {
      max-width: 28rem;
    }
    .status-pill {
      display: inline-block;
      padding: 0.1rem 0.5rem;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      background: #e2e8f0;
      color: #334155;
    }
    .status-pill--new {
      background: #e0e7ff;
      color: #3730a3;
    }
    .status-pill--in_review {
      background: #fef3c7;
      color: #92400e;
    }
    .status-pill--responded {
      background: #dcfce7;
      color: #166534;
    }
    .status-pill--archived {
      background: #f1f5f9;
      color: #475569;
    }
    .empty-state {
      padding: 1.4rem 1rem;
      background: var(--linen-card, #fafaf7);
      border: 1px dashed var(--rule-border, #cbd5e1);
      border-radius: 4px;
      color: #475569;
      text-align: center;
    }
  </style>
</BaseLayout>

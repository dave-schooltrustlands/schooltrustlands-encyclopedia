---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LibrarianTabs from '../../../components/LibrarianTabs.astro';
import { requireLibrarian, formatPatronNumber, formatCardDate } from '../../../lib/librarian';

export const prerender = false;

const guard = await requireLibrarian(Astro);
if (!guard.ok) return guard.response;
const { supabase, role } = guard.context;

const { data: appsRaw } = await supabase
  .from('librarian_applications')
  .select('id, ticket_number, user_id, statement, status, submitted_at')
  .order('submitted_at', { ascending: false });

const apps = (appsRaw ?? []) as Array<{
  id: string;
  ticket_number: string;
  user_id: string;
  statement: string;
  status: string;
  submitted_at: string;
}>;

const userIds = Array.from(new Set(apps.map((a) => a.user_id)));
let profileMap = new Map<string, { display_name: string | null; patron_number: number | null }>();
if (userIds.length > 0) {
  const { data: profileRows } = await supabase
    .from('profiles')
    .select('id, display_name, patron_number')
    .in('id', userIds);
  for (const p of profileRows ?? []) {
    profileMap.set(p.id, {
      display_name: p.display_name ?? null,
      patron_number: p.patron_number ?? null,
    });
  }
}

const STATUS_LABEL: Record<string, string> = {
  new: 'New',
  in_review: 'In review',
  approved: 'Approved',
  declined: 'Declined',
  withdrawn: 'Withdrawn',
};

function summarize(statement: string): string {
  const s = (statement ?? '').trim();
  if (s.length <= 80) return s;
  return s.slice(0, 80).trimEnd() + '…';
}
---

<BaseLayout
  title="Applications · Librarian dashboard"
  sourceId="librarian-applications"
>
  <article class="applications prose prose-slate max-w-none prose-a:text-blue-700 prose-a:underline">
    <h1>Applications</h1>
    <LibrarianTabs current="applications" role={role} />

    {apps.length > 0 ? (
      <table class="apps-table">
        <thead>
          <tr>
            <th>Ticket</th>
            <th>Applicant</th>
            <th>Submitted</th>
            <th>Status</th>
            <th>Statement</th>
          </tr>
        </thead>
        <tbody>
          {apps.map((a) => {
            const p = profileMap.get(a.user_id);
            const applicant = p
              ? `${(p.display_name ?? '').trim() || '—'} · № ${formatPatronNumber(p.patron_number)}`
              : '—';
            return (
              <tr>
                <td>
                  <a href={`/librarian/applications/${a.id}/`} class="ticket-link">
                    {a.ticket_number}
                  </a>
                </td>
                <td>{applicant}</td>
                <td>{formatCardDate(a.submitted_at)}</td>
                <td>
                  <span class:list={['status-pill', `status-pill--${a.status}`]}>
                    {STATUS_LABEL[a.status] ?? a.status}
                  </span>
                </td>
                <td class="statement-cell">{summarize(a.statement)}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    ) : (
      <p class="empty-state">No applications yet.</p>
    )}
  </article>

  <style>
    .apps-table {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--font-sans);
      font-size: 0.92rem;
    }
    .apps-table th,
    .apps-table td {
      text-align: left;
      padding: 0.55rem 0.7rem;
      border-bottom: 1px solid var(--rule-border, #e5e7eb);
      vertical-align: top;
    }
    .apps-table th {
      background: var(--linen-card, #fafaf7);
      font-weight: 600;
      color: var(--deep-navy, #1e3a5f);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .ticket-link {
      font-family: var(--font-mono, ui-monospace, Menlo, monospace);
      font-size: 0.85rem;
      font-weight: 600;
    }
    .statement-cell {
      max-width: 28rem;
    }
    .status-pill {
      display: inline-block;
      padding: 0.1rem 0.5rem;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      background: #e2e8f0;
      color: #334155;
    }
    .status-pill--new       { background: #e0e7ff; color: #3730a3; }
    .status-pill--in_review { background: #fef3c7; color: #92400e; }
    .status-pill--approved  { background: #dcfce7; color: #166534; }
    .status-pill--declined  { background: #fee2e2; color: #991b1b; }
    .status-pill--withdrawn { background: #f1f5f9; color: #64748b; }
    .empty-state {
      padding: 1.4rem 1rem;
      background: var(--linen-card, #fafaf7);
      border: 1px dashed var(--rule-border, #cbd5e1);
      border-radius: 4px;
      color: #475569;
      text-align: center;
    }
  </style>
</BaseLayout>

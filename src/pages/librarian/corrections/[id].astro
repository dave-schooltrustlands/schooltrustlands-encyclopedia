---
// Site Update v32 — Librarian-side correction detail.
//
// Mirrors src/pages/librarian/tickets/[id].astro but reads from the
// corrections table and surfaces the four structured fields (claim,
// proposed_fix, source_offered, reasoning) prominently. The response form
// POSTs to /api/ticket-response with ticket_type='correction'.

import BaseLayout from '../../../layouts/BaseLayout.astro';
import LibrarianTabs from '../../../components/LibrarianTabs.astro';
import { requireLibrarian, formatPatronNumber, formatCardDate, isLibrarianRole } from '../../../lib/librarian';

export const prerender = false;

const guard = await requireLibrarian(Astro);
if (!guard.ok) return guard.response;
const { supabase, role } = guard.context;

// Pure-moderator visitors can pass requireLibrarian (v32 lets moderators
// reach the dashboard for the Moderation tab) but corrections are a
// librarian-tier ticket surface. Return 404 for anyone who is only a
// moderator — same 404-not-403 contract as the rest of /librarian/*.
if (!isLibrarianRole(role)) {
  return new Response('Not Found', { status: 404 });
}

const id = Astro.params.id;
if (!id) return new Response('Not Found', { status: 404 });

const { data: ticket } = await supabase
  .from('corrections')
  .select('id, ticket_number, page_url, claim, proposed_fix, source_offered, reasoning, status, submitted_at, user_id')
  .eq('id', id)
  .maybeSingle();

if (!ticket) return new Response('Not Found', { status: 404 });

const { data: profileRow } = await supabase
  .from('profiles')
  .select('display_name, patron_number, created_at')
  .eq('id', ticket.user_id)
  .maybeSingle();

// Prior responses on this correction — chronological so the conversation
// reads top-to-bottom. RLS already filters; librarian-side policies give us
// everything for this ticket.
const { data: responsesRaw } = await supabase
  .from('ticket_responses')
  .select('id, body, author_id, author_role, posted_at, is_public')
  .eq('ticket_type', 'correction')
  .eq('ticket_id', id)
  .order('posted_at', { ascending: true });

const responses = responsesRaw ?? [];

// v32 (EPSILON): attachments associated with this correction. Librarian RLS
// (Librarians read attachments) lets us read any patron's row; we mint fresh
// 1-hour signed URLs on each render so download links never outlive the TTL.
const { data: attachmentsRaw } = await supabase
  .from('file_attachments')
  .select('id, storage_path, file_name, content_type, byte_size, uploaded_at')
  .eq('parent_type', 'correction')
  .eq('parent_id', id)
  .order('uploaded_at', { ascending: true });

type AttachmentView = {
  id: string;
  file_name: string;
  byte_size: number;
  signed_url: string | null;
};

const attachments: AttachmentView[] = [];
for (const row of attachmentsRaw ?? []) {
  const { data: signed } = await supabase.storage
    .from('attachments')
    .createSignedUrl(row.storage_path, 60 * 60);
  attachments.push({
    id: row.id,
    file_name: row.file_name,
    byte_size: row.byte_size,
    signed_url: signed?.signedUrl ?? null,
  });
}

function fmtBytes(n: number): string {
  if (n < 1024) return `${n} B`;
  if (n < 1024 * 1024) return `${(n / 1024).toFixed(0)} KB`;
  return `${(n / 1024 / 1024).toFixed(1)} MB`;
}

const authorIds = Array.from(new Set(responses.map((r) => r.author_id)));
let authorMap = new Map<string, { display_name: string | null }>();
if (authorIds.length > 0) {
  const { data: authors } = await supabase
    .from('profiles')
    .select('id, display_name')
    .in('id', authorIds);
  for (const a of authors ?? []) {
    authorMap.set(a.id, { display_name: a.display_name ?? null });
  }
}

const STATUS_LABEL: Record<string, string> = {
  new: 'New',
  in_review: 'In review',
  responded: 'Responded',
  accepted: 'Accepted',
  rejected: 'Rejected',
  archived: 'Archived',
};

const patronName = (profileRow?.display_name ?? '').trim() || 'Library Patron';
const patronNumber = formatPatronNumber(profileRow?.patron_number ?? null);
const submitted = formatCardDate(ticket.submitted_at);
---

<BaseLayout
  title={`${ticket.ticket_number} · Librarian dashboard`}
  sourceId="librarian-correction-detail"
>
  <article class="ticket-detail prose prose-slate max-w-none prose-a:text-blue-700 prose-a:underline">
    <p class="back-line"><a href="/librarian/">← Back to pending tickets</a></p>

    <LibrarianTabs current="tickets" role={role} />

    <header class="ticket-header">
      <h1 class="ticket-id">{ticket.ticket_number}</h1>
      <p class="ticket-meta">
        <span class="type-pill type-pill--correction">Correction</span>
        <span class:list={['status-pill', `status-pill--${ticket.status}`]}>
          {STATUS_LABEL[ticket.status] ?? ticket.status}
        </span>
        <span class="meta-divider">·</span>
        Submitted {submitted}
        <span class="meta-divider">·</span>
        {patronName} (№ {patronNumber})
      </p>
    </header>

    <p class="ticket-page">
      <strong>Page:</strong>
      <a href={ticket.page_url}>{ticket.page_url}</a>
    </p>

    <section class="correction-section">
      <h2>What is the error?</h2>
      <div class="ticket-body">{ticket.claim}</div>
    </section>

    <section class="correction-section">
      <h2>What should it say instead?</h2>
      <div class="ticket-body">{ticket.proposed_fix}</div>
    </section>

    {ticket.source_offered && (
      <section class="correction-section">
        <h2>Source</h2>
        <div class="ticket-body ticket-body--inline">{ticket.source_offered}</div>
      </section>
    )}

    {ticket.reasoning && (
      <section class="correction-section">
        <h2>Reasoning</h2>
        <div class="ticket-body">{ticket.reasoning}</div>
      </section>
    )}

    {attachments.length > 0 && (
      <section class="attachments-section">
        <h2>Attachments</h2>
        <ul class="attachments-list">
          {attachments.map((a) => (
            <li class="attachments-item">
              {a.signed_url ? (
                <a href={a.signed_url} target="_blank" rel="noopener">{a.file_name}</a>
              ) : (
                <span>{a.file_name}</span>
              )}
              <span class="attachments-size">({fmtBytes(a.byte_size)})</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="responses-section">
      <h2>Conversation</h2>
      {responses.length > 0 ? (
        <ol class="response-list">
          {responses.map((r) => {
            const a = authorMap.get(r.author_id);
            const who = (a?.display_name ?? '').trim() || (r.author_role === 'librarian' ? 'Librarian' : 'Patron');
            return (
              <li class:list={['response-item', `response-item--${r.author_role}`]}>
                <header class="response-meta">
                  <span class:list={['role-badge', `role-badge--${r.author_role}`]}>
                    {r.author_role}
                  </span>
                  <span class="response-author">{who}</span>
                  <span class="meta-divider">·</span>
                  <time>{formatCardDate(r.posted_at)}</time>
                </header>
                <div class="response-body">{r.body}</div>
              </li>
            );
          })}
        </ol>
      ) : (
        <p class="empty-line">No responses yet.</p>
      )}
    </section>

    <section class="response-form-section">
      <h2>Write response</h2>
      <form class="response-form" data-ticket-id={ticket.id}>
        <label class="response-label" for="response-body">Response (sent to the patron by email)</label>
        <textarea
          id="response-body"
          name="body"
          required
          maxlength="4000"
          rows="6"
          placeholder="Write to the patron…"
        ></textarea>
        <label class="response-public">
          <input type="checkbox" name="is_public" />
          Mark this response as public (default: private, only the patron sees it)
        </label>
        <button type="submit" class="response-submit">Submit response</button>
        <p class="response-status" aria-live="polite"></p>
      </form>
    </section>
  </article>

  <script is:inline define:vars={{ ticketId: ticket.id }}>
    const form = document.querySelector('.response-form');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const status = form.querySelector('.response-status');
        const submit = form.querySelector('.response-submit');
        const body = form.querySelector('#response-body').value.trim();
        const isPublic = form.querySelector('input[name="is_public"]').checked;
        if (!body) {
          status.textContent = 'Write a response before submitting.';
          status.className = 'response-status err';
          return;
        }
        submit.disabled = true;
        submit.textContent = 'Submitting…';
        try {
          const res = await fetch('/api/ticket-response', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({
              ticket_type: 'correction',
              ticket_id: ticketId,
              body,
              is_public: isPublic,
            }),
          });
          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error || `HTTP ${res.status}`);
          }
          status.textContent = 'Response submitted. The patron will see it in My Library and by email.';
          status.className = 'response-status ok';
          setTimeout(() => location.reload(), 800);
        } catch (err) {
          status.textContent = 'Could not submit: ' + (err?.message || 'unknown error');
          status.className = 'response-status err';
          submit.disabled = false;
          submit.textContent = 'Submit response';
        }
      });
    }
  </script>

  <style>
    .back-line {
      font-family: var(--font-sans);
      font-size: 0.85rem;
      margin: 0 0 0.5rem;
    }
    .ticket-header {
      margin: 0.5rem 0 1rem;
    }
    .ticket-id {
      font-family: var(--font-mono, ui-monospace, Menlo, monospace);
      font-size: 1.4rem;
      margin: 0;
    }
    .ticket-meta {
      font-family: var(--font-sans);
      font-size: 0.85rem;
      color: #475569;
      margin: 0.25rem 0 0;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.4rem;
    }
    .meta-divider {
      color: #94a3b8;
    }
    .ticket-page {
      font-family: var(--font-sans);
      font-size: 0.92rem;
      margin: 0.4rem 0;
    }
    .correction-section {
      margin: 0.9rem 0;
    }
    .correction-section > h2 {
      font-family: var(--font-sans);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: #64748b;
      margin: 0.6rem 0 0.3rem;
    }
    .ticket-body {
      font-family: var(--font-serif);
      font-size: 1rem;
      white-space: pre-wrap;
      padding: 0.9rem 1rem;
      background: var(--linen-card, #fafaf7);
      border: 1px solid var(--rule-border, #e5e7eb);
      border-radius: 4px;
      margin: 0.2rem 0;
    }
    .ticket-body--inline {
      font-family: var(--font-sans);
      font-size: 0.92rem;
      padding: 0.55rem 0.8rem;
    }
    .attachments-section { margin: 1rem 0 1.25rem; }
    .attachments-section > h2 {
      font-family: var(--font-sans);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: #64748b;
      margin: 0.6rem 0 0.3rem;
    }
    .attachments-list { list-style: none; padding: 0; margin: 0.3rem 0 0; }
    .attachments-item {
      font-family: var(--font-sans);
      font-size: 0.9rem;
      padding: 0.25rem 0;
    }
    .attachments-size { color: #94a3b8; font-size: 0.82rem; margin-left: 0.4rem; }
    .status-pill,
    .type-pill {
      display: inline-block;
      padding: 0.1rem 0.5rem;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      background: #e2e8f0;
      color: #334155;
    }
    .type-pill--correction { background: #fef3c7; color: #92400e; }
    .status-pill--new       { background: #e0e7ff; color: #3730a3; }
    .status-pill--in_review { background: #fef3c7; color: #92400e; }
    .status-pill--responded { background: #dcfce7; color: #166534; }
    .status-pill--accepted  { background: #dcfce7; color: #166534; }
    .status-pill--rejected  { background: #fee2e2; color: #991b1b; }
    .status-pill--archived  { background: #f1f5f9; color: #64748b; }
    .responses-section { margin: 1.25rem 0; }
    .response-list { list-style: none; padding: 0; margin: 0; }
    .response-item {
      padding: 0.85rem 1rem;
      border-radius: 4px;
      margin: 0.6rem 0;
      border: 1px solid var(--rule-border, #e5e7eb);
    }
    .response-item--librarian { background: #f0f9ff; border-color: #bae6fd; }
    .response-item--patron    { background: #fff; }
    .response-meta {
      font-family: var(--font-sans);
      font-size: 0.8rem;
      color: #64748b;
      margin: 0 0 0.4rem;
    }
    .role-badge {
      display: inline-block;
      padding: 0.05rem 0.45rem;
      border-radius: 999px;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-right: 0.4rem;
    }
    .role-badge--librarian { background: #1e3a5f; color: #fff; }
    .role-badge--patron    { background: #fef3c7; color: #92400e; }
    .response-author { font-weight: 600; color: var(--deep-navy, #1e3a5f); }
    .response-body {
      font-family: var(--font-serif);
      font-size: 0.96rem;
      white-space: pre-wrap;
      color: #1e293b;
    }
    .empty-line { color: #64748b; font-style: italic; }
    .response-form {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      max-width: 40rem;
    }
    .response-form textarea {
      font-family: var(--font-sans);
      font-size: 0.95rem;
      padding: 0.6rem 0.75rem;
      border: 1px solid var(--rule-border, #cbd5e1);
      border-radius: 4px;
      background: #fff;
      resize: vertical;
    }
    .response-public {
      font-family: var(--font-sans);
      font-size: 0.85rem;
      color: #475569;
    }
    .response-submit {
      align-self: flex-start;
      padding: 0.55rem 1.1rem;
      background: var(--deep-navy, #1e3a5f);
      color: #fff;
      border: 0;
      border-radius: 4px;
      font-family: var(--font-sans);
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
    }
    .response-submit[disabled] { opacity: 0.5; cursor: wait; }
    .response-status { font-family: var(--font-sans); font-size: 0.88rem; margin: 0; }
    .response-status.ok { color: #065f46; }
    .response-status.err { color: #991b1b; }
  </style>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LibrarianTabs from '../../components/LibrarianTabs.astro';
import { requireLibrarian, formatPatronNumber } from '../../lib/librarian';

export const prerender = false;

const guard = await requireLibrarian(Astro);
if (!guard.ok) return guard.response;
const { supabase, role } = guard.context;

// Pending tickets: feedback + corrections rows in status 'new' or 'in_review',
// merged client-side and ordered by submitted_at desc. We do two parallel
// queries rather than a Postgres UNION because the two parent tables have
// slightly different columns and the supabase-js typings prefer same-shape
// .from() reads.
const [{ data: feedbackRaw }, { data: correctionsRaw }] = await Promise.all([
  supabase
    .from('feedback')
    .select('id, ticket_number, page_url, subject, body, status, submitted_at, user_id')
    .in('status', ['new', 'in_review'])
    .order('submitted_at', { ascending: false }),
  supabase
    .from('corrections')
    .select('id, ticket_number, page_url, claim, status, submitted_at, user_id')
    .in('status', ['new', 'in_review'])
    .order('submitted_at', { ascending: false }),
]);

type TicketRow = {
  id: string;
  ticket_type: 'feedback' | 'correction';
  ticket_number: string;
  page_url: string;
  summary_text: string;
  status: string;
  submitted_at: string;
  user_id: string;
};

const feedbackTickets: TicketRow[] = (feedbackRaw ?? []).map((t) => ({
  id: t.id,
  ticket_type: 'feedback',
  ticket_number: t.ticket_number,
  page_url: t.page_url,
  summary_text:
    (t.subject && t.subject.trim().length > 0 ? t.subject.trim() : (t.body ?? '')),
  status: t.status,
  submitted_at: t.submitted_at,
  user_id: t.user_id,
}));

const correctionTickets: TicketRow[] = (correctionsRaw ?? []).map((c) => ({
  id: c.id,
  ticket_type: 'correction',
  ticket_number: c.ticket_number,
  page_url: c.page_url,
  // For the summary cell on the dashboard, lead with the claim — that's
  // the librarian-relevant headline of a correction ticket.
  summary_text: c.claim ?? '',
  status: c.status,
  submitted_at: c.submitted_at,
  user_id: c.user_id,
}));

const tickets = [...feedbackTickets, ...correctionTickets].sort((a, b) =>
  b.submitted_at.localeCompare(a.submitted_at)
);

// Patron join: pull display_name + patron_number for each unique user_id.
const userIds = Array.from(new Set(tickets.map((t) => t.user_id)));
let profileMap = new Map<string, { display_name: string | null; patron_number: number | null }>();
if (userIds.length > 0) {
  const { data: profileRows } = await supabase
    .from('profiles')
    .select('id, display_name, patron_number')
    .in('id', userIds);
  for (const p of profileRows ?? []) {
    profileMap.set(p.id, {
      display_name: p.display_name ?? null,
      patron_number: p.patron_number ?? null,
    });
  }
}

const MONTHS_SHORT = [
  'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
  'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec',
];
function fmtDate(iso: string): string {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return '';
  return `${d.getUTCDate().toString().padStart(2, '0')} ${MONTHS_SHORT[d.getUTCMonth()]} ${d.getUTCFullYear()}`;
}
function summarize(text: string): string {
  const b = (text ?? '').trim();
  if (b.length <= 60) return b;
  return b.slice(0, 60).trimEnd() + '…';
}

const TYPE_LABEL: Record<TicketRow['ticket_type'], string> = {
  feedback: 'Feedback',
  correction: 'Correction',
};

function detailHref(t: TicketRow): string {
  return t.ticket_type === 'correction'
    ? `/librarian/corrections/${t.id}/`
    : `/librarian/tickets/${t.id}/`;
}

const STATUS_LABEL: Record<string, string> = {
  new: 'New',
  in_review: 'In review',
};
---

<BaseLayout
  title="Librarian dashboard · America's School Trust Library"
  sourceId="librarian-dashboard"
>
  <article class="librarian-dashboard prose prose-slate max-w-none prose-a:text-blue-700 prose-a:underline">
    <h1>Librarian dashboard</h1>
    <p class="role-line">
      Signed in as <strong>{role.replace(/_/g, ' ')}</strong>.
    </p>

    <LibrarianTabs current="tickets" role={role} />

    <h2>Pending tickets</h2>
    {tickets.length > 0 ? (
      <table class="dashboard-table">
        <thead>
          <tr>
            <th>Ticket</th>
            <th>Type</th>
            <th>Submitted</th>
            <th>Patron</th>
            <th>Status</th>
            <th>Subject</th>
          </tr>
        </thead>
        <tbody>
          {tickets.map((t) => {
            const p = profileMap.get(t.user_id);
            const patronLabel = p
              ? `${(p.display_name ?? '').trim() || '—'} · № ${formatPatronNumber(p.patron_number)}`
              : '—';
            return (
              <tr>
                <td><a href={detailHref(t)} class="ticket-link">{t.ticket_number}</a></td>
                <td>
                  <span class:list={['type-pill', `type-pill--${t.ticket_type}`]}>
                    {TYPE_LABEL[t.ticket_type]}
                  </span>
                </td>
                <td>{fmtDate(t.submitted_at)}</td>
                <td>{patronLabel}</td>
                <td>
                  <span class:list={['status-pill', `status-pill--${t.status}`]}>
                    {STATUS_LABEL[t.status] ?? t.status}
                  </span>
                </td>
                <td class="subject-cell">{summarize(t.summary_text)}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    ) : (
      <p class="empty-state">No pending tickets. The mailbox is clean.</p>
    )}
  </article>

  <style>
    .role-line {
      font-family: var(--font-sans);
      font-size: 0.85rem;
      color: #64748b;
      margin: -0.25rem 0 0.5rem;
      text-transform: capitalize;
    }
    .dashboard-table {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--font-sans);
      font-size: 0.92rem;
    }
    .dashboard-table th,
    .dashboard-table td {
      text-align: left;
      padding: 0.55rem 0.7rem;
      border-bottom: 1px solid var(--rule-border, #e5e7eb);
      vertical-align: top;
    }
    .dashboard-table th {
      background: var(--linen-card, #fafaf7);
      font-weight: 600;
      color: var(--deep-navy, #1e3a5f);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .ticket-link {
      font-family: var(--font-mono, ui-monospace, Menlo, monospace);
      font-size: 0.85rem;
      font-weight: 600;
    }
    .subject-cell {
      max-width: 24rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .status-pill,
    .type-pill {
      display: inline-block;
      padding: 0.1rem 0.5rem;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      background: #e2e8f0;
      color: #334155;
    }
    .type-pill--feedback {
      background: #ede9fe;
      color: #5b21b6;
    }
    .type-pill--correction {
      background: #fef3c7;
      color: #92400e;
    }
    .status-pill--new {
      background: #e0e7ff;
      color: #3730a3;
    }
    .status-pill--in_review {
      background: #fef3c7;
      color: #92400e;
    }
    .empty-state {
      padding: 1.4rem 1rem;
      background: var(--linen-card, #fafaf7);
      border: 1px dashed var(--rule-border, #cbd5e1);
      border-radius: 4px;
      color: #475569;
      text-align: center;
    }
  </style>
</BaseLayout>

---
// Site Update v32 — Discussions tab inside the librarian dashboard shell.
//
// Mirrors /discussions/ but inside the LibrarianTabs frame, and includes
// hidden threads (so moderators can find them). The guard here is the
// standard requireLibrarian — a pure discussion_moderator will also pass
// because the v32 librarian.ts widens LibrarianRole to include the
// moderator role. The LibrarianTabs nav handles role-aware tab visibility.

import BaseLayout from '../../../layouts/BaseLayout.astro';
import LibrarianTabs from '../../../components/LibrarianTabs.astro';
import { requireLibrarian, formatPatronNumber, formatCardDate } from '../../../lib/librarian';

export const prerender = false;

const guard = await requireLibrarian(Astro);
if (!guard.ok) return guard.response;
const { supabase, role } = guard.context;

// Moderators (any role) see hidden threads so they can find/unhide them.
const { data: threadsRaw } = await supabase
  .from('discussions')
  .select('id, ticket_number, user_id, title, topic, status, created_at, last_activity_at')
  .order('last_activity_at', { ascending: false });

const threads = (threadsRaw ?? []) as Array<{
  id: string;
  ticket_number: string;
  user_id: string;
  title: string;
  topic: string | null;
  status: string;
  created_at: string;
  last_activity_at: string;
}>;

// Author profiles.
const authorIds = Array.from(new Set(threads.map((t) => t.user_id)));
const profileMap = new Map<string, { display_name: string | null; patron_number: number | null }>();
if (authorIds.length > 0) {
  const { data: profileRows } = await supabase
    .from('profiles')
    .select('id, display_name, patron_number')
    .in('id', authorIds);
  for (const p of profileRows ?? []) {
    profileMap.set(p.id, {
      display_name: p.display_name ?? null,
      patron_number: p.patron_number ?? null,
    });
  }
}

// Reply counts.
const replyCounts = new Map<string, number>();
if (threads.length > 0) {
  const threadIds = threads.map((t) => t.id);
  const { data: postRows } = await supabase
    .from('discussion_posts')
    .select('discussion_id')
    .in('discussion_id', threadIds);
  for (const row of postRows ?? []) {
    const k = row.discussion_id as string;
    if (!k) continue;
    replyCounts.set(k, (replyCounts.get(k) ?? 0) + 1);
  }
}

const STATUS_LABEL: Record<string, string> = {
  open: 'Open',
  closed: 'Locked',
  hidden: 'Hidden',
};
---

<BaseLayout
  title="Discussions · Librarian dashboard"
  sourceId="librarian-discussions"
>
  <article class="discussions prose prose-slate max-w-none prose-a:text-blue-700 prose-a:underline">
    <h1>Discussions</h1>
    <p class="role-line">
      Signed in as <strong>{role.replace(/_/g, ' ')}</strong>.
    </p>
    <LibrarianTabs current="discussions" role={role} />

    {threads.length > 0 ? (
      <table class="threads-table">
        <thead>
          <tr>
            <th>Ticket</th>
            <th>Title</th>
            <th>Topic</th>
            <th>Author</th>
            <th>Replies</th>
            <th>Last activity</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {threads.map((t) => {
            const p = profileMap.get(t.user_id);
            const author = (p?.display_name ?? '').trim() || 'Library Patron';
            const num = formatPatronNumber(p?.patron_number ?? null);
            const replies = replyCounts.get(t.id) ?? 0;
            return (
              <tr>
                <td>
                  <a href={`/discussions/${t.ticket_number}/`} class="ticket-link">
                    {t.ticket_number}
                  </a>
                </td>
                <td class="title-cell">{t.title}</td>
                <td>{t.topic ?? ''}</td>
                <td>{author} · № {num}</td>
                <td>{replies}</td>
                <td>{formatCardDate(t.last_activity_at)}</td>
                <td>
                  <span class:list={['status-pill', `status-pill--${t.status}`]}>
                    {STATUS_LABEL[t.status] ?? t.status}
                  </span>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    ) : (
      <p class="empty-state">No discussions yet.</p>
    )}
  </article>

  <style>
    .role-line {
      font-family: var(--font-sans);
      font-size: 0.85rem;
      color: #64748b;
      margin: -0.25rem 0 0.5rem;
      text-transform: capitalize;
    }
    .threads-table {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--font-sans);
      font-size: 0.9rem;
    }
    .threads-table th,
    .threads-table td {
      text-align: left;
      padding: 0.55rem 0.7rem;
      border-bottom: 1px solid var(--rule-border, #e5e7eb);
      vertical-align: top;
    }
    .threads-table th {
      background: var(--linen-card, #fafaf7);
      font-weight: 600;
      color: var(--deep-navy, #1e3a5f);
      font-size: 0.76rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .ticket-link {
      font-family: var(--font-mono, ui-monospace, Menlo, monospace);
      font-size: 0.82rem;
      font-weight: 600;
    }
    .title-cell {
      max-width: 22rem;
      font-family: var(--font-serif);
    }
    .status-pill {
      display: inline-block;
      padding: 0.1rem 0.5rem;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      background: #e2e8f0;
      color: #334155;
    }
    .status-pill--open    { background: #dcfce7; color: #166534; }
    .status-pill--closed  { background: #fee2e2; color: #991b1b; }
    .status-pill--hidden  { background: #f1f5f9; color: #64748b; }
    .empty-state {
      padding: 1.4rem 1rem;
      background: var(--linen-card, #fafaf7);
      border: 1px dashed var(--rule-border, #cbd5e1);
      border-radius: 4px;
      color: #475569;
      text-align: center;
    }
  </style>
</BaseLayout>

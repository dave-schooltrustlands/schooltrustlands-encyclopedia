---
import { getCollection, type CollectionEntry } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const entries = await getCollection('states');
  return entries.map((entry) => ({
    params: { iso: entry.data.iso.toLowerCase() },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'states'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { data } = entry;

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const usd = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
});
const num = new Intl.NumberFormat('en-US');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{data.name} — School Trust Lands Encyclopedia</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <Header />
    <main class="mx-auto max-w-prose p-4 sm:p-8">
      <header class="border-b border-slate-200 pb-6">
        <p class="text-sm uppercase tracking-wide text-slate-500">
          {data.iso} · FIPS {data.fips} · Admission #{data.admissionNumber}
        </p>
        <h1 class="mt-2 text-4xl font-bold tracking-tight">{data.name}</h1>
        <dl class="mt-4 grid grid-cols-1 gap-x-8 gap-y-2 text-sm sm:grid-cols-2">
          <div>
            <dt class="inline font-semibold text-slate-700">Admitted:</dt>
            <dd class="inline text-slate-600"> {dateFmt.format(data.admittedDate)}</dd>
          </div>
          <div>
            <dt class="inline font-semibold text-slate-700">Era:</dt>
            <dd class="inline text-slate-600"> {data.eraName} (cohort {data.eraCohort})</dd>
          </div>
          {data.federalGrantAcres !== null && (
            <div>
              <dt class="inline font-semibold text-slate-700">Federal grant:</dt>
              <dd class="inline text-slate-600">
                {data.federalGrantAcres === 0
                  ? ' none (state-derived)'
                  : ` ${num.format(data.federalGrantAcres)} acres`}
              </dd>
            </div>
          )}
          <div>
            <dt class="inline font-semibold text-slate-700">Governance:</dt>
            <dd class="inline text-slate-600"> {data.governanceForm}</dd>
          </div>
          {data.permanentFundCorpus && (
            <div>
              <dt class="inline font-semibold text-slate-700">Permanent fund:</dt>
              <dd class="inline text-slate-600">
                {' '}{usd.format(data.permanentFundCorpus.value)}
                {data.permanentFundCorpus.asOf && (
                  <span> (as of {dateFmt.format(data.permanentFundCorpus.asOf)})</span>
                )}
              </dd>
            </div>
          )}
          {data.latestDistribution && (
            <div>
              <dt class="inline font-semibold text-slate-700">
                {data.latestDistribution.fiscalYear
                  ? `FY${data.latestDistribution.fiscalYear} distribution:`
                  : 'Recent distribution:'}
              </dt>
              <dd class="inline text-slate-600"> {usd.format(data.latestDistribution.value)}</dd>
            </div>
          )}
        </dl>
        <p class="mt-4 text-xs text-slate-500">
          Substrate v{data.substrateVersion} · Last reviewed {dateFmt.format(data.lastReviewed)}
        </p>
      </header>
      <article class="prose prose-slate mt-8 max-w-none prose-a:text-blue-700 prose-a:underline">
        <Content />
      </article>
    </main>
    <Footer />
  </body>
</html>

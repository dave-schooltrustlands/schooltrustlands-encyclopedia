---
import BaseLayout from '../layouts/BaseLayout.astro';

type Hotspot = {
  href: string;
  ariaLabel: string;
  top: string;
  left: string;
  width: string;
  height: string;
  name: string;
  description: string;
  sections: string;
  anchorRight?: boolean;
};

const hotspots: Hotspot[] = [
  {
    href: '/',
    ariaLabel: 'Great Hall — the entrance and overview',
    top: '44%', left: '41%', width: '14%', height: '20%',
    name: 'Great Hall',
    description: 'The entrance and overview. Start anywhere.',
    sections: '',
  },
  {
    href: '/reading/',
    ariaLabel: 'Reading Room — three book-length works on America’s school trust lands',
    top: '45%', left: '21%', width: '17%', height: '25%',
    name: 'Reading Room',
    description: 'Three book-length works on America’s school trust lands.',
    sections: 'Schools of the Republic · The Eighth Anchor · Who Steals from Children',
  },
  {
    href: '/atlas/',
    ariaLabel: 'Atlas — what every federal-grant state did with its school-trust lands',
    top: '18%', left: '38%', width: '13%', height: '19%',
    name: 'Atlas',
    description: 'What every federal-grant state did with its school-trust lands.',
    sections: 'Fifty state entries — federal-grant states in alphabetical order',
  },
  {
    href: '/maps/',
    ariaLabel: 'Map Room — state-by-state cartography of the trust geography',
    top: '18%', left: '54%', width: '14%', height: '19%',
    name: 'Map Room',
    description: 'State-by-state cartography of the trust geography.',
    sections: '',
    anchorRight: true,
  },
  {
    href: '/counting/',
    ariaLabel: 'Counting House — the financial record',
    top: '45%', left: '70%', width: '16%', height: '25%',
    name: 'Counting House',
    description: 'The financial record. How much, where, and what was lost.',
    sections: '',
    anchorRight: true,
  },
  {
    href: '/newsroom/',
    ariaLabel: 'Newsroom — a weekly survey of what’s changing across the fifty states',
    top: '68%', left: '41%', width: '12%', height: '19%',
    name: 'Newsroom',
    description: 'A weekly survey of what’s changing across the fifty states.',
    sections: 'About the Newsroom · Recent issues · Subscribe by email · RSS feed',
  },
  {
    href: '/voices/',
    ariaLabel: 'Voices — signed editorial pieces from named contributors',
    top: '68%', left: '54%', width: '12%', height: '19%',
    name: 'Voices',
    description: 'Signed editorial pieces from named contributors.',
    sections: '',
  },
  {
    href: '/updates/',
    ariaLabel: 'Updates — the running log of what’s shipped on the site',
    top: '68%', left: '28%', width: '12%', height: '19%',
    name: 'Updates',
    description: 'The running log of what’s shipped on the site.',
    sections: 'Weekly summaries by date',
  },
  {
    href: '/pro/',
    ariaLabel: 'Pro Wing — governance, editorial standards, collection development, roles, charter, dispute resolution',
    top: '70%', left: '8%', width: '17%', height: '24%',
    name: 'Pro Wing',
    description: 'Governance, editorial standards, collection-development policy, roles, charter, dispute resolution.',
    sections: 'Governance · Editorial Standards · Collection Development · Roles · Bylaws · Dispute Resolution',
  },
];
---
<BaseLayout
  title="Explore the Library · America's School Trust Library"
  description="A floor plan of America's School Trust Library. Click any room to enter — Reading Room, Atlas, Map Room, Counting House, Newsroom, Voices, Updates, the Pro side. The Library's main spaces and how they connect."
  sourceId="explore"
>
  <article class="prose prose-slate max-w-none prose-a:text-blue-700 prose-a:underline">
    <p class="text-xs uppercase tracking-wide text-slate-500">Explore</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Explore the Library</h1>

    <p class="kicker text-slate-600">
      Click any room to enter. The Library is built around the spaces shown below — Reading Room, Atlas, Counting House, Map Room, Newsroom, Voices, Updates, and the Pro side. Smaller alcoves and side rooms in the drawing are sketched for future expansion and aren't clickable yet.
    </p>

    <div class="floor-plan-container not-prose">
      <img
        src="/img/posters/library-spatial-blueprint-v1.png"
        alt="Floor plan of America's School Trust Library showing rooms arranged around a Great Hall lobby — Reading Room, Atlas, Map Room, Counting House, Newsroom, Voices, Updates, Pro Wing — with hidden alcoves and corridors. Smaller decorative elements include a Primary Sources Alcove, a Scholarship Stack, and a Windowed Alcove."
        class="floor-plan-image"
      />
      {hotspots.map((h) => (
        <a
          href={h.href}
          class={`hotspot${h.anchorRight ? ' tooltip-anchor-right' : ''}`}
          style={`top:${h.top};left:${h.left};width:${h.width};height:${h.height}`}
          aria-label={h.ariaLabel}
        >
          <span class="visually-hidden">{h.name}</span>
          <span class="hotspot-tooltip" role="presentation">
            <strong>{h.name}</strong>
            <span class="tooltip-description">{h.description}</span>
            {h.sections && <span class="tooltip-sections">{h.sections}</span>}
          </span>
        </a>
      ))}
    </div>

    <p class="text-sm text-slate-600 mt-6">
      On phones and narrow screens, the floor plan above hides — the list below is the same content in text form. On wider screens it stays available as a quick directory.
    </p>

    <ul class="room-list">
      <li><a href="/"><strong>Great Hall</strong></a> — the entrance and overview. Start anywhere.</li>
      <li><a href="/reading/"><strong>Reading Room</strong></a> — three book-length works on America's school trust lands.</li>
      <li><a href="/atlas/"><strong>Atlas</strong></a> — what every federal-grant state did with its school-trust lands.</li>
      <li><a href="/maps/"><strong>Map Room</strong></a> — state-by-state cartography of the trust geography.</li>
      <li><a href="/counting/"><strong>Counting House</strong></a> — the financial record. How much, where, and what was lost.</li>
      <li><a href="/newsroom/"><strong>Newsroom</strong></a> — a weekly survey of what's changing across the fifty states.</li>
      <li><a href="/voices/"><strong>Voices</strong></a> — signed editorial pieces from named contributors.</li>
      <li><a href="/updates/"><strong>Updates</strong></a> — the running log of what's shipped on the site.</li>
      <li><a href="/pro/"><strong>Pro Wing</strong></a> — governance, editorial standards, collection-development policy, roles.</li>
    </ul>

    <p class="mt-10 text-slate-700">
      The Library is being built openly. If you find something missing or wrong, <a href="/about/founder/">tell the editor</a> — we welcome corrections and additions. For more on how the Library was conceived and built, see <a href="/about/">About the Library</a> and <a href="/about/how-this-works/">How this works</a>.
    </p>
  </article>
</BaseLayout>

<style>
  .floor-plan-container {
    position: relative;
    width: min(95vw, 1600px);
    margin: 1.5em auto;
    left: 50%;
    transform: translateX(-50%);
  }
  .floor-plan-image {
    width: 100%;
    height: auto;
    display: block;
  }
  .hotspot {
    position: absolute;
    background: transparent;
    border: 2px solid transparent;
    border-radius: 6px;
    transition: background 0.15s, border 0.15s;
    text-decoration: none;
  }
  .hotspot:hover,
  .hotspot:focus {
    background: rgba(212, 175, 55, 0.18);
    border-color: rgba(212, 175, 55, 0.7);
    outline: none;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }
  .hotspot-tooltip {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 8px;
    background: #fbf6e9;
    border: 1px solid #c8b78a;
    padding: 10px 14px;
    border-radius: 6px;
    box-shadow: 0 4px 12px rgba(31, 42, 68, 0.18);
    font-size: 0.92rem;
    line-height: 1.4;
    min-width: 220px;
    max-width: 320px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s, visibility 0.15s;
    z-index: 20;
    pointer-events: none;
    color: #1f2a44;
    text-align: left;
  }
  .hotspot.tooltip-anchor-right .hotspot-tooltip {
    left: auto;
    right: 0;
  }
  .hotspot-tooltip strong {
    display: block;
    font-size: 1.05rem;
    margin-bottom: 4px;
    color: #1f2a44;
  }
  .tooltip-description {
    display: block;
    margin-bottom: 6px;
  }
  .tooltip-sections {
    display: block;
    font-size: 0.85rem;
    color: #4a5a72;
  }
  .hotspot:hover .hotspot-tooltip,
  .hotspot:focus .hotspot-tooltip,
  .hotspot:focus-within .hotspot-tooltip {
    opacity: 1;
    visibility: visible;
  }
  .room-list {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 1rem 0;
  }
  .room-list li {
    margin: 0.4rem 0;
    line-height: 1.5;
  }
  @media (max-width: 768px) {
    .floor-plan-container {
      display: none;
    }
  }
</style>

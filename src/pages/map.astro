---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';

const entries = await getCollection('states');

const fipsToEntry: Record<string, { iso: string; name: string; admittedDate: string; eraCohort: number; eraName: string }> = {};
for (const e of entries) {
  fipsToEntry[e.data.fips] = {
    iso: e.data.iso.toLowerCase(),
    name: e.data.name,
    admittedDate: e.data.admittedDate.toISOString().slice(0, 10),
    eraCohort: e.data.eraCohort,
    eraName: e.data.eraName,
  };
}

// Six-cohort palette inspired by ColorBrewer Dark2 — colorblind-safe, print-safe.
const COHORT_COLORS: Record<number, string> = {
  1: '#1b9e77',
  2: '#d95f02',
  3: '#7570b3',
  4: '#e7298a',
  5: '#66a61e',
  6: '#e6ab02',
};

const COHORT_LABELS: Record<number, string> = {
  1: 'The Founding Floor',
  2: 'Statehood Without the Federal Floor',
  3: 'The Northwest Ordinance Template',
  4: 'The Antebellum Doubling',
  5: 'Reconstruction and the Western Stack',
  6: 'The Twentieth-Century High-Water Mark',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Map — School Trust Lands Encyclopedia</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <Header />
    <main class="mx-auto max-w-5xl p-4 sm:p-8">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Map of the school-trust states
      </h1>
      <p class="mt-3 text-slate-700">
        Each state is colored by its era cohort — the architectural moment in which it
        was admitted and given (or denied) a federal school-land grant. Click a state to
        open its encyclopedia entry.
      </p>

      <div
        id="map"
        class="mt-6 h-[60vh] min-h-[420px] w-full overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm"
      >
      </div>
      <pre
        id="map-error"
        class="mt-2 hidden whitespace-pre-wrap rounded border border-red-200 bg-red-50 p-3 text-xs text-red-800"
      ></pre>

      <script
        type="application/json"
        id="map-data"
        set:html={JSON.stringify({ fipsToEntry, cohortColors: COHORT_COLORS })}
      />

      <ol class="mt-4 grid grid-cols-1 gap-2 text-sm sm:grid-cols-2">
        {Object.entries(COHORT_LABELS).map(([cohort, label]) => (
          <li class="flex items-center gap-2">
            <span
              class="inline-block h-4 w-4 flex-none rounded-sm border border-slate-300"
              style={`background:${COHORT_COLORS[Number(cohort)]}`}
            ></span>
            <span class="text-slate-700">
              <span class="font-semibold">Chapter {cohort}.</span> {label}
            </span>
          </li>
        ))}
      </ol>
    </main>

    <script>
      import maplibregl from 'maplibre-gl';
      import 'maplibre-gl/dist/maplibre-gl.css';
      import { Protocol, PMTiles, FileSource } from 'pmtiles';

      const errBox = document.getElementById('map-error');
      const showErr = (label, e) => {
        const msg = `[${label}] ${e?.message ?? e}\n${e?.stack ?? ''}`;
        console.error(label, e);
        if (errBox) {
          errBox.classList.remove('hidden');
          errBox.textContent = (errBox.textContent ? errBox.textContent + '\n\n' : '') + msg;
        }
      };
      window.addEventListener('error', (ev) => showErr('window.error', ev.error || ev.message));
      window.addEventListener('unhandledrejection', (ev) => showErr('unhandledrejection', ev.reason));

      const dataNode = document.getElementById('map-data');
      const { fipsToEntry, cohortColors: COHORT_COLORS } = JSON.parse(
        dataNode.textContent || '{}',
      );

      const protocol = new Protocol();
      maplibregl.addProtocol('pmtiles', protocol.tile);

      // Pre-fetch the .pmtiles archive (~51 KB) as an ArrayBuffer and register it
      // with the protocol via FileSource. PMTiles' default FetchSource issues HTTP
      // byte-range requests, but Cloudflare Pages returns the full file on Range
      // requests (HTTP 200, no Accept-Ranges header), which causes FetchSource to
      // throw "Server returned no content-length header or content-length exceeding
      // request." Loading the whole archive once and serving slices from memory
      // avoids the dependency on byte-range support entirely.
      const PMTILES_KEY = '/us-states.pmtiles';
      const PMTILES_URL = `pmtiles://${PMTILES_KEY}`;
      try {
        const resp = await fetch(PMTILES_KEY);
        if (!resp.ok) throw new Error(`fetch ${PMTILES_KEY} → HTTP ${resp.status}`);
        const buf = await resp.arrayBuffer();
        const file = new File([buf], PMTILES_KEY, {
          type: 'application/octet-stream',
        });
        protocol.add(new PMTiles(new FileSource(file)));
      } catch (e) {
        showErr('pmtiles preload', e);
      }

      // Build a MapLibre 'match' expression: STATEFP (string) → cohort color.
      const matchExpr = ['match', ['get', 'STATEFP']];
      for (const [fips, entry] of Object.entries(fipsToEntry)) {
        matchExpr.push(fips, COHORT_COLORS[entry.eraCohort]);
      }
      matchExpr.push('#e2e8f0'); // slate-200 fallback for non-state polygons (DC, PR)

      const map = new maplibregl.Map({
        container: 'map',
        style: {
          version: 8,
          sources: {
            states: {
              type: 'vector',
              url: PMTILES_URL,
            },
          },
          layers: [
            {
              id: 'background',
              type: 'background',
              paint: { 'background-color': '#f8fafc' },
            },
            {
              id: 'states-fill',
              type: 'fill',
              source: 'states',
              'source-layer': 'states',
              paint: {
                'fill-color': matchExpr,
                'fill-opacity': [
                  'case',
                  ['boolean', ['feature-state', 'hover'], false],
                  0.95,
                  0.75,
                ],
              },
            },
            {
              id: 'states-outline',
              type: 'line',
              source: 'states',
              'source-layer': 'states',
              paint: {
                'line-color': '#475569',
                'line-width': 0.5,
              },
            },
            {
              id: 'states-outline-hover',
              type: 'line',
              source: 'states',
              'source-layer': 'states',
              paint: {
                'line-color': '#0f172a',
                'line-width': [
                  'case',
                  ['boolean', ['feature-state', 'hover'], false],
                  2,
                  0,
                ],
              },
            },
          ],
        },
        center: [-98.5, 39.5],
        zoom: 3,
        minZoom: 2,
        maxZoom: 6,
        attributionControl: false,
      });

      map.on('error', (e) => showErr('maplibre.error', e?.error || e));
      map.on('sourcedataloading', (e) => {
        if (e.sourceId === 'states') console.log('[map] sourcedataloading', e);
      });
      map.on('sourcedata', (e) => {
        if (e.sourceId === 'states' && e.isSourceLoaded)
          console.log('[map] source loaded', e);
      });

      map.addControl(
        new maplibregl.AttributionControl({
          customAttribution: 'US Census Bureau (cb_2023_us_state_20m)',
          compact: true,
        }),
      );
      map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-right');

      // Fit to CONUS on load; mobile-friendly.
      map.on('load', () => {
        map.fitBounds(
          [
            [-125, 24],
            [-66, 50],
          ],
          { padding: 20, animate: false },
        );
      });

      const popup = new maplibregl.Popup({
        closeButton: false,
        closeOnClick: false,
        offset: 6,
      });

      let hoveredFips = null;
      const setHover = (fips, on) => {
        if (fips === null) return;
        map.setFeatureState(
          { source: 'states', sourceLayer: 'states', id: undefined, ...{ } },
          { hover: on },
        );
      };

      map.on('mousemove', 'states-fill', (e) => {
        if (!e.features || e.features.length === 0) return;
        const f = e.features[0];
        const fips = f.properties.STATEFP;
        const entry = fipsToEntry[fips];
        const stateName = f.properties.NAME ?? entry?.name ?? '';

        // Reset previous hover state, set new.
        if (hoveredFips !== null && hoveredFips !== f.id) {
          map.setFeatureState(
            { source: 'states', sourceLayer: 'states', id: hoveredFips },
            { hover: false },
          );
        }
        hoveredFips = f.id;
        map.setFeatureState(
          { source: 'states', sourceLayer: 'states', id: hoveredFips },
          { hover: true },
        );

        map.getCanvas().style.cursor = entry ? 'pointer' : 'default';

        const html = entry
          ? `<div style="font-size:13px;line-height:1.3"><strong>${stateName}</strong><br/><span style="color:#64748b">Admitted ${entry.admittedDate}</span><br/><span style="color:#64748b;font-size:11px">Click to open entry →</span></div>`
          : `<div style="font-size:13px;line-height:1.3"><strong>${stateName}</strong><br/><span style="color:#64748b;font-size:11px">No encyclopedia entry</span></div>`;

        popup.setLngLat(e.lngLat).setHTML(html).addTo(map);
      });

      map.on('mouseleave', 'states-fill', () => {
        if (hoveredFips !== null) {
          map.setFeatureState(
            { source: 'states', sourceLayer: 'states', id: hoveredFips },
            { hover: false },
          );
          hoveredFips = null;
        }
        map.getCanvas().style.cursor = '';
        popup.remove();
      });

      map.on('click', 'states-fill', (e) => {
        if (!e.features || e.features.length === 0) return;
        const f = e.features[0];
        const entry = fipsToEntry[f.properties.STATEFP];
        if (entry) {
          window.location.href = `/states/${entry.iso}/`;
        }
      });
    </script>
  </body>
</html>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import LibraryCard from '../components/LibraryCard.astro';
import MemberBadgeList from '../components/MemberBadgeList.astro';
import { getServerSupabase } from '../lib/supabase';
import { userHasLibrarianRole } from '../lib/librarian';

export const prerender = false;

const supabase = getServerSupabase(Astro);
const {
  data: { user },
} = await supabase.auth.getUser();

if (!user) {
  return Astro.redirect('/auth/sign-in?redirect=/my-library/');
}

let formMessage: { kind: 'ok' | 'err'; text: string } | null = null;

if (Astro.request.method === 'POST') {
  const fd = await Astro.request.formData();
  const action = String(fd.get('action') ?? '');
  if (action === 'remove') {
    const id = String(fd.get('id') ?? '');
    if (id) {
      const { error } = await supabase
        .from('bookmarks')
        .delete()
        .eq('user_id', user.id)
        .eq('id', id);
      formMessage = error
        ? { kind: 'err', text: error.message }
        : { kind: 'ok', text: 'Bookmark removed.' };
    }
  }
}

const { data: bookmarks } = await supabase
  .from('bookmarks')
  .select('id, url, title, created_at')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false });

// v30 — patron's own feedback tickets, reverse chronological.
const { data: ticketsRaw } = await supabase
  .from('feedback')
  .select('id, ticket_number, page_url, subject, body, status, submitted_at')
  .eq('user_id', user.id)
  .order('submitted_at', { ascending: false });

const tickets = (ticketsRaw ?? []) as Array<{
  id: string;
  ticket_number: string;
  page_url: string;
  subject: string | null;
  body: string;
  status: string;
  submitted_at: string;
}>;

const STATUS_LABEL: Record<string, string> = {
  new: 'New',
  in_review: 'In review',
  responded: 'Responded',
  archived: 'Archived',
};

// Pull patron-card fields. Wide select so older deployments without the
// v2 columns still resolve (Supabase returns just the columns that exist).
// v33: include is_public_profile and bio for the profile-editor section.
let profile:
  | {
      display_name?: string | null;
      patron_number?: number | null;
      tier?: string | null;
      standing?: string | null;
      pages_read?: number | null;
      created_at?: string | null;
      bio?: string | null;
      is_public_profile?: boolean | null;
    }
  | null = null;

const { data: profileRow } = await supabase
  .from('profiles')
  .select('*')
  .eq('id', user.id)
  .single();
profile = profileRow ?? null;

// v30.1 — patron-name fallback chain. Never fall through to the tier value
// (which defaults to "Reader" and was bleeding into the name slot for
// pre-v29 patrons whose auth.users.raw_user_meta_data has no name field).
// Order: explicit display_name → magic-link metadata full_name →
// capitalized email local-part → generic placeholder.
const emailLocalPart = user.email ? user.email.split('@')[0] : '';
const metaFullNameRaw = user.user_metadata?.full_name;
const metadataFullName =
  typeof metaFullNameRaw === 'string' ? metaFullNameRaw.trim() : '';
const displayName =
  profile?.display_name?.trim() ||
  metadataFullName ||
  (emailLocalPart
    ? emailLocalPart.charAt(0).toUpperCase() + emailLocalPart.slice(1)
    : '') ||
  'Library Patron';
const tier = profile?.tier || 'Reader';
const standing = profile?.standing || 'Active';
const pagesRead = profile?.pages_read ?? 0;
const bookmarkCount = bookmarks?.length ?? 0;

// Patron number — formatted "00 001" with a regular space (the spec calls for
// a thin space; renders close enough at the card font size and stays copy-paste
// friendly). Fall back to 0 if the v2 migration hasn't been applied yet.
function formatPatronNumber(n: number | null | undefined): string {
  const v = typeof n === 'number' && n > 0 ? n : 0;
  const s = String(v).padStart(5, '0');
  return s.slice(0, 2) + ' ' + s.slice(2);
}
const patronNumberDisplay = formatPatronNumber(profile?.patron_number ?? null);

// Issued date — formatted as "11 May 2026" (DD Mon YYYY).
const MONTHS_SHORT = [
  'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
  'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec',
];
function formatCardDate(iso: string | null | undefined): string {
  if (!iso) return '';
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return '';
  return `${d.getUTCDate().toString().padStart(2, '0')} ${MONTHS_SHORT[d.getUTCMonth()]} ${d.getUTCFullYear()}`;
}

const createdAtIso = profile?.created_at || user.created_at || new Date().toISOString();
const issuedDisplay = formatCardDate(createdAtIso);

// "Member since" — `Today` if the account was created today (UTC); otherwise
// the same DD Mon YYYY format as the card.
function isSameUtcDate(a: Date, b: Date): boolean {
  return (
    a.getUTCFullYear() === b.getUTCFullYear() &&
    a.getUTCMonth() === b.getUTCMonth() &&
    a.getUTCDate() === b.getUTCDate()
  );
}
const createdDate = new Date(createdAtIso);
const memberSinceDisplay = isSameUtcDate(createdDate, new Date())
  ? 'Today'
  : formatCardDate(createdAtIso);

// Greeting — first-visit vs returning. A small cookie tracks whether the
// patron has been here before. Set after we read it so the first render of
// the page sees the first-visit greeting and every subsequent render sees
// the returning-visit greeting.
const visitedCookie = Astro.cookies.get('my_library_visited');
const isFirstVisit = !visitedCookie || visitedCookie.value !== '1';
if (isFirstVisit) {
  Astro.cookies.set('my_library_visited', '1', {
    path: '/',
    httpOnly: false,
    sameSite: 'lax',
    secure: true,
    maxAge: 60 * 60 * 24 * 365 * 5,
  });
}
const greeting = isFirstVisit
  ? `Welcome to the Library, ${displayName}.`
  : `Welcome back, ${displayName}.`;

// Continue-where-you-left-off strip: the most recent bookmark, if any.
const continueItem = (bookmarks && bookmarks.length > 0) ? bookmarks[0] : null;

// v30 — formatting helpers for feedback tickets.
function formatTicketDate(iso: string | null | undefined): string {
  if (!iso) return '';
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return '';
  const dd = d.getUTCDate().toString().padStart(2, '0');
  const mon = MONTHS_SHORT[d.getUTCMonth()];
  const yyyy = d.getUTCFullYear();
  return `${dd} ${mon} ${yyyy}`;
}
function summarizeTicket(t: { subject: string | null; body: string }): string {
  if (t.subject && t.subject.trim().length > 0) return t.subject.trim();
  const b = (t.body ?? '').trim();
  if (b.length <= 60) return b;
  return b.slice(0, 60).trimEnd() + '…';
}

// v31 — show the "Become a librarian" link unless the patron already has a
// librarian role. RLS "Own role read" gives the patron access to their own
// row, so this query returns truthy only when the patron is a librarian.
const isAlreadyLibrarian = await userHasLibrarianRole(supabase, user.id);

// ----------------------------------------------------------------------
// v33 — Inbox + Activity timeline + Profile editor
// ----------------------------------------------------------------------

// Inbox: 50 most recent notifications, unread first.
const { data: notificationsRaw } = await supabase
  .from('notifications')
  .select('id, kind, title, body, link_url, read_at, created_at')
  .eq('user_id', user.id)
  .order('read_at', { ascending: true, nullsFirst: true })
  .order('created_at', { ascending: false })
  .limit(50);

type NotificationRow = {
  id: string;
  kind: string;
  title: string;
  body: string | null;
  link_url: string | null;
  read_at: string | null;
  created_at: string;
};
const notifications = (notificationsRaw ?? []) as NotificationRow[];

const NOTIF_KIND_LABEL: Record<string, string> = {
  response_received: 'Response',
  review_published: 'Review published',
  application_approved: 'Application approved',
  application_declined: 'Application declined',
  discussion_reply: 'Discussion reply',
  badge_granted: 'Badge granted',
  ticket_status_changed: 'Ticket update',
};

function truncate(s: string | null | undefined, n: number): string {
  if (!s) return '';
  const t = s.trim();
  if (t.length <= n) return t;
  return t.slice(0, n).trimEnd() + '…';
}

// Activity timeline: union of recent events from six sources. Run in
// parallel; if any individual query errors, fall through with an empty
// list for that source.
type ActivityItem = {
  kind: string;
  label: string;
  summary: string;
  ts: string;
  href: string | null;
};

const [
  feedbackRes,
  correctionsRes,
  reviewsRes,
  discussionsRes,
  discussionPostsRes,
  badgesRes,
] = await Promise.all([
  supabase
    .from('feedback')
    .select('id, ticket_number, subject, body, submitted_at')
    .eq('user_id', user.id)
    .order('submitted_at', { ascending: false })
    .limit(50),
  supabase
    .from('corrections')
    .select('id, ticket_number, claim, submitted_at')
    .eq('user_id', user.id)
    .order('submitted_at', { ascending: false })
    .limit(50),
  supabase
    .from('reviews')
    .select('id, work_id, body, is_published, submitted_at, published_at, works(slug, title)')
    .eq('user_id', user.id)
    .order('submitted_at', { ascending: false })
    .limit(50),
  supabase
    .from('discussions')
    .select('id, ticket_number, title, created_at')
    .eq('user_id', user.id)
    .order('created_at', { ascending: false })
    .limit(50),
  supabase
    .from('discussion_posts')
    .select('id, discussion_id, body, posted_at')
    .eq('user_id', user.id)
    .order('posted_at', { ascending: false })
    .limit(50),
  supabase
    .from('member_badges')
    .select('id, badge, attribution, granted_at')
    .eq('user_id', user.id)
    .order('granted_at', { ascending: false })
    .limit(50),
]);

const activity: ActivityItem[] = [];

for (const f of (feedbackRes.data ?? []) as Array<{
  id: string; ticket_number: string; subject: string | null; body: string; submitted_at: string;
}>) {
  activity.push({
    kind: 'feedback',
    label: 'Submitted feedback',
    summary:
      (f.subject && f.subject.trim().length > 0)
        ? f.subject.trim()
        : truncate(f.body, 80),
    ts: f.submitted_at,
    href: `/my-library/tickets/${f.id}/`,
  });
}

for (const c of (correctionsRes.data ?? []) as Array<{
  id: string; ticket_number: string; claim: string; submitted_at: string;
}>) {
  activity.push({
    kind: 'correction',
    label: 'Submitted correction',
    summary: truncate(c.claim, 80),
    ts: c.submitted_at,
    href: `/my-library/tickets/${c.id}/`,
  });
}

for (const r of (reviewsRes.data ?? []) as Array<{
  id: string; work_id: string; body: string; is_published: boolean;
  submitted_at: string; published_at: string | null;
  works: { slug: string; title: string } | { slug: string; title: string }[] | null;
}>) {
  const work = Array.isArray(r.works) ? r.works[0] : r.works;
  const workTitle = work?.title ?? 'a work';
  const workSlug = work?.slug ?? '';
  activity.push({
    kind: 'review',
    label: r.is_published ? 'Review published' : 'Wrote review',
    summary: `Review of "${workTitle}" — ${truncate(r.body, 60)}`,
    ts: r.is_published && r.published_at ? r.published_at : r.submitted_at,
    href: workSlug ? `/reading/${workSlug}/reviews/` : null,
  });
}

for (const d of (discussionsRes.data ?? []) as Array<{
  id: string; ticket_number: string; title: string; created_at: string;
}>) {
  activity.push({
    kind: 'discussion',
    label: 'Started discussion',
    summary: truncate(d.title, 80),
    ts: d.created_at,
    href: `/discussions/${d.ticket_number}/`,
  });
}

// For discussion_posts we need ticket_number + title of the parent threads.
const postRows = (discussionPostsRes.data ?? []) as Array<{
  id: string; discussion_id: string; body: string; posted_at: string;
}>;
if (postRows.length > 0) {
  const threadIds = Array.from(new Set(postRows.map((p) => p.discussion_id)));
  const { data: threadLookupRaw } = await supabase
    .from('discussions')
    .select('id, ticket_number, title')
    .in('id', threadIds);
  const threadMap = new Map<string, { ticket_number: string; title: string }>();
  for (const t of (threadLookupRaw ?? []) as Array<{
    id: string; ticket_number: string; title: string;
  }>) {
    threadMap.set(t.id, { ticket_number: t.ticket_number, title: t.title });
  }
  for (const p of postRows) {
    const parent = threadMap.get(p.discussion_id);
    activity.push({
      kind: 'discussion_post',
      label: 'Replied in discussion',
      summary: parent
        ? `In "${truncate(parent.title, 50)}" — ${truncate(p.body, 60)}`
        : truncate(p.body, 80),
      ts: p.posted_at,
      href: parent ? `/discussions/${parent.ticket_number}/` : null,
    });
  }
}

const BADGE_LABEL: Record<string, string> = {
  state_expert: 'State Expert',
  oastl_board: 'OASTL Board',
  astl_board: 'ASTL Board',
  friend_of_library: 'Friend of the Library',
  editorial_contributor: 'Editorial Contributor',
  citizen_historian: 'Citizen Historian',
};
for (const b of (badgesRes.data ?? []) as Array<{
  id: string; badge: string; attribution: string | null; granted_at: string;
}>) {
  const name = BADGE_LABEL[b.badge] ?? b.badge;
  activity.push({
    kind: 'badge',
    label: 'Received badge',
    summary: b.attribution ? `${name} — ${b.attribution}` : name,
    ts: b.granted_at,
    href: profile?.is_public_profile && profile?.patron_number
      ? `/p/${profile.patron_number}/`
      : null,
  });
}

activity.sort((a, b) => (a.ts < b.ts ? 1 : a.ts > b.ts ? -1 : 0));
const activityRecent = activity.slice(0, 50);

// Profile editor — pull the current values into safe defaults.
const profileDisplayName = (profile?.display_name ?? '').trim();
const profileBio = (profile?.bio ?? '').trim();
const profileIsPublic = profile?.is_public_profile === true;
const patronNumberForUrl = profile?.patron_number ?? 0;
---

<BaseLayout
  title="My Library · America's School Trust Library"
  sourceId="my-library"
>
  <article class="my-library prose prose-slate max-w-none prose-a:text-blue-700 prose-a:underline">
    <h1 class="greeting">{greeting}</h1>

    {formMessage && (
      <div class:list={['flash', formMessage.kind]}>
        <p>{formMessage.text}</p>
      </div>
    )}

    <section class="card-section" aria-label="Your Library card">
      <LibraryCard
        name={displayName}
        number={patronNumberDisplay}
        issued={issuedDisplay}
        tier={tier}
        standing={standing}
        displayWidth={720}
        svgId="patron-library-card"
      />
      <p class="card-actions">
        <button type="button" class="card-action" data-action="download-card">
          Download card (PNG)
        </button>
        <span class="card-actions-divider" aria-hidden="true">·</span>
        <button type="button" class="card-action" data-action="share-card">
          Share card image
        </button>
      </p>
      <div class="card-badges" aria-label="Granted badges">
        <MemberBadgeList userId={user.id} />
      </div>
    </section>

    <section class="activity-row" aria-label="Library activity">
      <div class="activity-panel">
        <p class="activity-label">Member since</p>
        <p class="activity-value">{memberSinceDisplay}</p>
      </div>
      <div class="activity-panel">
        <p class="activity-label">Bookmarks</p>
        <p class="activity-value">{bookmarkCount}</p>
      </div>
      <div class="activity-panel">
        <p class="activity-label">Pages read</p>
        <p class="activity-value">{pagesRead}</p>
      </div>
    </section>

    <section class="unlocks" aria-label="What your card unlocks">
      <h2 class="unlocks-header">What your card unlocks</h2>
      <div class="unlocks-grid">
        <div class="unlocks-column">
          <p class="unlocks-subhead">Available now.</p>
          <ul class="unlocks-list">
            <li>Bookmark pages as you read.</li>
            <li>Continue where you left off.</li>
            <li>Track your reading.</li>
          </ul>
        </div>
        <div class="unlocks-column">
          <p class="unlocks-subhead">Coming soon.</p>
          <ul class="unlocks-list">
            <li>Submit a correction or annotation.</li>
            <li>Subscribe to a state page and get an update digest.</li>
            <li>Appear in the Library's Founders' Ledger (Patron tier and above, opt-in).</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="tickets-section" aria-label="My tickets">
      <div class="tickets-header-row">
        <h2 class="tickets-header">My Tickets</h2>
        {!isAlreadyLibrarian && (
          <a href="/apply/librarian/" class="become-link">
            Become a librarian →
          </a>
        )}
      </div>
      {tickets.length > 0 ? (
        <ul class="ticket-list">
          {tickets.map((t) => (
            <li class="ticket-item">
              <a class="ticket-row-link" href={`/my-library/tickets/${t.id}/`}>
                <span class="ticket-number">{t.ticket_number}</span>
                <span class="ticket-date">{formatTicketDate(t.submitted_at)}</span>
                <span class:list={['ticket-status', `ticket-status--${t.status}`]}>
                  {STATUS_LABEL[t.status] ?? t.status}
                </span>
                <span class="ticket-subject">{summarizeTicket(t)}</span>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty-state tickets-empty">
          You have not submitted any feedback or corrections yet. Press the
          <em> Submit feedback on this page </em>
          link in the footer of any page to start.
        </p>
      )}
    </section>

    <section class="inbox-section" aria-label="Inbox">
      <div class="inbox-header-row">
        <h2 class="inbox-header">Inbox</h2>
        {notifications.length > 0 && (
          <button type="button" class="mark-all-read" data-action="mark-all-read">
            Mark all read
          </button>
        )}
      </div>
      {notifications.length > 0 ? (
        <ul class="notification-list">
          {notifications.map((n) => {
            const label = NOTIF_KIND_LABEL[n.kind] ?? n.kind;
            const unread = n.read_at === null;
            const excerpt = truncate(n.body, 120);
            const Tag = n.link_url ? 'a' : 'div';
            return (
              <li class:list={['notification-item', unread ? 'is-unread' : '']}>
                <Tag
                  class="notification-row"
                  href={n.link_url ?? undefined}
                  data-notification-id={unread ? n.id : undefined}
                >
                  <span class="notification-dot" aria-hidden="true"></span>
                  <span class="notification-meta">
                    <span class="notification-kind">{label}</span>
                    <span class="notification-date">{formatTicketDate(n.created_at)}</span>
                  </span>
                  <span class="notification-title">{n.title}</span>
                  {excerpt && <span class="notification-body">{excerpt}</span>}
                </Tag>
              </li>
            );
          })}
        </ul>
      ) : (
        <p class="empty-state inbox-empty">
          No notifications yet. Activity on your tickets, reviews, and applications will appear here.
        </p>
      )}
    </section>

    <section class="activity-section" aria-label="Activity timeline">
      <h2 class="activity-section-header">Activity</h2>
      {activityRecent.length > 0 ? (
        <ul class="activity-timeline">
          {activityRecent.map((a) => {
            const Tag = a.href ? 'a' : 'div';
            return (
              <li class="activity-timeline-item">
                <Tag class="activity-timeline-row" href={a.href ?? undefined}>
                  <span class="activity-timeline-label">{a.label}</span>
                  <span class="activity-timeline-date">{formatTicketDate(a.ts)}</span>
                  <span class="activity-timeline-summary">{a.summary}</span>
                </Tag>
              </li>
            );
          })}
        </ul>
      ) : (
        <p class="empty-state activity-empty">
          Your activity will appear here as you submit feedback, write reviews, or join discussions.
        </p>
      )}
    </section>

    <section class="profile-section" aria-label="Your profile">
      <h2 class="profile-header">Your profile</h2>
      <form id="profile-form" class="profile-form">
        <label class="profile-label" for="profile-display-name">
          Display name
        </label>
        <input
          id="profile-display-name"
          name="display_name"
          type="text"
          class="profile-input"
          maxlength="80"
          value={profileDisplayName}
          required
        />

        <label class="profile-label" for="profile-bio">
          Bio
          <span class="profile-hint">(optional, up to 500 characters)</span>
        </label>
        <textarea
          id="profile-bio"
          name="bio"
          class="profile-textarea"
          maxlength="500"
          rows="4"
        >{profileBio}</textarea>

        <label class="profile-checkbox-row">
          <input
            id="profile-is-public"
            name="is_public_profile"
            type="checkbox"
            checked={profileIsPublic}
          />
          <span>Show my profile publicly</span>
        </label>

        <div class="profile-actions">
          <button type="submit" class="profile-save">Save profile</button>
          <span id="profile-status" class="profile-status" aria-live="polite"></span>
        </div>
      </form>
      {profileIsPublic && patronNumberForUrl > 0 && (
        <p class="profile-public-link">
          Your public profile: <a href={`/p/${patronNumberForUrl}/`}>/p/{patronNumberForUrl}/</a>
        </p>
      )}
    </section>

    {continueItem && (
      <section class="continue-strip" aria-label="Continue where you left off">
        <h2 class="continue-header">Continue where you left off.</h2>
        <a class="continue-card" href={continueItem.url}>
          <p class="continue-title">{continueItem.title || continueItem.url}</p>
          <p class="continue-url">{continueItem.url}</p>
          <p class="continue-cta">Continue →</p>
        </a>
      </section>
    )}

    <section class="bookmarks-section" aria-label="Your bookmarks">
      <h2 class="bookmarks-header">Bookmarks</h2>
      {bookmarks && bookmarks.length > 0 ? (
        <ul class="bookmark-list">
          {bookmarks.map((b) => (
            <li class="bookmark-item">
              <div class="bookmark-meta">
                <a class="bookmark-link" href={b.url}>
                  {b.title || b.url}
                </a>
                <p class="bookmark-url">{b.url}</p>
              </div>
              <form method="POST" class="bookmark-remove-form">
                <input type="hidden" name="action" value="remove" />
                <input type="hidden" name="id" value={b.id} />
                <button type="submit" class="bookmark-remove">Remove</button>
              </form>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty-state">
          Your bookmarks will appear here as you save pages you want to return to.
        </p>
      )}
    </section>

    <p class="library-footer">
      <a href="/profile">Edit profile</a> &nbsp;·&nbsp;
      <a href="/auth/sign-out">Sign out</a>
    </p>
  </article>

  <script
    is:inline
    define:vars={{
      TEMPLATE_HREF: '/img/cards/library_card_blank_template_v1.png',
      TEMPLATE_W: 1586,
      TEMPLATE_H: 992,
      PATRON_NAME: displayName,
      PATRON_NUMBER: patronNumberDisplay,
    }}
  >

    async function renderCardToBlob(targetW = 1200) {
      const svg = document.getElementById('patron-library-card');
      if (!svg) throw new Error('card SVG not found');

      // Serialize the SVG. Replace the same-origin image href with a data URL
      // so the canvas isn't tainted (and so the rasterization is deterministic).
      const cloned = svg.cloneNode(true);
      const imgEl = cloned.querySelector('image');
      if (imgEl) {
        const resp = await fetch(TEMPLATE_HREF);
        const blob = await resp.blob();
        const dataUrl = await new Promise((resolve, reject) => {
          const r = new FileReader();
          r.onload = () => resolve(r.result);
          r.onerror = () => reject(r.error);
          r.readAsDataURL(blob);
        });
        imgEl.setAttribute('href', dataUrl);
        imgEl.removeAttribute('xlink:href');
      }
      cloned.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
      const xml = new XMLSerializer().serializeToString(cloned);
      const svgBlob = new Blob([xml], { type: 'image/svg+xml;charset=utf-8' });
      const svgUrl = URL.createObjectURL(svgBlob);

      try {
        const aspect = TEMPLATE_H / TEMPLATE_W;
        const w = targetW;
        const h = Math.round(targetW * aspect);
        const canvas = document.createElement('canvas');
        canvas.width = w;
        canvas.height = h;
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#FBF8F1';
        ctx.fillRect(0, 0, w, h);

        await new Promise((resolve, reject) => {
          const img = new Image();
          img.onload = () => {
            ctx.drawImage(img, 0, 0, w, h);
            resolve();
          };
          img.onerror = (e) => reject(new Error('SVG image load failed'));
          img.src = svgUrl;
        });

        return await new Promise((resolve) =>
          canvas.toBlob(resolve, 'image/png')
        );
      } finally {
        URL.revokeObjectURL(svgUrl);
      }
    }

    function filenameFor(ext) {
      const slug = (PATRON_NAME || 'patron')
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');
      const numberPart = (PATRON_NUMBER || '00_000').replace(/\s+/g, '_');
      return `library-card-${numberPart}-${slug}.${ext}`;
    }

    document.querySelectorAll('[data-action="download-card"]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        try {
          const blob = await renderCardToBlob(1200);
          if (!blob) throw new Error('no blob');
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = filenameFor('png');
          document.body.appendChild(a);
          a.click();
          a.remove();
          URL.revokeObjectURL(url);
        } catch (e) {
          console.error('download failed', e);
          alert('Sorry — the card could not be rendered. Try refreshing.');
        }
      });
    });

    document.querySelectorAll('[data-action="share-card"]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        try {
          const blob = await renderCardToBlob(1200);
          if (!blob) throw new Error('no blob');
          const file = new File([blob], filenameFor('png'), { type: 'image/png' });

          if (navigator.canShare && navigator.canShare({ files: [file] })) {
            await navigator.share({
              files: [file],
              title: 'My Library Card',
              text: 'America’s School Trust Library — Patron Card',
            });
            return;
          }

          if (navigator.clipboard && window.ClipboardItem) {
            await navigator.clipboard.write([
              new ClipboardItem({ 'image/png': blob }),
            ]);
            alert('Card image copied to clipboard.');
            return;
          }

          // Final fallback — open in a new tab.
          const url = URL.createObjectURL(blob);
          window.open(url, '_blank', 'noopener');
        } catch (e) {
          console.error('share failed', e);
          alert('Sharing is not supported in this browser. Use Download card instead.');
        }
      });
    });
  </script>

  <script is:inline>
    // v33 — Inbox: mark-all-read button and per-row mark-read on click.
    (function () {
      var markAllBtn = document.querySelector('[data-action="mark-all-read"]');
      if (markAllBtn) {
        markAllBtn.addEventListener('click', function () {
          markAllBtn.disabled = true;
          fetch('/api/notification/mark-all-read', { method: 'POST' })
            .then(function () { window.location.reload(); })
            .catch(function () { markAllBtn.disabled = false; });
        });
      }

      // Per-row: fire-and-forget mark-read, let the link navigate naturally.
      var rows = document.querySelectorAll('[data-notification-id]');
      rows.forEach(function (row) {
        row.addEventListener('click', function () {
          var id = row.getAttribute('data-notification-id');
          if (!id) return;
          try {
            fetch('/api/notification/' + encodeURIComponent(id) + '/mark-read', {
              method: 'POST',
              keepalive: true,
            });
          } catch (_) { /* swallow */ }
        });
      });
    })();
  </script>

  <script is:inline>
    // v33 — Profile editor: POST JSON to /api/profile/update, show status.
    (function () {
      var form = document.getElementById('profile-form');
      if (!form) return;
      var status = document.getElementById('profile-status');
      form.addEventListener('submit', function (ev) {
        ev.preventDefault();
        if (status) { status.textContent = 'Saving…'; status.className = 'profile-status'; }
        var displayName = document.getElementById('profile-display-name');
        var bio = document.getElementById('profile-bio');
        var isPublic = document.getElementById('profile-is-public');
        var payload = {
          display_name: displayName ? displayName.value : '',
          bio: bio ? bio.value : '',
          is_public_profile: isPublic ? !!isPublic.checked : false,
        };
        fetch('/api/profile/update', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        })
          .then(function (res) {
            return res.json().then(function (j) { return { ok: res.ok, body: j }; });
          })
          .then(function (r) {
            if (r.ok) {
              if (status) {
                status.textContent = 'Saved.';
                status.className = 'profile-status ok';
              }
              setTimeout(function () { window.location.reload(); }, 700);
            } else {
              if (status) {
                status.textContent = (r.body && r.body.error) || 'Could not save profile.';
                status.className = 'profile-status err';
              }
            }
          })
          .catch(function () {
            if (status) {
              status.textContent = 'Could not save profile.';
              status.className = 'profile-status err';
            }
          });
      });
    })();
  </script>


---
import { getCollection } from 'astro:content';
import RoomLayout from '../../../layouts/RoomLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('library');
  return entries.map((entry) => ({
    params: { slug: (entry.slug ?? entry.id).replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const slug = (entry.slug ?? entry.id).replace(/\.md$/, '');
const treatment = entry.data.treatment;
const sourceLabel = entry.data.sourceLabel ?? 'the source';
const subtitle = `${entry.data.author}, ${entry.data.year}.`;
---
<RoomLayout
  room="reading"
  title={entry.data.title}
  parents={[{ label: 'The Curated Collection', href: '/reading/library/' }]}
  subtitle={subtitle}
  width="prose"
  sourceId={`library-${slug}`}
  pageTitle={`${entry.data.title} · Reading Room · America's School Trust Library`}
>
  <p slot="before-title" class="text-xs uppercase tracking-wide text-slate-500">
    Reading Room · {entry.data.categoryName}
  </p>

  <article class="prose prose-slate max-w-none mt-8 prose-a:text-blue-700 prose-a:underline">
    <Content />
  </article>

  {treatment === 'link-plus-full-text-hosted' && entry.data.hostedPdfPath && (
    <section class="not-prose mt-10">
      <h2 class="text-xl font-semibold tracking-tight text-slate-900">Full text — hosted at the Library</h2>
      <p class="mt-2 text-sm text-slate-600">
        The Library carries the full opinion inline below. A downloadable copy is available beneath the viewer.
      </p>
      <iframe
        src={entry.data.hostedPdfPath}
        title={`${entry.data.title} — full text`}
        class="mt-4 w-full rounded-md border border-slate-300 bg-white"
        style="height: 600px;"
      ></iframe>
      <p class="mt-3 text-sm">
        <a href={entry.data.hostedPdfPath} class="text-blue-700 underline" download>
          Download PDF →
        </a>
      </p>
    </section>
  )}

  <section class="not-prose mt-10 rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
      How to engage
    </p>
    <p class="mt-2 text-base text-slate-800">
      <a href={entry.data.sourceUrlPrimary} class="font-semibold text-blue-700 underline" rel="noopener" target="_blank">
        Read it at {sourceLabel} →
      </a>
    </p>
    {entry.data.sourceUrlFallback && (
      <p class="mt-2 text-sm text-slate-600">
        Fallback: <a href={entry.data.sourceUrlFallback} class="text-blue-700 underline" rel="noopener" target="_blank">{entry.data.sourceUrlFallback}</a>
      </p>
    )}
    {treatment === 'link-plus-full-text' && (
      <p class="mt-3 text-sm italic text-slate-600">
        The full text is reproduced inline above as part of the Library's editorial presentation.
      </p>
    )}
    {treatment === 'link-plus-excerpt' && (
      <p class="mt-3 text-sm italic text-slate-600">
        A representative passage from the work is excerpted inline above; the full text lives at the source.
      </p>
    )}
  </section>

  <hr class="my-10 border-slate-200" />

  <p class="text-sm text-slate-600">
    <a href="/reading/" class="text-blue-700 underline">← Back to the Reading Room</a>
    &nbsp;·&nbsp;
    <a href="/contribute/" class="text-blue-700 underline">Suggest a contribution</a>
  </p>
</RoomLayout>

---
// v25 GAMMA — Volume 1 landing for Who Steals from Children. Renders
// the title, byline, spine sentence, and a 16-row Table of Contents
// drawn from the essays collection filtered to the WSFC Vol 1 sourceWork.
//
// Like other landings, this page does NOT carry the per-chapter banner
// (banner is gated on kind === 'essay' in [slug].astro). It does carry
// the site-wide pre-publication footer via BaseLayout.
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const WSFC_VOL1 = 'Who Steals from Children: Volume 1 — Oregon and the Elliott';

const chapters = (await getCollection('essays'))
  .filter((e) => e.data.sourceWork === WSFC_VOL1)
  .sort((a, b) => a.data.order - b.data.order);

const formatChapterNumber = (n: string | number | undefined): string => {
  if (n === undefined) return '';
  if (typeof n === 'number') return `Chapter ${n}`;
  return n; // "Foreword", "Preface", "Documentary Record"
};

// Strip the "Chapter N — " prefix from body-chapter titles when we
// already render the chapter number in the ToC's first column.
const trimChapterTitle = (title: string): string =>
  title.replace(/^Chapter\s+\d+\s+—\s+/, '').trim();
---
<BaseLayout
  title="Who Steals from Children: Volume 1 — Oregon and the Elliott · America's School Trust Library"
  description="The prosecutorial-history record of how the State of Oregon has spent thirty-five years removing the Elliott State Forest from the Common School Fund. Volume 1 of the Who Steals from Children series."
  sourceId="reading-wsfc-vol1-elliott"
>
  <article class="prose prose-slate max-w-none prose-a:text-blue-700 prose-a:underline">
    <p class="text-xs uppercase tracking-wide text-slate-500">
      Reading Room · <a href="/reading/who-steals-from-children/"><em>Who Steals from Children</em> series</a> · Volume 1
    </p>
    <h1 class="mt-2">
      <em>Who Steals from Children: Volume 1 — Oregon and the Elliott</em>
    </h1>
    <p class="byline text-slate-700">
      <strong>Dave Sullivan</strong>, with Daniel Zene Crowe (legal) and Margaret Bird (foreword).
    </p>

    <p class="spine mt-6 text-lg leading-relaxed text-slate-800">
      Oregon is trying to take a $1-billion-plus asset that belongs in trust
      for schoolchildren and convert it into a research forest at OSU paid for
      by general-fund bonds, and we have caught them in the act. That is the
      whole indictment. The rest of this book is the evidence.
    </p>

    <p class="mt-6 text-slate-700">
      Volume 1 is the first volume of the <a href="/reading/who-steals-from-children/"><em>Who Steals from Children</em> series</a> — a state-by-state prosecutorial-history record of how America's school-land trusts are being broken in the present tense. Future volumes are forthcoming as each state's record is assembled.
    </p>
  </article>

  <section class="toc mt-10" aria-labelledby="toc-heading">
    <h2 id="toc-heading" class="toc-heading">Table of Contents</h2>
    <ol class="toc-list">
      {chapters.map((c) => {
        const isBodyChapter = typeof c.data.chapterNumber === 'number';
        const navTitle = isBodyChapter ? trimChapterTitle(c.data.title) : c.data.title;
        const numberLabel = formatChapterNumber(c.data.chapterNumber);
        return (
          <li class="toc-item">
            <a href={`/reading/${c.slug}/`} class="toc-link">
              <span class="toc-number">{numberLabel}</span>
              <span class="toc-title">{navTitle}</span>
            </a>
          </li>
        );
      })}
    </ol>
  </section>

  <p class="mt-12 text-sm text-slate-600">
    <a href="/reading/who-steals-from-children/">← Back to the series landing</a>
    <span aria-hidden="true" class="text-slate-300"> · </span>
    <a href="/reading/">Back to the Reading Room</a>
  </p>
</BaseLayout>

<style>
  .byline {
    font-family: var(--font-sans);
    font-size: 0.95rem;
  }
  .spine {
    font-family: var(--font-serif, Georgia, serif);
    border-left: 3px solid var(--old-gold, #8b7355);
    padding: 0.25rem 0 0.25rem 1rem;
    margin-top: 1.5rem;
  }
  .toc {
    border-top: 1px solid var(--rule-border, #e5e7eb);
    padding-top: 1.5rem;
  }
  .toc-heading {
    font-family: var(--font-serif, Georgia, serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--deep-navy, #1e3a5f);
    margin: 0 0 1rem;
  }
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc-item {
    border-bottom: 1px dotted var(--rule-border, #e5e7eb);
  }
  .toc-link {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 0.75rem;
    padding: 0.65rem 0.25rem;
    color: inherit;
    text-decoration: none;
    align-items: baseline;
  }
  .toc-link:hover {
    background: var(--linen-card, #fafaf7);
  }
  .toc-number {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--old-gold, #8b7355);
    font-weight: 600;
  }
  .toc-title {
    font-family: var(--font-serif, Georgia, serif);
    font-size: 1.02rem;
    color: var(--deep-navy, #1e3a5f);
    text-decoration: underline;
    text-decoration-color: #cbd5e1;
    text-underline-offset: 3px;
  }
  .toc-link:hover .toc-title {
    text-decoration-color: var(--deep-navy, #1e3a5f);
  }
  @media (max-width: 640px) {
    .toc-link {
      grid-template-columns: 1fr;
      gap: 0.1rem;
    }
  }
</style>

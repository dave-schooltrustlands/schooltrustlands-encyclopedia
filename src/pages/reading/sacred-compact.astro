---
import { getCollection, type CollectionEntry } from 'astro:content';
import RoomLayout from '../../layouts/RoomLayout.astro';
import BookBanner from '../../components/BookBanner.astro';
import { getServerSupabase } from '../../lib/supabase';

export const prerender = false;

// v32 — published-review count for the Reviews link at the foot of the
// landing. We resolve the eighth-anchor work row by slug and count
// published reviews; failures degrade silently to 0.
let reviewCount = 0;
try {
  const supabase = getServerSupabase(Astro);
  const { data: work } = await supabase
    .from('works')
    .select('id')
    .eq('slug', 'the-eighth-anchor')
    .maybeSingle();
  if (work?.id) {
    const { count } = await supabase
      .from('reviews')
      .select('id', { count: 'exact', head: true })
      .eq('work_id', work.id)
      .eq('is_published', true);
    if (typeof count === 'number') reviewCount = count;
  }
} catch {
  // swallow
}

type Essay = CollectionEntry<'essays'>;

const sections: Essay[] = (await getCollection('essays'))
  .filter((e) => e.data.sourceWork === 'Sacred Compact white paper v5.0')
  .sort((a, b) => a.data.order - b.data.order);

// Pull H2s from each section's body so the landing surfaces the
// internal subheads without requiring the substrate to maintain a
// duplicate outline.
function extractH2s(body: string): string[] {
  const lines = body.split('\n');
  const heads: string[] = [];
  for (const ln of lines) {
    const m = ln.match(/^##\s+(.+?)\s*$/);
    if (m && !/^Footnotes/i.test(m[1])) heads.push(m[1]);
  }
  return heads;
}

const sectionsWithSubheads = await Promise.all(
  sections.map(async (entry) => {
    const body = entry.body;
    return { entry, subheads: extractH2s(body) };
  }),
);

const num = new Intl.NumberFormat('en-US');
const total = sections.reduce((sum, s) => sum + s.data.wordCount, 0);
---

<RoomLayout
  room="reading"
  title="The Eighth Anchor"
  subtitle={`How Long-Horizon Trusts Survive (and Fail), and What the Next Generation Needs to Know. Dave Sullivan, Volume 2 of a two-volume work. ${num.format(total)} words across eight sections — the school-trust record applied to the AI-era institutions now being designed.`}
  width="prose"
  sourceId="sacred-compact-toc"
>
  <BookBanner slot="before-title" direction="forward" />
  <figure class="opener-figure" style="margin: 1.5rem 0;">
    <img
      src="/img/sources/magna-carta-1215.jpg"
      alt="Magna Carta exemplar, 1215"
      style="width: 100%; height: auto; max-height: 360px; object-fit: cover; border: 1px solid var(--rule-border);"
    />
    <figcaption>
      Magna Carta exemplar, 1215. The deepest root of the trust covenant whose American descendants this paper traces. Public domain.
    </figcaption>
  </figure>

  <section class="authors-note" aria-labelledby="authors-note-heading">
    <p class="authors-note-kicker">Front Matter</p>
    <h2 id="authors-note-heading" class="authors-note-heading"><em>A Note from the Authors</em></h2>
    <p>
      This volume does not propose to save the world. We want to be clear about
      that at the start, because the language of multi-generational trust
      architecture can drift into the messianic, and we have neither the
      temperament nor the credentials for messianic claims. What the volume does
      propose is more modest, and we believe it is achievable.
    </p>
    <p>
      The architects of a small set of forever-institutions are, in 2026,
      drafting charters that will operate for centuries. The institutions are
      real and are listed in the Prologue: AI Targeting Authorities, perpetual
      climate trusts, sovereign wealth funds for citizens not yet born,
      longevity escrows, compute reserves, data trusts. Their charters are, at
      this writing, still draft. The window in which the school-trust
      experiment's 240-year record can usefully reach those architects is the
      window in which their charters can still be amended. After the charters
      set, the same institutional drift the school trusts have endured will
      start running on the new institutions, and the lessons of the school-trust
      record will arrive too late to inform the design that produced the drift.
    </p>
    <p>
      We are not the architects of those institutions. We are not the people
      writing the AI Targeting Authority charter, or the perpetual climate
      trust language, or the sovereign-wealth-fund-for-the-unborn governance
      document. What we are is a small team — a school-trust economist who has
      worked inside the system for forty years; a retired systems scientist and
      tree farmer who has watched a particular institutional-failure pattern
      play out three times in his career; the Library at schooltrusts.net,
      which is the institutional substrate this volume rests on; and a working
      network of advocates and researchers and named editors who have, between
      them, spent enough time inside the school-trust record to write down what
      we have learned in a form the architects can read.
    </p>
    <p>
      Our hope is modest. Reach the small set of people whose charter drafts
      this volume can usefully inform. Ten readers, twenty, perhaps fifty. The
      number is small because the work is specialized; the potential effect, if
      those readers are reached in time, is large because the institutions they
      are designing are designed to compound across the kind of time horizons
      most institutions never face. Multi-generational work pays dividends on
      the timescale of the trust, not on the timescale of the founders' lives.
      The framers of 1785 did not see their endowment reach Utah's nine
      thousand school deliberators in 2026; they wrote the gift, and the gift
      kept going. We are writing what we have learned for whoever is drafting
      the next round.
    </p>
    <p>
      If we have done the work in this volume well, one architect in one
      charter window will read a chapter, change one design choice, and the
      institution they are launching will hold for a longer span of time,
      against more pressure, than it would otherwise have. That is the whole
      aim. It is not the same as saving the world. It is, we believe,
      achievable. And it is enough.
    </p>
    <p class="authors-note-byline">
      — <em>Dave Sullivan, Oregon, 2026.</em>
    </p>
  </section>

  <section class="asymmetric-authorship-note" aria-labelledby="asymmetric-authorship-heading">
    <p class="asymmetric-authorship-kicker">A note on authorship</p>
    <h2 id="asymmetric-authorship-heading" class="asymmetric-authorship-heading"><em>Two volumes, two vantage points</em></h2>
    <p>
      Volume 1 of this work, <em>Schools of the Republic</em>, is the historical
      record of America's school trust lands. Margaret Bird is the co-author;
      she has spent her career fighting for school trusts from inside the
      system, and that work pulls her gaze backward — into what the trusts
      were promised, what was delivered, and what is owed.
    </p>
    <p>
      Volume 2, <em>The Eighth Anchor</em>, is the forward-looking case the
      record makes possible: what the failure modes of two centuries of school
      trusts teach the architects of the next fiduciary era — AI Targeting
      Authorities, perpetual climate trusts, sovereign wealth for the unborn,
      longevity escrows, compute reserves. Volume 2 is mine alone. My
      background is in information systems; that work pulls my gaze forward,
      into the question of what we are about to build and what could keep it
      from drifting.
    </p>
    <p>
      Both volumes stand on their own. A reader can begin with either.
    </p>
    <p class="asymmetric-authorship-byline">
      — <em>Dave Sullivan</em>
    </p>
  </section>

  <p class="mt-4 text-xs text-slate-500">
    The eight sections below can be read in order or dipped into independently;
    footnote namespaces are section-prefixed so cross-section links resolve
    cleanly.
  </p>

  <style>
    .authors-note {
      margin: 2rem 0 2.25rem;
      padding: 1.25rem 1.5rem 1rem;
      background: var(--linen-card, #fafaf7);
      border: 1px solid var(--rule-border, #e5e7eb);
      border-left: 3px solid var(--old-gold, #8b7355);
      border-radius: 4px;
    }
    .authors-note-kicker {
      font-family: var(--font-sans);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--old-gold, #8b7355);
      margin: 0 0 0.4rem;
    }
    .authors-note-heading {
      font-family: var(--font-serif, Georgia, serif);
      font-size: 1.35rem;
      font-weight: 600;
      color: var(--deep-navy, #1e3a5f);
      margin: 0 0 0.85rem;
      line-height: 1.3;
    }
    .authors-note p {
      font-family: var(--font-serif, Georgia, serif);
      font-size: 1rem;
      line-height: 1.65;
      color: #1f2937;
      margin: 0 0 0.85rem;
    }
    .authors-note p:last-child {
      margin-bottom: 0;
    }
    .authors-note-byline {
      margin-top: 1rem;
      color: #475569;
    }

    .asymmetric-authorship-note {
      margin: 1.5rem 0 2rem;
      padding: 1.1rem 1.4rem 0.9rem;
      background: var(--linen-card, #fafaf7);
      border: 1px solid var(--rule-border, #e5e7eb);
      border-left: 3px solid var(--old-gold, #8b7355);
      border-radius: 4px;
    }
    .asymmetric-authorship-kicker {
      font-family: var(--font-sans);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--old-gold, #8b7355);
      margin: 0 0 0.35rem;
    }
    .asymmetric-authorship-heading {
      font-family: var(--font-serif, Georgia, serif);
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--deep-navy, #1e3a5f);
      margin: 0 0 0.75rem;
      line-height: 1.3;
    }
    .asymmetric-authorship-note p {
      font-family: var(--font-serif, Georgia, serif);
      font-size: 0.97rem;
      line-height: 1.6;
      color: #1f2937;
      margin: 0 0 0.7rem;
    }
    .asymmetric-authorship-note p:last-child {
      margin-bottom: 0;
    }
    .asymmetric-authorship-byline {
      margin-top: 0.85rem;
      color: #475569;
    }
  </style>

  <ol class="mt-8 space-y-6">
    {sectionsWithSubheads.map(({ entry, subheads }) => (
      <li class="border-b border-slate-200 pb-4 last:border-b-0">
        <a
          href={`/reading/${entry.slug}/`}
          class="text-lg font-semibold text-blue-700 underline hover:text-blue-900"
        >
          {entry.data.title.replace(/^Sacred Compact: /, '').replace(/^The Eighth Anchor: /, '')}
        </a>
        <p class="mt-1 text-xs text-slate-500">
          {num.format(entry.data.wordCount)} words
        </p>
        {subheads.length > 0 && (
          <ul class="mt-2 list-disc pl-6 text-sm text-slate-600">
            {subheads.map((h) => (
              <li>{h}</li>
            ))}
          </ul>
        )}
      </li>
    ))}
  </ol>

  <p class="mt-8 text-sm text-slate-500">
    <a href="/reading/" class="text-blue-700 underline hover:text-blue-900">← Reading Room</a>
  </p>

  <p class="mt-4 text-sm text-slate-500">
    <a href="/reading/the-eighth-anchor/reviews/" class="text-blue-700 underline hover:text-blue-900">Reviews ({reviewCount})</a>
  </p>
</RoomLayout>

---
import { getCollection, type CollectionEntry } from 'astro:content';
import RoomLayout from '../../layouts/RoomLayout.astro';
import StateDossier from '../../components/StateDossier.astro';
import StateDossierCard from '../../components/StateDossierCard.astro';

type EssayProps = { kind: 'essay'; entry: CollectionEntry<'essays'> };
type StateProps = { kind: 'state'; entry: CollectionEntry<'states'> };
type Props = EssayProps | StateProps;

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  const states = await getCollection('states');

  const essayPaths = essays.map((entry) => ({
    params: { slug: entry.slug.replace(/^\d+-/, '') },
    props: { kind: 'essay' as const, entry },
  }));

  const statePaths = states.map((entry) => ({
    params: { slug: entry.data.iso.toLowerCase() },
    props: { kind: 'state' as const, entry },
  }));

  return [...essayPaths, ...statePaths];
}

const props = Astro.props as Props;

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const num = new Intl.NumberFormat('en-US');
const usd = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
});

const { Content } = await props.entry.render();

const layoutProps =
  props.kind === 'essay'
    ? {
        title: props.entry.data.title,
        subtitle: `Era: ${props.entry.data.era}`,
        sourceId: `essay-${props.entry.slug}-${props.entry.data.sourceVersion}`,
        pagefindEra: props.entry.data.era,
      }
    : {
        title: props.entry.data.name,
        subtitle: `${props.entry.data.iso} · FIPS ${props.entry.data.fips} · Admission #${props.entry.data.admissionNumber}`,
        state: {
          iso: props.entry.data.iso.toLowerCase(),
          name: props.entry.data.name,
        },
        sourceId: `state-${props.entry.data.iso.toLowerCase()}-v${props.entry.data.substrateVersion}`,
      };
---

<RoomLayout room="reading" {...layoutProps} width="prose">
  {props.kind === 'essay' && (
    <Fragment slot="header-extras">
      <p class="mt-4 text-xs text-slate-500">
        {num.format(props.entry.data.wordCount)} words · Substrate {props.entry.data.sourceVersion} · Last synced {dateFmt.format(props.entry.data.lastSynced)}
      </p>
      <p class="mt-3">
        <a href="/reading/" class="text-sm text-blue-700 underline hover:text-blue-900">
          ← Back to Reading Room
        </a>
      </p>
    </Fragment>
  )}

  {props.kind === 'state' && (
    <Fragment slot="header-extras">
      <dl class="mt-4 grid grid-cols-1 gap-x-8 gap-y-2 text-sm sm:grid-cols-2">
        <div data-pagefind-weight="20">
          <dt class="inline font-semibold text-slate-700">Admitted:</dt>
          <dd class="inline text-slate-600"> {dateFmt.format(props.entry.data.admittedDate)}</dd>
        </div>
        <div>
          <dt class="inline font-semibold text-slate-700">Era:</dt>
          <dd class="inline text-slate-600"> {props.entry.data.eraName} (cohort {props.entry.data.eraCohort})</dd>
        </div>
        {props.entry.data.federalGrantAcres !== null && (
          <div>
            <dt class="inline font-semibold text-slate-700">Federal grant:</dt>
            <dd class="inline text-slate-600">
              {props.entry.data.federalGrantAcres === 0
                ? ' none (state-derived)'
                : ` ${num.format(props.entry.data.federalGrantAcres)} acres`}
            </dd>
          </div>
        )}
        <div>
          <dt class="inline font-semibold text-slate-700">Governance:</dt>
          <dd class="inline text-slate-600"> {props.entry.data.governanceForm}</dd>
        </div>
        {props.entry.data.permanentFundCorpus && (
          <div>
            <dt class="inline font-semibold text-slate-700">Permanent fund:</dt>
            <dd class="inline text-slate-600">
              {' '}{usd.format(props.entry.data.permanentFundCorpus.value)}
              {props.entry.data.permanentFundCorpus.asOf && (
                <span> (as of {dateFmt.format(props.entry.data.permanentFundCorpus.asOf)})</span>
              )}
            </dd>
          </div>
        )}
        {props.entry.data.latestDistribution && (
          <div>
            <dt class="inline font-semibold text-slate-700">
              {props.entry.data.latestDistribution.fiscalYear
                ? `FY${props.entry.data.latestDistribution.fiscalYear} distribution:`
                : 'Recent distribution:'}
            </dt>
            <dd class="inline text-slate-600"> {usd.format(props.entry.data.latestDistribution.value)}</dd>
          </div>
        )}
      </dl>
      <p class="mt-4 text-xs text-slate-500">
        Substrate v{props.entry.data.substrateVersion} · Last reviewed {dateFmt.format(props.entry.data.lastReviewed)}
      </p>
    </Fragment>
  )}

  {props.kind === 'state' && (
    <section class="mt-8">
      <StateDossierCard
        iso={props.entry.data.iso.toLowerCase()}
        name={props.entry.data.name}
        admittedDate={props.entry.data.admittedDate}
        eraName={props.entry.data.eraName}
        governanceForm={props.entry.data.governanceForm}
        federalGrantAcres={props.entry.data.federalGrantAcres}
        summary={props.entry.data.summary}
        currentIssue={props.entry.data.currentIssue}
      />
    </section>
  )}

  <article
    class:list={[
      'prose prose-slate mt-8 max-w-none prose-a:text-blue-700 prose-a:underline',
      props.kind === 'essay' && '[&>h1:first-child]:hidden',
    ]}
  >
    <Content />
  </article>

  {props.kind === 'state' && (
    <section class="mt-12 max-w-prose">
      <StateDossier
        iso={props.entry.data.iso.toLowerCase()}
        name={props.entry.data.name}
      />
    </section>
  )}
</RoomLayout>

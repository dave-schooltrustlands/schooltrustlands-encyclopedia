---
import { getCollection, type CollectionEntry } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const entries = await getCollection('essays');
  return entries.map((entry) => ({
    params: { slug: entry.slug.replace(/^\d+-/, '') },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'essays'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { data } = entry;

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const num = new Intl.NumberFormat('en-US');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{data.title} — School Trust Lands Encyclopedia</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <Header />
    <main class="mx-auto max-w-prose p-4 sm:p-8">
      <header class="border-b border-slate-200 pb-6">
        <p class="text-sm uppercase tracking-wide text-slate-500">
          Reading Room · {data.era}
        </p>
        <h1 data-pagefind-weight="10" class="mt-2 text-4xl font-bold tracking-tight">{data.title}</h1>
        <p class="mt-4 text-xs text-slate-500">
          {num.format(data.wordCount)} words · Substrate {data.sourceVersion} · Last synced {dateFmt.format(data.lastSynced)}
        </p>
        <p class="mt-3">
          <a href="/reading/" class="text-sm text-blue-700 underline hover:text-blue-900">
            ← Back to Reading Room
          </a>
        </p>
      </header>
      <article class="prose prose-slate mt-8 max-w-none prose-a:text-blue-700 prose-a:underline">
        <Content />
      </article>
    </main>
    <Footer />
  </body>
</html>

---
import RoomLayout from '../../layouts/RoomLayout.astro';
import ReferenceDesk from '../../components/ReferenceDesk.astro';
import BookBanner from '../../components/BookBanner.astro';
---

<RoomLayout
  room="reading"
  title="Reading Room"
  subtitle="Five rooms, each with its own purpose. Pick a door."
  width="prose"
  sourceId="reading-toc"
>
  <section class="reading-lobby mt-6">
    <p class="lobby-intro">
      The Reading Room is the public face of America's School Trust Library —
      five rooms, each with its own purpose. The Library's Argument lays out
      what the school-trust tradition is and what is at stake. The Founders'
      Library collects the foundational texts. The Scholarship surfaces the
      secondary literature that reads, organizes, and extends the tradition.
      State Records houses what each state has done with its trust. Voices is
      where the people who study, steward, and contest these lands speak in
      their own words. Pick a door.
    </p>

    <hr class="archival-divider" />

    <!-- ================================================================== -->
    <!-- Door cards — four substrate rooms (Voices lives in nav, not here)  -->
    <!-- ================================================================== -->
    <section class="lobby-doors" aria-label="Reading Room sections">
      <article class="door-card">
        <h2 class="door-title">I. The Library's Argument</h2>
        <p class="door-description">
          Two paired works that together carry the Library's argument:
          <em>Schools of the Republic</em>, the historical record across all
          fifty states, and <em>The Eighth Anchor</em>, the diagnostic frame
          that names three forces of drift and seven structural anchors —
          held in place by a standing constituency that watches the
          architecture across generations. Read either way: the record
          first if you want the proof, the frame first if you want the
          argument.
        </p>
        <a href="/reading/the-librarys-argument/" class="door-enter">
          Enter →
        </a>
      </article>

      <article class="door-card">
        <h2 class="door-title">II. The Founders' Library</h2>
        <p class="door-description">
          Fifteen primary-source documents the school-trust experiment was
          built on, organized into three era cohorts: the 1780s founding
          (Land Ordinance, Northwest Ordinance, Massachusetts Constitution,
          Federalist No. 10, Jefferson's Bill); the common-school era (Mann,
          Barnard, McGuffey, Pierce); and the high-water and reform period
          (Fitch &amp; Skinner, Swift, Hawkes, Utah Code Title 53C).
        </p>
        <a href="/reading/founders-library/" class="door-enter">Enter →</a>
      </article>

      <article class="door-card">
        <h2 class="door-title">III. The Scholarship</h2>
        <p class="door-description">
          The secondary literature on school trust lands, public-school
          governance, and intergenerational fiduciary law. Tier 1 open-access
          works the Library hosts in full; Tier 2 partially-available works
          the Library annotates and excerpts; and Tier 3 stub pages for
          in-copyright reference works (Bogert; Restatement (Third) of Trusts;
          Souder &amp; Fairfax; Culp; NEFA). Each Tier 3 stub carries a
          Title-Steward call.
        </p>
        <a href="/reading/scholarship/" class="door-enter">Enter →</a>
      </article>

      <article class="door-card">
        <h2 class="door-title">IV. State Records</h2>
        <p class="door-description">
          The per-state evidentiary material the <em>Schools of the
          Republic</em> case-by-case record draws on: filings, audits,
          governor's messages, treasurer's reports, attorney-general
          opinions. Currently weighted toward Oregon (the active-litigation
          state) and the comparative cohort — Utah, New Mexico, Texas,
          California, Arizona. Browse via the <a href="/atlas/">Atlas</a>.
        </p>
        <a href="/atlas/" class="door-enter">Enter →</a>
      </article>

      <article class="door-card">
        <h2 class="door-title">V. <em>Who Steals from Children</em> — A Series</h2>
        <p class="door-description">
          The Library's series-in-progress documenting how America's
          school-land trusts are being broken in the present tense.
          Volume 1, <em>Oregon and the Elliott</em>, is in
          pre-publication review as a Reader's Edition — a first-person
          account written for the parents and school-district
          administrators whose children are the trusts' named
          beneficiaries.
        </p>
        <a href="/reading/who-steals-from-children/" class="door-enter">Enter →</a>
      </article>

    </section>

    <hr class="archival-divider" />

    <!-- ================================================================== -->
    <!-- Featured books on display                                          -->
    <!-- ================================================================== -->
    <section class="lobby-featured" aria-label="Featured this week">
      <h2 class="featured-section-heading">On display this week</h2>

      <article class="featured-book">
        <BookBanner direction="forward" />
        <h3 class="featured-title">The Eighth Anchor</h3>
        <p class="featured-byline">Sullivan and Bird · v5.0 · Volume II · eight sections + three interludes</p>
        <p class="featured-blurb">
          The Library's diagnostic frame in eight sections. The Eighth Anchor
          reads the 1785 school-trust experiment as the longest-running
          multi-generational fiduciary record America has produced — and as
          the working manual for the AI-era trusts now being designed.
        </p>
        <a href="/reading/sacred-compact-prologue/" class="featured-link"
          >Read this →</a
        >
      </article>

      <article class="featured-book">
        <span class="featured-tag">New in pre-publication</span>
        <h3 class="featured-title"><em>Who Steals from Children: Volume 1 — Oregon and the Elliott</em></h3>
        <p class="featured-byline">Dave Sullivan · Volume 1 of the WSFC series · Reader's Edition · Foreword + Preface + 13 chapters + Documentary Record</p>
        <p class="featured-blurb">
          A first-person, scene-grounded account of how the State of
          Oregon has spent thirty-five years removing a billion-dollar
          working trust asset from the Common School Fund — written for
          the parents and school-district administrators whose children
          are the Common School Fund's named beneficiaries.
        </p>
        <a href="/reading/who-steals-from-children-vol1-elliott/" class="featured-link"
          >Read the draft →</a
        >
      </article>

      <article class="featured-book">
        <span class="featured-tag">Featured</span>
        <h3 class="featured-title">Horace Mann's <em>Twelfth Annual Report</em></h3>
        <p class="featured-byline">Massachusetts Board of Education · 1848</p>
        <p class="featured-blurb">
          The 1848 <em>Twelfth Annual Report</em> of the Massachusetts Board
          of Education. Source of <em>the balance-wheel of the social
          machinery</em> — the phrase that organizes much of the Library's
          argument. Mann reading public schools as republican infrastructure.
        </p>
        <a
          href="/reading/founders-library/mann-twelfth-annual-report-1848/"
          class="featured-link"
          >Read this →</a
        >
      </article>
    </section>

    <hr class="archival-divider" />

    <p class="lobby-footer">
      The Library accepts contributions of source material, corrections, and
      citizen-historian work.
      <a href="/contribute/">Suggest a contribution →</a>
    </p>

    <ReferenceDesk />
  </section>

  <style>
    .reading-lobby {
      margin-top: 1.5rem;
    }
    .lobby-intro {
      font-family: var(--font-serif, Georgia, serif);
      font-size: 1.1rem;
      line-height: 1.65;
      color: #334155;
      margin: 1rem 0 1.75rem;
    }
    .lobby-doors {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin: 1.5rem 0 2rem;
    }
    .door-card {
      background: var(--linen-card, #fafaf7);
      border: 1px solid var(--rule-border, #e5e7eb);
      border-radius: 4px;
      padding: 1.5rem 1.5rem 1.25rem;
      display: flex;
      flex-direction: column;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }
    .door-card:hover {
      border-color: var(--old-gold, #8b7355);
      box-shadow: 0 1px 4px rgba(15, 23, 42, 0.06);
    }
    .door-title {
      font-family: var(--font-serif, Georgia, serif);
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--deep-navy, #1e3a5f);
      margin: 0 0 0.5rem;
      letter-spacing: 0.005em;
    }
    .door-description {
      font-size: 0.95rem;
      line-height: 1.55;
      color: #475569;
      margin: 0 0 1rem;
      flex: 1;
    }
    .door-enter {
      align-self: flex-start;
      color: #1d4ed8;
      font-family: var(--font-sans);
      font-size: 0.9rem;
      font-weight: 600;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .door-enter:hover {
      color: #1e40af;
    }

    .lobby-featured {
      margin: 2rem 0;
    }
    .featured-section-heading {
      font-family: var(--font-sans);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #64748b;
      margin: 0 0 1rem;
    }
    .featured-book {
      background: #fff;
      border: 1px solid var(--rule-border, #e5e7eb);
      border-left: 3px solid var(--old-gold, #8b7355);
      padding: 1.25rem 1.5rem;
      margin-bottom: 1.25rem;
      border-radius: 2px;
    }
    .featured-tag {
      display: inline-block;
      font-family: var(--font-sans);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--old-gold, #8b7355);
      margin-bottom: 0.4rem;
    }
    .featured-title {
      font-family: var(--font-serif, Georgia, serif);
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--deep-navy, #1e3a5f);
      margin: 0 0 0.25rem;
    }
    .featured-byline {
      font-family: var(--font-sans);
      font-size: 0.82rem;
      color: #64748b;
      margin: 0 0 0.6rem;
    }
    .featured-blurb {
      font-size: 0.95rem;
      line-height: 1.55;
      color: #475569;
      margin: 0 0 0.85rem;
    }
    .featured-link {
      color: #1d4ed8;
      font-family: var(--font-sans);
      font-size: 0.88rem;
      font-weight: 600;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .featured-link:hover {
      color: #1e40af;
    }

    .lobby-footer {
      font-family: var(--font-sans);
      font-size: 0.95rem;
      color: #475569;
      margin: 1.5rem 0 0.5rem;
      line-height: 1.55;
    }
    .lobby-footer a {
      color: #1d4ed8;
      text-decoration: underline;
      text-underline-offset: 2px;
      font-weight: 600;
    }

    @media (max-width: 700px) {
      .lobby-doors {
        grid-template-columns: 1fr;
      }
    }
  </style>
</RoomLayout>

---
// v59 — Reading Room landing rebuild. The room reframes from a multi-door
// lobby into a curated reference room with two collections: the Atlas of
// 50 state dossiers (each at /reading/us-XX/), and a curated catalog of
// 39 works by other authors at /reading/library/<slug>/. Four featured
// entries sit above the six category sections. The Library's own books
// remain at their existing /reading/* URLs pending a future migration to
// the Writing Room.
import { getCollection } from 'astro:content';
import RoomLayout from '../../layouts/RoomLayout.astro';
import ReferenceDesk from '../../components/ReferenceDesk.astro';

const libraryEntries = await getCollection('library');
const stateEntries = await getCollection('states');

type Cat = 'A' | 'B' | 'C' | 'D' | 'E' | 'F';

const categoryOrder: Cat[] = ['A', 'B', 'C', 'D', 'E', 'F'];

const categoryNames: Record<Cat, string> = {
  A: 'Foundational primary sources',
  B: 'Historical scholarship, pre-1950',
  C: 'Doctrinal court opinions',
  D: 'Contemporary scholarship & reference works',
  E: 'State-commissioned studies & reports',
  F: 'Educational & cultural context',
};

const categoryBlurbs: Record<Cat, string> = {
  A: 'The federal acts of Congress, the territorial ordinances, the early state constitutions, and the admission acts on which the entire school-trust system rests. All public-domain by virtue of being federal or state government works.',
  B: 'The early- and mid-twentieth-century scholars who first reconstructed, state by state, what had happened to the school-trust corpora in their founding centuries. Close enough to the records to capture details modern researchers cannot easily recover.',
  C: 'The cases American courts have decided on the questions the Library’s substrate turns on: whether admission-act grants are real trusts, what the trustee state owes the beneficiary, what the fiduciary standard is, what the remedies are when it is breached.',
  D: 'The standing academic and practitioner literature on school trust lands, trust doctrine generally, and school finance. Most are in copyright; the Library carries Tier 3 editorial summaries with Title-Steward recruitment open. Culp et al. is open-access.',
  E: 'State-level reports and studies that document school-trust-lands administration from inside the system. Reform statutes, agency annual reports, and the advocacy-office reporting that holds trustee states accountable to beneficiaries.',
  F: 'Works that are not directly about school trust lands but document what the trust was intended to fund — the public-school education the framers had in mind, and the cultural fabric the Section 16 grants were meant to support.',
};

const treatmentLabel: Record<string, string> = {
  'link-only': 'Link',
  'link-plus-excerpt': 'Excerpt',
  'link-plus-full-text': 'Full text',
  'link-plus-full-text-hosted': 'Full text',
};

type Entry = (typeof libraryEntries)[number];

const slugOf = (e: Entry) => (e.slug ?? e.id).replace(/\.md$/, '');

const sortByCategoryThenYear = (a: Entry, b: Entry) => {
  const yA = Number(a.data.year) || 0;
  const yB = Number(b.data.year) || 0;
  return yA - yB;
};

const featuredSlugs = [
  'land-ordinance-1785',
  'swift-public-permanent-school-funds-1911',
  'meinhard-v-salmon-1928',
  'margaret-bird-selected-essays',
];
const featured = featuredSlugs
  .map((s) => libraryEntries.find((e) => slugOf(e) === s))
  .filter((e): e is Entry => Boolean(e));

const byCategory: Record<Cat, Entry[]> = { A: [], B: [], C: [], D: [], E: [], F: [] };
for (const e of libraryEntries) byCategory[e.data.category as Cat].push(e);
for (const c of categoryOrder) byCategory[c].sort(sortByCategoryThenYear);

const states = stateEntries
  .slice()
  .sort((a, b) => a.data.name.localeCompare(b.data.name));

// v73 — Margaret Bird's 2026-05-15 ask: "I cannot figure out how to go
// directly to just one state from the reading room." Pill row of the
// 50 state postal codes lives just under the lobby intro so a visitor
// can jump straight to a dossier without scrolling to the bottom roster.
// All 50 dossiers carry substantive content today; if a stub class is
// needed later, mark the entry in frontmatter and branch on it here.
const statePills = stateEntries
  .map((s) => ({
    abbr: s.data.iso.replace(/^US-/, ''),
    href: `/reading/${s.data.iso.toLowerCase()}/`,
    name: s.data.name,
  }))
  .sort((a, b) => a.abbr.localeCompare(b.abbr));
---

<RoomLayout
  room="reading"
  title="Reading Room"
  subtitle="The Library’s reference shelf. Two collections, side by side."
  width="prose"
  sourceId="reading-toc-v59"
>
  <section class="reading-lobby mt-6">
    <div class="lobby-intro">
      <p>
        The Reading Room is the Library’s reference shelf. Two
        collections live here, side by side. The first is the Atlas
        — one page for each of the fifty states, documenting what
        that state was granted at admission, what its constitution and
        statutes say about the trust, what its courts have held, what
        its records show about the corpus and the distributions, and
        what the Library knows about the state’s current condition.
      </p>

      <p>
        The second is the curated collection — foundational
        primary sources, historical scholarship, doctrinal court
        opinions, state-commissioned reports, and contemporary policy
        and reference work by authors other than the Library. These
        works were written by other people. The Library carries them
        because anyone who wants to understand the school-trust system
        has to read them eventually, and we would rather keep them
        findable than let them drift into the corners of the internet
        where good scholarship goes to disappear.
      </p>

      <p>
        Below: four featured entries the Library most needs visitors to
        encounter first; the published shelf of finished works; the
        full thirty-nine-entry browse organized into six categories;
        and the alphabetical roster of fifty state dossiers. The
        Library’s own books in progress live in the
        <a href="/writing/">Writing Room</a>.
      </p>
    </div>

    {/* ============================================================== */}
    {/* State-jump pill row (v73 — per Margaret 2026-05-15 request)    */}
    {/* ============================================================== */}
    <nav class="state-jump" aria-label="Jump to a state's reading">
      <p class="state-jump__label">Reading by state:</p>
      <ul class="state-jump__list">
        {statePills.map((s, i) => (
          <li>
            <a href={s.href} title={s.name}>{s.abbr}</a>{i < statePills.length - 1 && <span class="state-jump__sep" aria-hidden="true"> · </span>}
          </li>
        ))}
      </ul>
    </nav>

    <hr class="archival-divider" />

    {/* ============================================================== */}
    {/* Featured entries — 2x2 grid                                    */}
    {/* ============================================================== */}
    <section class="lobby-featured" aria-label="Featured entries">
      <h2 class="section-heading">Featured</h2>
      <ul class="featured-grid">
        {featured.map((e) => {
          const slug = slugOf(e);
          return (
            <li>
              <a href={`/reading/library/${slug}/`} class="library-featured-card">
                <span class="featured-eyebrow">Featured</span>
                <h3 class="featured-title">{e.data.title}</h3>
                <p class="featured-byline">{e.data.author}, {e.data.year}</p>
                {e.data.featuredRationale && (
                  <p class="featured-rationale">{e.data.featuredRationale}</p>
                )}
                <span class="entry-treatment">
                  Read this → <span class="treatment-tag">{treatmentLabel[e.data.treatment]}</span>
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    </section>

    <hr class="archival-divider" />

    {/* ============================================================== */}
    {/* The published shelf — finished works (moved from Writing Room) */}
    {/* ============================================================== */}
    <section class="published-shelf" id="published-shelf" aria-label="The published shelf">
      <h2 class="section-heading">The published shelf</h2>
      <p class="section-subhead">
        Finished, published works that sit beside the Library’s
        collections — the companion textbook behind the Oregon case,
        the foundational fire-history scholarship, and the definitive
        Elliott State Forest history. Works still being written live
        in the <a href="/writing/">Writing Room</a>.
      </p>

      <article class="shelf-card">
        <p class="shelf-kicker">Published 2025 · Companion textbook</p>
        <h3 class="shelf-title"><em>Oregon's Constitutional Duties to Schools</em></h3>
        <p class="shelf-byline">Margaret Bird and Dave Sullivan · 2025 · 150 pages</p>
        <p class="shelf-blurb">
          A 150-page volume documenting the billion-dollar inheritance
          for Oregon schoolchildren and the case for constitutional
          accountability. The legal architecture and factual record
          cited in <em>Advocates for School Trust Lands v. State of
          Oregon</em>.
        </p>
        <p class="shelf-links">
          <a href="https://drive.google.com/file/d/1E1IhBgk8fdtKnQd2FqkFqE9V1xduYd0u/view?usp=sharing" rel="noopener" target="_blank">Free PDF (Google Drive) →</a>
          <a href="https://a.co/d/8PpB6f8" rel="noopener" target="_blank">Amazon (Kindle / paperback / hardback) →</a>
        </p>
        <p class="shelf-note">
          Also distributed by OASTL Oregon at
          <a href="https://oastl-oregon.drdavesullivan.workers.dev" rel="noopener" target="_blank">oastl-oregon.drdavesullivan.workers.dev</a>.
        </p>
      </article>

      <article class="shelf-card">
        <p class="shelf-kicker">Published · Companion forestry work</p>
        <h3 class="shelf-title"><em>Great Fires: Catastrophic Burning Patterns 1491-1951</em></h3>
        <p class="shelf-byline">Bob Zybach et al.</p>
        <p class="shelf-blurb">
          Describes how Indian burning practices shaped coastal forests
          for thousands of years; foundational reference for
          understanding the fire-history context of the Elliott State
          Forest and the broader Pacific Northwest.
        </p>
        <p class="shelf-links">
          <a href="https://www.amazon.com/Great-Fires-Catastrophic-Patterns-1491-1951/dp/1732127603" rel="noopener" target="_blank">Amazon →</a>
        </p>
      </article>

      <article class="shelf-card">
        <p class="shelf-kicker">Published 1999 · Definitive Elliott history</p>
        <h3 class="shelf-title"><em>Caulked Boots and Cheese Sandwiches</em></h3>
        <p class="shelf-byline">Jerry Phillips · Oregon Department of Forestry, 1999</p>
        <p class="shelf-blurb">
          The definitive history of the Elliott State Forest, written
          by its long-term manager (1956-1989). Hosted as a free PDF on
          the ORWW Field Station archive.
        </p>
        <p class="shelf-links">
          <a href="http://www.orww.org/Elliott_Forest/History/Phillips/Phillips_1998-201.pdf" rel="noopener" target="_blank">Free PDF (ORWW) →</a>
        </p>
        <p class="shelf-note">Hosted by ORWW Field Station.</p>
      </article>
    </section>

    <hr class="archival-divider" />

    {/* ============================================================== */}
    {/* Browse by category                                             */}
    {/* ============================================================== */}
    <section class="lobby-browse" aria-label="Browse the curated collection by category">
      <h2 class="section-heading">Browse by category</h2>
      <p class="section-subhead">
        Thirty-nine entries the Library carries because they belong on
        the reference shelf of anyone serious about school trust lands.
      </p>

      {categoryOrder.map((cat) => (
        <section class="category-section" id={`category-${cat.toLowerCase()}`}>
          <h3 class="category-title">
            <span class="category-badge">{cat}</span>
            {categoryNames[cat]}
          </h3>
          <p class="category-blurb">{categoryBlurbs[cat]}</p>
          <ul class="entry-list">
            {byCategory[cat].map((e) => {
              const slug = slugOf(e);
              return (
                <li>
                  <a href={`/reading/library/${slug}/`} class="library-entry-card">
                    <h4 class="entry-title">
                      {e.data.title}
                      <span class="entry-meta"> ({e.data.author}, {e.data.year})</span>
                    </h4>
                    <p class="entry-rationale">{e.data.rationale}</p>
                    <span class="entry-treatment">
                      → <span class="treatment-tag">{treatmentLabel[e.data.treatment]}</span>
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      ))}
    </section>

    <hr class="archival-divider" />

    {/* ============================================================== */}
    {/* State dossier roster                                           */}
    {/* ============================================================== */}
    <section class="lobby-atlas" aria-label="State dossiers">
      <h2 class="section-heading">State dossiers</h2>
      <p class="section-subhead">
        One page for each of the fifty states. The Atlas of state
        dossiers documents the federal grant, the constitutional and
        statutory architecture, the doctrinal record, the present
        condition of the corpus and the distributions, and the gaps
        the Library has flagged for follow-up research. Oregon and
        Utah are the deepest pages today; the rest build out as the
        Library’s curation continues.
      </p>
      <ul class="state-roster">
        {states.map((s) => (
          <li>
            <a href={`/reading/${s.data.iso.toLowerCase()}/`}>{s.data.name}</a>
          </li>
        ))}
      </ul>
    </section>

    <hr class="archival-divider" />

    <p class="lobby-footer">
      The Library accepts contributions of source material, corrections,
      and citizen-historian work.
      <a href="/contribute/">Suggest a contribution →</a>
    </p>

    <ReferenceDesk />
  </section>

  <style>
    .reading-lobby { margin-top: 1.5rem; }

    .lobby-intro p {
      font-family: var(--font-serif, Georgia, serif);
      font-size: 1.05rem;
      line-height: 1.65;
      color: #334155;
      margin: 0 0 1rem;
    }
    .lobby-intro p:last-child { margin-bottom: 0; }

    .section-heading {
      font-family: var(--font-sans);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #64748b;
      margin: 0 0 0.75rem;
    }
    .section-subhead {
      font-size: 0.95rem;
      line-height: 1.55;
      color: #475569;
      margin: 0 0 1.25rem;
    }

    /* Published shelf — finished works moved from the Writing Room */
    .shelf-card {
      background: var(--linen-card, #fafaf7);
      border: 1px solid var(--rule-border, #e5e7eb);
      border-left: 3px solid var(--old-gold, #8b7355);
      border-radius: 4px;
      padding: 1.25rem 1.25rem 1rem;
      margin: 0 0 1rem;
    }
    .shelf-kicker {
      font-family: var(--font-sans);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--old-gold, #8b7355);
      margin: 0 0 0.45rem;
    }
    .shelf-title {
      font-family: var(--font-serif, Georgia, serif);
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--deep-navy, #1e3a5f);
      margin: 0 0 0.35rem;
    }
    .shelf-byline {
      font-family: var(--font-sans);
      font-size: 0.85rem;
      color: #475569;
      margin: 0 0 0.35rem;
    }
    .shelf-blurb {
      font-size: 0.95rem;
      line-height: 1.55;
      color: #334155;
      margin: 0 0 0.75rem;
    }
    .shelf-links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.25rem 1.5rem;
      margin: 0 0 0.5rem;
      font-family: var(--font-sans);
      font-size: 0.9rem;
      font-weight: 600;
    }
    .shelf-links a {
      color: #1d4ed8;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .shelf-links a:hover { color: #1e40af; }
    .shelf-note {
      font-family: var(--font-sans);
      font-size: 0.8rem;
      color: #64748b;
      font-style: italic;
      margin: 0;
    }
    .shelf-note a {
      color: #475569;
      text-decoration: underline;
    }

    /* v73 — state-jump pill row */
    .state-jump {
      margin: 1.25rem 0 0;
      padding: 0.7rem 0.9rem;
      background: var(--linen-card, #fafaf7);
      border: 1px solid var(--rule-border, #e5e7eb);
      border-radius: 3px;
    }
    .state-jump__label {
      font-family: var(--font-sans);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #64748b;
      margin: 0 0 0.45rem;
    }
    .state-jump__list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      column-gap: 0;
      row-gap: 0.25rem;
      font-family: var(--font-sans);
      font-size: 0.92rem;
      line-height: 1.5;
    }
    .state-jump__list li {
      display: inline-flex;
      align-items: baseline;
    }
    .state-jump__list a {
      color: #1d4ed8;
      text-decoration: underline;
      text-underline-offset: 2px;
      padding: 0 0.1rem;
      font-variant-numeric: tabular-nums;
    }
    .state-jump__list a:hover { color: #1e40af; }
    .state-jump__sep {
      color: #94a3b8;
      padding: 0 0.35rem;
    }

    /* Featured 2x2 grid */
    .featured-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
    .library-featured-card {
      display: block;
      background: #fff;
      border: 1px solid var(--rule-border, #e5e7eb);
      border-left: 3px solid var(--old-gold, #8b7355);
      border-radius: 3px;
      padding: 1.25rem 1.4rem 1.1rem;
      color: inherit;
      text-decoration: none;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
      height: 100%;
    }
    .library-featured-card:hover {
      border-color: var(--old-gold, #8b7355);
      box-shadow: 0 1px 6px rgba(15, 23, 42, 0.08);
    }
    .featured-eyebrow {
      display: inline-block;
      font-family: var(--font-sans);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--old-gold, #8b7355);
      margin-bottom: 0.45rem;
    }
    .featured-title {
      font-family: var(--font-serif, Georgia, serif);
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--deep-navy, #1e3a5f);
      margin: 0 0 0.3rem;
      line-height: 1.3;
    }
    .featured-byline {
      font-family: var(--font-sans);
      font-size: 0.82rem;
      color: #64748b;
      margin: 0 0 0.7rem;
    }
    .featured-rationale {
      font-size: 0.93rem;
      line-height: 1.55;
      color: #475569;
      margin: 0 0 0.85rem;
    }
    .entry-treatment {
      display: inline-block;
      color: #1d4ed8;
      font-family: var(--font-sans);
      font-size: 0.85rem;
      font-weight: 600;
    }
    .treatment-tag {
      display: inline-block;
      margin-left: 0.35rem;
      padding: 0 0.4rem;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: #64748b;
      background: #f1f5f9;
      border-radius: 2px;
    }

    /* Browse by category */
    .lobby-browse { margin-top: 0.5rem; }
    .category-section {
      margin: 1.75rem 0 1.5rem;
    }
    .category-title {
      font-family: var(--font-serif, Georgia, serif);
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--deep-navy, #1e3a5f);
      margin: 0 0 0.4rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .category-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.6rem;
      height: 1.6rem;
      border: 1px solid var(--old-gold, #8b7355);
      border-radius: 50%;
      font-family: var(--font-sans);
      font-size: 0.78rem;
      font-weight: 700;
      color: var(--old-gold, #8b7355);
      background: #fafaf7;
    }
    .category-blurb {
      font-size: 0.92rem;
      line-height: 1.55;
      color: #475569;
      margin: 0 0 0.9rem;
    }
    .entry-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.85rem;
    }
    .library-entry-card {
      display: block;
      background: var(--linen-card, #fafaf7);
      border: 1px solid var(--rule-border, #e5e7eb);
      border-radius: 3px;
      padding: 0.85rem 1rem 0.9rem;
      color: inherit;
      text-decoration: none;
      transition: border-color 0.15s ease, background 0.15s ease;
      height: 100%;
    }
    .library-entry-card:hover {
      border-color: var(--old-gold, #8b7355);
      background: #fff;
    }
    .entry-title {
      font-family: var(--font-serif, Georgia, serif);
      font-size: 0.98rem;
      font-weight: 600;
      color: var(--deep-navy, #1e3a5f);
      margin: 0 0 0.3rem;
      line-height: 1.3;
    }
    .entry-meta {
      font-weight: 400;
      color: #64748b;
      font-size: 0.88rem;
    }
    .entry-rationale {
      font-size: 0.88rem;
      line-height: 1.5;
      color: #475569;
      margin: 0 0 0.55rem;
    }

    /* State roster */
    .state-roster {
      list-style: none;
      padding: 0;
      margin: 0.5rem 0 0;
      columns: 3;
      column-gap: 1.25rem;
      font-family: var(--font-sans);
      font-size: 0.92rem;
    }
    .state-roster li {
      break-inside: avoid;
      padding: 0.15rem 0;
    }
    .state-roster a {
      color: #1d4ed8;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .state-roster a:hover { color: #1e40af; }

    .lobby-footer {
      font-family: var(--font-sans);
      font-size: 0.95rem;
      color: #475569;
      margin: 1.5rem 0 0.5rem;
      line-height: 1.55;
    }
    .lobby-footer a {
      color: #1d4ed8;
      text-decoration: underline;
      text-underline-offset: 2px;
      font-weight: 600;
    }

    @media (max-width: 720px) {
      .featured-grid { grid-template-columns: 1fr; }
      .entry-list { grid-template-columns: 1fr; }
      .state-roster { columns: 2; }
    }
    @media (max-width: 460px) {
      .state-roster { columns: 1; }
    }
  </style>
</RoomLayout>

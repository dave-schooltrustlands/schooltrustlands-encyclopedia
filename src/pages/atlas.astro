---
import RoomLayout from '../layouts/RoomLayout.astro';

import eraCohort from '../data/map-layers/era-cohort.json';
import eraCohortDates from '../data/map-layers/era-cohort-dates.json';
import corpus from '../data/map-layers/corpus.json';
import grantAcres from '../data/map-layers/grant-acres.json';
import transparency from '../data/map-layers/transparency.json';

const isDev = import.meta.env.DEV;

type LensRecord = {
  stateIso: string;
  fips: string;
  name: string;
  value: number | string | null;
  category: string;
  displayLabel: string;
  admittedYear?: number;
  dataConfidence: string;
};

type Lens = {
  id: string;
  label: string;
  description: string;
  records: LensRecord[];
  // category → fill color. Order = legend order.
  categoryColors: { category: string; color: string; legend: string }[];
};

// v52 BETA — era cohort uses a six-step sequential palette walking from
// deep oxidized navy (Ch. 1, the founding) to warm ochre (Ch. 6, the
// twentieth-century high-water mark), so the eye reads temporal sequence
// from hue+brightness on the static map. Other lenses keep their
// colorblind-safe categorical or sequential palettes.
const ERA_COHORT_PALETTE: Record<string, string> = {
  'cohort-1': '#1f3851',
  'cohort-2': '#3a4f6c',
  'cohort-3': '#5a6677',
  'cohort-4': '#8a7560',
  'cohort-5': '#b58a45',
  'cohort-6': '#d4a64a',
};

// v52 ALPHA — base legend labels per cohort. Date ranges interpolated
// at build time from era-cohort-dates.json so labels stay correct if a
// state's eraCohort or admittedDate ever changes in substrate.
const ERA_COHORT_BASE_LABELS: Record<string, string> = {
  'cohort-1': 'Ch. 1 — Founding Floor',
  'cohort-2': 'Ch. 2 — Statehood without federal floor',
  'cohort-3': 'Ch. 3 — Northwest Ordinance template',
  'cohort-4': 'Ch. 4 — Antebellum doubling',
  'cohort-5': 'Ch. 5 — Reconstruction & western stack',
  'cohort-6': 'Ch. 6 — Twentieth-century high-water mark',
};

type CohortDates = { firstYear: number; lastYear: number };
const cohortDates = eraCohortDates as Record<string, CohortDates>;

// v52 BETA — timeline-strip geometry. Hoisted into the frontmatter so the
// type annotations don't collide with Astro's JSX-aware template parser
// (Array<...> generics inside a template-side IIFE get misread as markup).
const TIMELINE_X_LEFT = 20;
const TIMELINE_X_RIGHT = 980;
const TIMELINE_START_YEAR = 1785;
const TIMELINE_END_YEAR = 1959;
function yearToTimelineX(y: number): number {
  return (
    TIMELINE_X_LEFT +
    ((y - TIMELINE_START_YEAR) / (TIMELINE_END_YEAR - TIMELINE_START_YEAR)) *
      (TIMELINE_X_RIGHT - TIMELINE_X_LEFT)
  );
}
const FEDERAL_COHORT_SEGMENTS: { key: string; label: string }[] = [
  { key: 'cohort-1', label: 'Ch. 1' },
  { key: 'cohort-3', label: 'Ch. 3' },
  { key: 'cohort-4', label: 'Ch. 4' },
  { key: 'cohort-5', label: 'Ch. 5' },
  { key: 'cohort-6', label: 'Ch. 6' },
];
const TIMELINE_TICKS: { year: number; note: string }[] = [
  { year: 1785, note: 'Land Ordinance' },
  { year: 1787, note: 'NW Ordinance' },
  { year: 1850, note: '2 sections' },
  { year: 1894, note: '4 sections' },
  { year: 1959, note: 'AK + HI' },
];
const cohort2Dates = cohortDates['cohort-2'];

const eraCohortCategoryColors = ['cohort-1', 'cohort-2', 'cohort-3', 'cohort-4', 'cohort-5', 'cohort-6'].map(
  (key) => {
    const range = cohortDates[key];
    const suffix = range ? ` (${range.firstYear}–${range.lastYear})` : '';
    return {
      category: key,
      color: ERA_COHORT_PALETTE[key],
      legend: `${ERA_COHORT_BASE_LABELS[key]}${suffix}`,
    };
  },
);

const LENSES: Lens[] = [
  {
    id: 'era-cohort',
    label: 'Era cohort',
    description:
      'The architectural moment a state was admitted, and whether it received a federal school-land grant.',
    records: eraCohort as LensRecord[],
    categoryColors: eraCohortCategoryColors,
  },
  {
    id: 'corpus',
    label: 'Permanent fund corpus',
    description:
      'Current size of the state-school permanent fund, where one exists. State-derived states with no federal trust are shown as such.',
    records: corpus as LensRecord[],
    categoryColors: [
      { category: '≥ $5B', color: '#08519c', legend: '≥ $5 billion' },
      { category: '$1–5B', color: '#3182bd', legend: '$1–5 billion' },
      { category: '< $1B', color: '#9ecae1', legend: 'Under $1 billion' },
      { category: 'no permanent fund', color: '#cbd5e1', legend: 'No permanent fund (state-derived)' },
      { category: 'data unavailable', color: '#f1f5f9', legend: 'Data not in substrate' },
    ],
  },
  {
    id: 'grant-acres',
    label: 'Federal grant acreage',
    description:
      'Acres of public land granted at admission for the support of common schools. State-derived states received none — see Chapters 1, 2.',
    records: grantAcres as LensRecord[],
    categoryColors: [
      { category: '≥ 5M acres', color: '#005a32', legend: '≥ 5 million acres' },
      { category: '1–5M acres', color: '#41ab5d', legend: '1–5 million acres' },
      { category: '< 1M acres', color: '#a1d99b', legend: 'Under 1 million acres' },
      { category: 'no federal grant', color: '#cbd5e1', legend: 'No federal grant (state-derived)' },
      { category: 'data unavailable', color: '#f1f5f9', legend: 'Data unavailable' },
    ],
  },
  {
    id: 'transparency',
    label: 'Trust transparency',
    description:
      'Whether the state publishes its school-trust corpus and most recent distribution.',
    records: transparency as LensRecord[],
    categoryColors: [
      { category: 'data-published', color: '#1b9e77', legend: 'Corpus and distribution disclosed' },
      { category: 'data-partially-published', color: '#fdae6b', legend: 'Partially disclosed' },
      { category: 'unknown', color: '#f1f5f9', legend: 'Disclosure unknown' },
      { category: 'never-had-trust', color: '#cbd5e1', legend: 'No federal trust to disclose' },
    ],
  },
];

// Per-FIPS index for hover lookup of the state name + admission date.
const fipsToInfo: Record<string, { iso: string; name: string }> = {};
for (const r of eraCohort as LensRecord[]) {
  fipsToInfo[r.fips] = { iso: r.stateIso, name: r.name };
}

// Three-line "what this lens measures" panel content. Persistent on the
// page; updates with the lens switcher. Copy is install-verbatim from
// the Reader-Onboarding synthesis.
type LensExplainer = {
  asks: string;
  structure: string;
  notice: string;
};
const LENS_EXPLAINERS: Record<string, LensExplainer> = {
  'era-cohort': {
    asks:
      'When did each state join the union, and which generation of school-trust architecture did it inherit?',
    structure:
      'A sequential palette walks from the founding (deep oxidized navy, Ch. 1) through the nineteenth-century federal eras to the twentieth-century high-water mark (warm ochre, Ch. 6). The state-derived states (Ch. 2 — Original 13 holdouts plus a few others that opted out or were never on the federal trust) take a sequence position rather than a separate color, since they overlap the federal eras in time. The timeline strip below the legend renders the same chapters as a horizontal arrow of time, with tick marks at the federal-policy moments.',
    notice:
      'The federal one-section-per-township floor became two sections in 1850 and four sections in 1894. Generation-of-statehood substantially predicts how much the federal trust handed each state — the gradient encodes that progression.',
  },
  corpus: {
    asks: 'What is the school-trust corpus worth today, in each state that has one?',
    structure:
      'Sequential gradient by dollar amount. Explicit categories: ≥ $5 billion / $1–5 billion / < $1 billion / no permanent fund (state-derived states + a few western states that never built one) / data unavailable.',
    notice:
      'The largest school-trust corpora are not the largest states or the wealthiest states. Architecture, custody, and constituency held more reliably than population or income.',
  },
  'grant-acres': {
    asks:
      'How much land did each state receive from the federal government for school-trust purposes?',
    structure:
      'Sequential gradient by acres. The state-derived states (Original 13 + a few others) received zero — not a data gap; an authoritative no.',
    notice:
      'The states that received the most acreage are not the states with the largest corpora. Land was granted at admission; what survived is a separate question — answered by the Counting House.',
  },
  transparency: {
    asks: 'Does each state publicly disclose its school-trust accounting?',
    structure:
      'Five categories: data published (12 states) / data partially published / data withheld / never had a trust (state-derived) / unknown.',
    notice:
      'Transparency is the threshold question. A state that does not disclose cannot be audited; a trust that cannot be audited is structurally the same as a fund that does not exist. Twelve states are visible. Thirty-eight are not. The pattern is the finding.',
  },
};
const initialExplainer = LENS_EXPLAINERS[LENSES[0].id];
---

<RoomLayout
  room="atlas"
  title="Four lenses on the school-trust map"
  subtitle="Switch the lens to recolor the same fifty states by a different question. Click a state to open its state dossier."
  width="full"
  sourceId="atlas-map-layers"
>
  <Fragment slot="header-extras">
    <div class="mt-6">
      <fieldset
        id="lens-switcher"
        class="flex flex-wrap gap-2"
        aria-label="Map lens"
      >
        <legend class="sr-only">Map lens</legend>
        {LENSES.map((lens, i) => (
          <label
            class="cursor-pointer rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 has-[:checked]:border-slate-900 has-[:checked]:bg-slate-900 has-[:checked]:text-white"
          >
            <input
              type="radio"
              name="lens"
              value={lens.id}
              class="sr-only"
              checked={i === 0}
            />
            {lens.label}
          </label>
        ))}
      </fieldset>
      <p id="lens-description" class="mt-3 text-sm text-slate-600">
        {LENSES[0].description}
      </p>
      <div class="mt-2 flex items-center gap-3">
        <button
          type="button"
          id="atlas-show-all"
          class="atlas-show-all-link"
          hidden
        >
          Show all states
        </button>
        <span class="atlas-filter-hint text-xs text-slate-500">
          Click a legend chip to filter — Esc clears.
        </span>
      </div>
      <div
        id="atlas-filter-announce"
        class="sr-only"
        aria-live="polite"
        aria-atomic="true"
      ></div>
    </div>
  </Fragment>

  <section
    id="lens-explainer"
    class="mt-6 rounded-lg border border-slate-200 bg-white p-4 text-sm shadow-sm sm:p-5"
    aria-label="What this lens measures"
    aria-live="polite"
  >
    <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
      What this lens measures
    </p>
    <dl class="mt-3 space-y-3 text-slate-700">
      <div>
        <dt class="font-semibold text-slate-800">This lens asks</dt>
        <dd id="lens-asks" class="mt-1">{initialExplainer.asks}</dd>
      </div>
      <div>
        <dt class="font-semibold text-slate-800">Category structure</dt>
        <dd id="lens-structure" class="mt-1">{initialExplainer.structure}</dd>
      </div>
      <div>
        <dt class="font-semibold text-slate-800">What to notice</dt>
        <dd id="lens-notice" class="mt-1">{initialExplainer.notice}</dd>
      </div>
    </dl>
  </section>

  <div
    id="map"
    class="mt-6 h-[60vh] min-h-[420px] w-full overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm"
  >
  </div>
  {isDev && (
    <pre
      id="map-error"
      class="mt-2 hidden whitespace-pre-wrap rounded border border-red-200 bg-red-50 p-3 text-xs text-red-800"
    ></pre>
  )}

  <script
    type="application/json"
    id="atlas-data"
    set:html={JSON.stringify({ lenses: LENSES, fipsToInfo, lensExplainers: LENS_EXPLAINERS })}
  />

  <ol id="legend" class="mt-4 grid grid-cols-1 gap-2 text-sm sm:grid-cols-2"></ol>

  {/* v52 BETA — Era-cohort timeline strip. Visible only when the era-cohort
      lens is active (the lens-switcher script toggles `hidden`). The strip
      renders the same five sequential federal-trust chapters as the legend,
      colored to match, plus tick marks at the federal-policy moments. The
      state-derived cohort (Ch. 2 — 1791–1863) appears as a secondary band
      below the main bar because it overlaps the federal eras in time and
      isn't a temporal step on the federal-trust evolution. Year→x is
      computed from the substrate-derived eraCohortDates so the strip stays
      correct if a state file ever changes its admittedDate or eraCohort. */}
  <section
    id="era-timeline"
    class="era-timeline mt-6 rounded-lg border border-slate-200 bg-white p-4 shadow-sm"
    aria-label="Era-cohort timeline"
    data-lens="era-cohort"
    data-autoplay-active=""
  >
    <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
      Federal-trust evolution, 1785–1959
    </p>
    <svg
      class="era-timeline-svg mt-3 block w-full"
      viewBox="0 0 1000 110"
      role="img"
      aria-label="Horizontal timeline from 1785 to 1959 showing the six era cohorts as colored segments, with tick marks at the Land Ordinance (1785), Northwest Ordinance (1787), the doubled-section grants (1850), the quadrupled-section grants (1894), and the final admissions (1959)."
    >
      {TIMELINE_TICKS.map((t) => (
        <g>
          <text
            x={yearToTimelineX(t.year)}
            y={9}
            text-anchor="middle"
            class="era-timeline-tick-year"
          >
            {t.year}
          </text>
          <text
            x={yearToTimelineX(t.year)}
            y={20}
            text-anchor="middle"
            class="era-timeline-tick-note"
          >
            {t.note}
          </text>
          <line
            x1={yearToTimelineX(t.year)}
            x2={yearToTimelineX(t.year)}
            y1={24}
            y2={32}
            class="era-timeline-tick-line"
          />
        </g>
      ))}
      <rect
        x={TIMELINE_X_LEFT}
        y={32}
        width={TIMELINE_X_RIGHT - TIMELINE_X_LEFT}
        height={14}
        class="era-timeline-bar-bg"
      />
      {FEDERAL_COHORT_SEGMENTS.map((c) => {
        const range = cohortDates[c.key];
        if (!range) return null;
        const x = yearToTimelineX(range.firstYear);
        const w = Math.max(2, yearToTimelineX(range.lastYear) - x);
        return (
          <g>
            <rect
              x={x}
              y={32}
              width={w}
              height={14}
              fill={ERA_COHORT_PALETTE[c.key]}
              class="atlas-state"
              data-category={c.key}
            />
            <text
              x={x + w / 2}
              y={56}
              text-anchor="middle"
              class="era-timeline-chapter-label"
            >
              {c.label}
            </text>
          </g>
        );
      })}
      {cohort2Dates && (
        <g>
          <rect
            x={yearToTimelineX(cohort2Dates.firstYear)}
            y={70}
            width={yearToTimelineX(cohort2Dates.lastYear) - yearToTimelineX(cohort2Dates.firstYear)}
            height={8}
            fill={ERA_COHORT_PALETTE['cohort-2']}
            opacity={0.85}
            class="atlas-state"
            data-category="cohort-2"
          />
          <text
            x={yearToTimelineX((cohort2Dates.firstYear + cohort2Dates.lastYear) / 2)}
            y={92}
            text-anchor="middle"
            class="era-timeline-secondary-label"
          >
            Ch. 2 — State-derived ({cohort2Dates.firstYear}–{cohort2Dates.lastYear})
          </text>
        </g>
      )}
    </svg>
    <div class="timeline-marker-container" data-lens="era-cohort">
      <label class="sr-only" for="timeline-marker">Scrub through history</label>
      <input
        id="timeline-marker"
        type="range"
        min="1787"
        max="1959"
        step="1"
        value="1959"
        aria-valuemin="1787"
        aria-valuemax="1959"
        aria-valuenow="1959"
        aria-valuetext="1959 — all states visible"
        class="timeline-marker"
      />
      <div class="timeline-year-display" id="timeline-year-display">1959</div>
      <p class="timeline-marker-hint text-xs text-slate-500">
        Drag the marker to dim states admitted after that year. Double-click to reset.
      </p>
    </div>
    <p class="era-timeline-caption mt-3 text-xs text-slate-500">
      Federal-trust chapters appear on the main bar in sequence; the
      state-derived chapter (Ch. 2) appears as a secondary band because its
      admissions overlap several federal eras in time. The federal
      school-land floor was one section per township in 1785, doubled in
      1850, and quadrupled in 1894.
    </p>
  </section>

  {/* v9 D.1 — missing-data ornament legend. Library Mode reveals the
      ornament strip; Reference Mode hides it (the table-page text
      already carries the same information). */}
  <aside
    class="atlas-ornament-legend mt-6 rounded-md border border-slate-200 bg-white p-4 text-sm text-slate-600 shadow-sm"
    aria-label="Missing-data ornament legend"
  >
    <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
      Where the map goes quiet
    </p>
    <ul class="mt-3 space-y-2">
      <li class="flex items-start gap-2">
        <img src="/ornaments/empty-shelf.svg" alt="" class="state-ornament" data-ornament="empty-shelf" />
        <span><strong class="font-semibold text-slate-700">Empty shelf</strong> — no audit on file. The state has a federal trust but the figure is not in the public substrate. <a href="/counting/">Counting House</a> marks these "Awaiting Disclosure."</span>
      </li>
      <li class="flex items-start gap-2">
        <img src="/ornaments/ghosted-ledger.svg" alt="" class="state-ornament" data-ornament="ghosted-ledger" />
        <span><strong class="font-semibold text-slate-700">Ghosted ledger</strong> — partial / redacted disclosure. Some figures are published; others are withheld. The ledger exists; the public can't read every entry.</span>
      </li>
      <li class="flex items-start gap-2">
        <img src="/ornaments/locked-drawer.svg" alt="" class="state-ornament" data-ornament="locked-drawer" />
        <span><strong class="font-semibold text-slate-700">Locked drawer</strong> — enabling-act citation chain pending. The state's school-trust statute exists; the substrate has not yet linked it through to its source.</span>
      </li>
    </ul>
  </aside>

    <script>
      import maplibregl from 'maplibre-gl';
      import 'maplibre-gl/dist/maplibre-gl.css';
      import { Protocol, PMTiles, FileSource } from 'pmtiles';
      import * as atlasInteractive from '../scripts/atlas-interactive.mjs';

      const errBox = document.getElementById('map-error');
      const showErr = (label, e) => {
        const msg = `[${label}] ${e?.message ?? e}\n${e?.stack ?? ''}`;
        console.error(label, e);
        if (errBox) {
          errBox.classList.remove('hidden');
          errBox.textContent = (errBox.textContent ? errBox.textContent + '\n\n' : '') + msg;
        }
      };
      window.addEventListener('error', (ev) => showErr('window.error', ev.error || ev.message));
      window.addEventListener('unhandledrejection', (ev) => showErr('unhandledrejection', ev.reason));

      const dataNode = document.getElementById('atlas-data');
      const { lenses, fipsToInfo, lensExplainers } = JSON.parse(dataNode.textContent || '{}');

      const lensesById = Object.fromEntries(lenses.map((l) => [l.id, l]));
      let activeLensId = lenses[0].id;

      // Build FIPS → category map for the active lens (used by the match expr
      // and by hover lookup of displayLabel).
      function fipsCategoryMap(lens) {
        const m = {};
        for (const r of lens.records) m[r.fips] = r;
        return m;
      }
      let activeFipsRecords = fipsCategoryMap(lensesById[activeLensId]);

      function colorForCategory(lens, cat) {
        const entry = lens.categoryColors.find((c) => c.category === cat);
        return entry ? entry.color : '#e2e8f0';
      }

      function buildMatchExpr(lens) {
        const expr = ['match', ['get', 'STATEFP']];
        for (const r of lens.records) {
          expr.push(r.fips, colorForCategory(lens, r.category));
        }
        expr.push('#e2e8f0'); // fallback for non-state polygons (DC, PR)
        return expr;
      }

      function renderLegend(lens) {
        const ol = document.getElementById('legend');
        if (!ol) return;
        ol.innerHTML = '';
        for (const c of lens.categoryColors) {
          const li = document.createElement('li');
          li.className = 'legend-chip-item';
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'legend-chip';
          btn.dataset.lens = lens.id;
          btn.dataset.category = c.category;
          btn.setAttribute('aria-pressed', 'false');
          btn.setAttribute(
            'aria-label',
            `Filter: ${c.legend}. Click to highlight only these states.`,
          );
          btn.style.color = c.color;
          const swatch = document.createElement('span');
          swatch.className = 'legend-swatch';
          swatch.style.background = c.color;
          const label = document.createElement('span');
          label.className = 'legend-chip-label';
          label.textContent = c.legend;
          btn.appendChild(swatch);
          btn.appendChild(label);
          li.appendChild(btn);
          ol.appendChild(li);
        }
      }

      function setLensDescription(lens) {
        const p = document.getElementById('lens-description');
        if (p) p.textContent = lens.description;
      }

      function setLensExplainer(lensId) {
        const ex = lensExplainers && lensExplainers[lensId];
        if (!ex) return;
        const a = document.getElementById('lens-asks');
        const s = document.getElementById('lens-structure');
        const n = document.getElementById('lens-notice');
        if (a) a.textContent = ex.asks;
        if (s) s.textContent = ex.structure;
        if (n) n.textContent = ex.notice;
      }

      // v52 BETA — show the era-cohort timeline strip only when the
      // era-cohort lens is active. The strip is hidden via the `hidden`
      // attribute (display: none) on every other lens.
      function setEraTimelineVisible(lensId) {
        const strip = document.getElementById('era-timeline');
        if (!strip) return;
        if (lensId === 'era-cohort') strip.removeAttribute('hidden');
        else strip.setAttribute('hidden', '');
      }

      const protocol = new Protocol();
      maplibregl.addProtocol('pmtiles', protocol.tile);

      const PMTILES_KEY = '/us-states.pmtiles';
      const PMTILES_URL = `pmtiles://${PMTILES_KEY}`;
      try {
        const resp = await fetch(PMTILES_KEY);
        if (!resp.ok) throw new Error(`fetch ${PMTILES_KEY} → HTTP ${resp.status}`);
        const buf = await resp.arrayBuffer();
        const file = new File([buf], PMTILES_KEY, {
          type: 'application/octet-stream',
        });
        protocol.add(new PMTiles(new FileSource(file)));
      } catch (e) {
        showErr('pmtiles preload', e);
      }

      const map = new maplibregl.Map({
        container: 'map',
        style: {
          version: 8,
          sources: {
            states: {
              type: 'vector',
              url: PMTILES_URL,
              promoteId: 'GEOID',
            },
          },
          layers: [
            {
              id: 'background',
              type: 'background',
              paint: { 'background-color': '#f8fafc' },
            },
            {
              id: 'states-fill',
              type: 'fill',
              source: 'states',
              'source-layer': 'states',
              paint: {
                'fill-color': buildMatchExpr(lensesById[activeLensId]),
                'fill-opacity': [
                  'case',
                  ['boolean', ['feature-state', 'hover'], false],
                  0.95,
                  0.75,
                ],
              },
            },
            {
              id: 'states-outline',
              type: 'line',
              source: 'states',
              'source-layer': 'states',
              paint: {
                'line-color': '#475569',
                'line-width': 0.5,
              },
            },
            {
              id: 'states-outline-hover',
              type: 'line',
              source: 'states',
              'source-layer': 'states',
              paint: {
                'line-color': '#0f172a',
                'line-width': [
                  'case',
                  ['boolean', ['feature-state', 'hover'], false],
                  2,
                  0,
                ],
              },
            },
          ],
        },
        center: [-98.5, 39.5],
        zoom: 3,
        minZoom: 2,
        maxZoom: 6,
        attributionControl: false,
      });

      map.on('error', (e) => showErr('maplibre.error', e?.error || e));

      map.addControl(
        new maplibregl.AttributionControl({
          customAttribution: 'US Census Bureau (cb_2023_us_state_20m)',
          compact: true,
        }),
      );
      map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-right');

      map.on('load', () => {
        map.fitBounds(
          [
            [-125, 24],
            [-66, 50],
          ],
          { padding: 20, animate: false },
        );
      });

      const popup = new maplibregl.Popup({
        closeButton: false,
        closeOnClick: false,
        offset: 6,
      });

      let hoveredFips = null;

      map.on('mousemove', 'states-fill', (e) => {
        if (!e.features || e.features.length === 0) return;
        const f = e.features[0];
        const fips = f.properties.STATEFP;
        const info = fipsToInfo[fips];
        const lensRec = activeFipsRecords[fips];
        const stateName = info?.name ?? f.properties.NAME ?? '';

        if (hoveredFips !== null && hoveredFips !== f.id) {
          map.setFeatureState(
            { source: 'states', sourceLayer: 'states', id: hoveredFips },
            { hover: false },
          );
        }
        if (f.id !== undefined) {
          hoveredFips = f.id;
          map.setFeatureState(
            { source: 'states', sourceLayer: 'states', id: hoveredFips },
            { hover: true },
          );
        }

        map.getCanvas().style.cursor = info ? 'pointer' : 'default';

        const lensLine = lensRec
          ? `<br/><span style="color:#0f172a">${lensRec.displayLabel}</span>`
          : '';
        const html = info
          ? `<div style="font-size:13px;line-height:1.35"><strong>${stateName}</strong>${lensLine}<br/><span style="color:#64748b;font-size:11px">Click to open entry →</span></div>`
          : `<div style="font-size:13px;line-height:1.3"><strong>${stateName}</strong><br/><span style="color:#64748b;font-size:11px">No state dossier</span></div>`;

        popup.setLngLat(e.lngLat).setHTML(html).addTo(map);
      });

      map.on('mouseleave', 'states-fill', () => {
        if (hoveredFips !== null && hoveredFips !== undefined) {
          map.setFeatureState(
            { source: 'states', sourceLayer: 'states', id: hoveredFips },
            { hover: false },
          );
          hoveredFips = null;
        }
        map.getCanvas().style.cursor = '';
        popup.remove();
      });

      map.on('click', 'states-fill', (e) => {
        if (!e.features || e.features.length === 0) return;
        const f = e.features[0];
        const info = fipsToInfo[f.properties.STATEFP];
        if (info) {
          window.location.href = `/reading/${info.iso}/`;
        }
      });

      // v53 — fill-opacity expression. Adds a dim-by-FIPS branch on top of
      // v52's hover-aware default. dimmedFipsList comes from the interactive
      // module via the `atlas:filter-change` custom event.
      let currentDimmedFips = [];
      function buildFillOpacityExpr(dimmedFipsList) {
        const hoverCase = [
          'case',
          ['boolean', ['feature-state', 'hover'], false],
          0.95,
          0.75,
        ];
        if (!dimmedFipsList || dimmedFipsList.length === 0) return hoverCase;
        return [
          'case',
          ['in', ['get', 'STATEFP'], ['literal', dimmedFipsList]],
          0.25,
          ['boolean', ['feature-state', 'hover'], false],
          0.95,
          0.75,
        ];
      }

      function updateMapOpacity() {
        if (map.getLayer && map.getLayer('states-fill')) {
          map.setPaintProperty(
            'states-fill',
            'fill-opacity',
            buildFillOpacityExpr(currentDimmedFips),
          );
        }
      }

      // Lens switcher.
      function setLens(id) {
        const lens = lensesById[id];
        if (!lens) return;
        activeLensId = id;
        activeFipsRecords = fipsCategoryMap(lens);
        if (map.getLayer('states-fill')) {
          map.setPaintProperty('states-fill', 'fill-color', buildMatchExpr(lens));
        }
        renderLegend(lens);
        setLensDescription(lens);
        setLensExplainer(id);
        setEraTimelineVisible(id);
        atlasInteractive.notifyLensChange(id);
      }

      const switcher = document.getElementById('lens-switcher');
      if (switcher) {
        switcher.addEventListener('change', (ev) => {
          const t = ev.target;
          if (t instanceof HTMLInputElement && t.name === 'lens') {
            setLens(t.value);
          }
        });
      }

      // Initial legend.
      renderLegend(lensesById[activeLensId]);

      // v53 — initialize interactive layer with per-lens records (so the
      // engine can compute "states in category X" and "states admitted by
      // year Y"). Listen for filter changes and re-drive maplibre opacity.
      const recordsByLens = {};
      for (const l of lenses) recordsByLens[l.id] = l.records;
      atlasInteractive.init({ records: recordsByLens });

      document.addEventListener('atlas:filter-change', (ev) => {
        currentDimmedFips = (ev.detail && ev.detail.dimmedFips) || [];
        updateMapOpacity();
      });
    </script>

    <style>
      /* v52 BETA — Era-cohort timeline strip. Compact, subordinate to the
         map; tick labels in slate-500, chapter labels in slate-700. */
      .era-timeline-svg {
        max-width: 100%;
        height: auto;
      }
      .era-timeline-tick-year {
        font-family: var(--font-sans);
        font-size: 9px;
        font-weight: 600;
        fill: #334155;
      }
      .era-timeline-tick-note {
        font-family: var(--font-sans);
        font-size: 8px;
        fill: #64748b;
      }
      .era-timeline-tick-line {
        stroke: #cbd5e1;
        stroke-width: 1;
      }
      .era-timeline-bar-bg {
        fill: #f1f5f9;
      }
      .era-timeline-chapter-label {
        font-family: var(--font-sans);
        font-size: 9px;
        font-weight: 600;
        fill: #334155;
      }
      .era-timeline-secondary-label {
        font-family: var(--font-sans);
        font-size: 9px;
        fill: #64748b;
      }
    </style>
</RoomLayout>

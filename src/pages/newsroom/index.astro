---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsroomSubscribeForm from '../../components/NewsroomSubscribeForm.astro';

const entries = (await getCollection('newsroom')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const recent = entries.slice(0, 5);
const onlyOne = recent.length === 1;

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title="Newsroom · America's School Trust Library"
  description="Weekly survey of what changed in school trust lands across the United States. RSS feed weekly; monthly email digest from July 2026."
  sourceId="newsroom-index"
  room="newsroom"
>
  <Fragment slot="head">
    <link
      rel="alternate"
      type="application/rss+xml"
      title="America's School Trust Library — Newsroom"
      href="/newsroom/rss.xml"
    />
  </Fragment>

  <article class="prose prose-slate max-w-none prose-a:text-blue-700 prose-a:underline">
    <h1>Newsroom</h1>
    <p class="kicker">
      What changed in school trust lands across the United States this week.
      Weekly entries every Monday. Monthly email digest on the first Monday
      of each month.
    </p>

    <h2>Subscribe</h2>

    <p>
      <strong>Weekly entries — by RSS.</strong> The Newsroom emits an RSS
      feed at <a href="/newsroom/rss.xml">/newsroom/rss.xml</a>. Add it to
      any RSS reader (Feedly, NetNewsWire, Inoreader, your browser of
      choice) and the weekly entries arrive there each Monday.
    </p>

    <p>
      <strong>Monthly digest — by email.</strong> A 600-to-900-word email
      distillation of each month's weekly entries, sent on the first Monday
      of the following month. Free. The list is curated and modest in size,
      intended for readers who want one short account each month of what
      shifted in this beat across the fifty states.
    </p>

    <NewsroomSubscribeForm />

    <p class="newsroom-subscribe-note">
      <em>
        The signup form above collects names and email addresses for the
        monthly digest list. The first issue is targeted for early July
        2026; subscribers receive that issue and every monthly thereafter.
        The list will move to Buttondown when subscriber count crosses
        fifty; current subscribers transfer with consent.
      </em>
    </p>

    <h2>Recent entries</h2>

    {recent.length === 0 ? (
      <p>
        <em>No entries published yet. The first weekly entry lands Monday.</em>
      </p>
    ) : (
      <ul class="not-prose newsroom-recent">
        {recent.map((entry) => (
          <li class="newsroom-card">
            <p class="newsroom-card__date">
              {dateFormatter.format(entry.data.date)}
            </p>
            <h3 class="newsroom-card__title">
              <a href={`/newsroom/${entry.slug}/`}>{entry.data.title}</a>
            </h3>
            <p class="newsroom-card__kicker" set:html={entry.data.kicker} />
            <p class="newsroom-card__read">
              <a href={`/newsroom/${entry.slug}/`}>
                Read the full entry →
              </a>
            </p>
          </li>
        ))}
      </ul>
    )}

    {onlyOne && (
      <p class="newsroom-recent-note">
        <em>More entries coming each Monday.</em>
      </p>
    )}

    {/* TODO: link to /newsroom/archive/ once that page exists (entry count
        crosses ~10). For now the recent-entries block carries everything. */}

    <h2>About this Newsroom</h2>

    <p>
      The Newsroom is one of three editorial surfaces in this library. The
      <a href="/reading/">Reading Room</a> holds the long-form synthesis —
      the encyclopedia entries, the white papers, the three book-length
      works. The <a href="/voices/">Voices</a> section carries signed
      first-person editorial pieces by named contributors. The Newsroom
      does neither of those jobs. It reports — third person, neutral,
      sourced — on what trustees, courts, and legislators have already
      done.
    </p>

    <p>
      Each Monday, an AI surveillance pass walks a defined source list
      (state land-management agencies, state legislatures, court dockets,
      regional press, academic and policy watchers, ASTL movement signal,
      the editor's curated inbox), drafts a candidate weekly summary, and
      hands it to a named human editor for review. Nothing publishes
      without that review. Confidence badges appear on every item. Items
      rated <em>major</em> require a two-source rule. Corrections are made
      in place with a dated correction note; the repository's history
      preserves the original.
    </p>

    <p>
      Quiet weeks are reported as quiet weeks. Padding low-grade items into
      a weekly is how a Newsroom slides into low-credibility content. The
      Newsroom that admits its quiet weeks earns the credibility to ring
      the bell loudly on a major week.
    </p>

    <p>
      <strong>Full methodology, source list, and editorial standards:</strong>
      <a href="/newsroom/about/">About the Newsroom →</a>
    </p>

    <hr class="archival-divider" />

    <p class="text-sm text-slate-600">
      <em>Editor: Dave Sullivan, President, Oregon Advocates for School Trust Lands.</em><br />
      <em>
        Newsroom drafts are generated by an AI surveillance pass over a
        defined source set. Every published entry has been reviewed and
        edited by a named human editor before publication.
      </em>
    </p>
  </article>

  <style>
    .kicker {
      font-family: var(--font-sans);
      font-size: 0.95rem;
      color: var(--ink);
      opacity: 0.85;
      margin: 0 0 1.5rem;
      max-width: 60ch;
    }
    .newsroom-subscribe-note {
      max-width: 60ch;
      font-size: 0.88rem;
      color: var(--ink);
      opacity: 0.75;
      margin: 0 0 2rem;
    }
    .newsroom-recent {
      list-style: none;
      margin: 0 0 1.5rem;
      padding: 0;
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .newsroom-card {
      padding: 1rem 1.25rem;
      background: var(--linen-card, #fffdf7);
      border: 1px solid var(--rule-border, #d8d1c2);
      border-radius: 4px;
    }
    .newsroom-card__date {
      font-family: var(--font-sans);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--old-gold, #b88a2e);
      margin: 0 0 0.35rem;
    }
    .newsroom-card__title {
      font-family: var(--font-serif);
      font-size: 1.15rem;
      font-weight: 700;
      line-height: 1.25;
      margin: 0 0 0.45rem;
      color: var(--deep-navy, #1f2a44);
    }
    .newsroom-card__title a {
      color: inherit;
      text-decoration: none;
    }
    .newsroom-card__title a:hover {
      text-decoration: underline;
    }
    .newsroom-card__kicker {
      font-size: 0.95rem;
      line-height: 1.55;
      margin: 0 0 0.5rem;
      color: var(--ink, #17202a);
    }
    .newsroom-card__read {
      margin: 0;
      font-family: var(--font-sans);
      font-size: 0.88rem;
    }
    .newsroom-recent-note {
      margin: 0 0 2rem;
      font-size: 0.9rem;
      color: var(--ink, #17202a);
      opacity: 0.75;
    }
  </style>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsroomSubscribeForm from '../../components/NewsroomSubscribeForm.astro';

const entries = (await getCollection('newsroom')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const recent = entries.slice(0, 5);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title="Newsroom · America's School Trust Library"
  description="A weekly survey of what changed in America's school trust lands."
  sourceId="newsroom-index"
  room="newsroom"
>
  <Fragment slot="head">
    <link
      rel="alternate"
      type="application/rss+xml"
      title="America's School Trust Library — Newsroom"
      href="/newsroom/rss.xml"
    />
  </Fragment>

  <article class="prose prose-slate max-w-none prose-a:text-blue-700 prose-a:underline">
    <h1>Newsroom</h1>
    <p class="kicker">
      A weekly survey of what changed in America's school trust lands.
    </p>

    <h2>Subscribe by email</h2>

    <NewsroomSubscribeForm />

    <p class="newsroom-subscribe-note">
      Issues arrive every Monday. Free. Unsubscribe with one click. Replies
      go directly to the editor.
    </p>

    <h2>Recent issues</h2>

    {recent.length === 0 ? (
      <p>
        <em>No entries published yet. The first weekly entry lands Monday.</em>
      </p>
    ) : (
      <ul class="not-prose newsroom-recent">
        {recent.map((entry) => (
          <li class="newsroom-card">
            <p class="newsroom-card__date">
              {dateFormatter.format(entry.data.date)}
            </p>
            <h3 class="newsroom-card__title">
              <a href={`/newsroom/${entry.slug}/`}>{entry.data.title}</a>
            </h3>
            <p class="newsroom-card__kicker" set:html={entry.data.kicker} />
            <p class="newsroom-card__read">
              <a href={`/newsroom/${entry.slug}/`}>
                Read the full entry →
              </a>
            </p>
          </li>
        ))}
      </ul>
    )}

    {/* TODO: /newsroom/archive/ page does not yet exist; link harmlessly
        404s until entry count crosses ~10 and the archive page lands. */}
    <p class="newsroom-archive-link">
      <a href="/newsroom/archive/">Browse the full archive →</a>
    </p>

    <hr class="archival-divider" />

    <p class="newsroom-foot">
      Also available via <strong>RSS</strong> at
      <a href="/newsroom/rss.xml">/newsroom/rss.xml</a>. For details on what
      we cover, how we source it, and how the Newsroom is made:
      <a href="/newsroom/about/">About the Newsroom →</a>
    </p>
  </article>

  <style>
    .kicker {
      font-family: var(--font-sans);
      font-size: 0.95rem;
      color: var(--ink);
      opacity: 0.85;
      margin: 0 0 1.5rem;
      max-width: 60ch;
    }
    .newsroom-subscribe-note {
      max-width: 60ch;
      font-size: 0.88rem;
      color: var(--ink);
      opacity: 0.75;
      margin: 0 0 2rem;
    }
    .newsroom-recent {
      list-style: none;
      margin: 0 0 1.5rem;
      padding: 0;
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .newsroom-card {
      padding: 1rem 1.25rem;
      background: var(--linen-card, #fffdf7);
      border: 1px solid var(--rule-border, #d8d1c2);
      border-radius: 4px;
    }
    .newsroom-card__date {
      font-family: var(--font-sans);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--old-gold, #b88a2e);
      margin: 0 0 0.35rem;
    }
    .newsroom-card__title {
      font-family: var(--font-serif);
      font-size: 1.15rem;
      font-weight: 700;
      line-height: 1.25;
      margin: 0 0 0.45rem;
      color: var(--deep-navy, #1f2a44);
    }
    .newsroom-card__title a {
      color: inherit;
      text-decoration: none;
    }
    .newsroom-card__title a:hover {
      text-decoration: underline;
    }
    .newsroom-card__kicker {
      font-size: 0.95rem;
      line-height: 1.55;
      margin: 0 0 0.5rem;
      color: var(--ink, #17202a);
    }
    .newsroom-card__read {
      margin: 0;
      font-family: var(--font-sans);
      font-size: 0.88rem;
    }
    .newsroom-archive-link {
      margin: 0 0 1.75rem;
      font-family: var(--font-sans);
      font-size: 0.92rem;
    }
    .newsroom-foot {
      font-size: 0.92rem;
      color: var(--ink);
      opacity: 0.85;
      max-width: 65ch;
    }
  </style>
</BaseLayout>

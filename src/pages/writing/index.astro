---
// Writing Room book shelf. Each book card and durable book link is driven by
// src/data/writingBookRegistry.ts so draft files can move without breaking
// public links.
import RoomLayout from '../../layouts/RoomLayout.astro';
import { writingBooks, type WritingBook } from '../../data/writingBookRegistry';

const frontShelfSlugs = [
  'how-the-library-works',
  'forgotten-forever-gift',
  'school-trust-lands-hornbook',
  'who-steals-from-children',
  'make-school-trusts-for-schools',
];

const frontShelf = frontShelfSlugs
  .map((slug) => writingBooks.find((book) => book.slug === slug))
  .filter(Boolean) as WritingBook[];

const workshopBooks = writingBooks.filter((book) => !frontShelfSlugs.includes(book.slug));

const frontShelfTitles: Record<string, string> = {
  'school-trust-lands-hornbook': 'The legal reference manual',
};

const workshopMeta: Record<string, { type: string; state: string }> = {
  'school-trust-rebirth': {
    type: 'roadmap brief',
    state: 'working public draft for close reviewers',
  },
  'law-that-says-nothing-new': {
    type: 'public repair booklet',
    state: 'working public draft',
  },
  'uptea-for-lawyers': {
    type: 'model-law guide',
    state: 'convergence draft for legal testing',
  },
  'case-waiting-for-you': {
    type: 'lawyer recruitment booklet',
    state: 'planned booklet',
  },
  'help-us-keep-the-books': {
    type: 'librarian recruitment booklet',
    state: 'planned booklet',
  },
  'stewards-of-the-republic': {
    type: 'forward-looking design book',
    state: 'development draft with known issues disclosed',
  },
  'trustees-handbook': {
    type: 'trustee practice handbook',
    state: 'planned handbook',
  },
  'useful-life': {
    type: 'formation-story booklet',
    state: 'working public-facing draft',
  },
  'accidental-plaintiff': {
    type: 'Oregon origin booklet',
    state: 'working public-facing draft',
  },
};

function shelfTitle(book: WritingBook) {
  return frontShelfTitles[book.slug] ?? book.title;
}

function workshopType(book: WritingBook) {
  return workshopMeta[book.slug]?.type ?? book.kicker.toLowerCase();
}

function workshopState(book: WritingBook) {
  return workshopMeta[book.slug]?.state ?? book.status;
}
---

<RoomLayout
  room="writing"
  title="Writing Room"
  subtitle="The books being written, in the open."
  width="full"
  sourceId="writing-index"
>
  <div class="writing-intro prose prose-slate max-w-none prose-a:text-blue-700 prose-a:underline">
    <p>
      This room holds the public-facing work the Library is actively writing.
      The drafts are real: they argue, they cite, they make their case. They
      are also openly unfinished. Some are ready for friends and close readers;
      some are scaffolds for a book that is still being assembled; none should
      be mistaken for board approval, legal advice, or gospel.
    </p>
    <p>
      The point of putting them here is stability. A draft may begin as a Word
      file, become a web book, move to a Reading Room shelf, or later be
      republished by a partner. The Writing Room book page stays the public
      address. Link to the book page, not to the temporary file behind it.
    </p>
    <p>
      The front shelf is intentionally narrow: five pieces that orient a new
      reader, carry the national history, make the law usable, show the present
      record, and translate repair into citizen action. Other booklets are still
      open below, but as workshop entries rather than full cards.
    </p>
  </div>

  <section id="book-family" class="books mt-10" aria-labelledby="books-heading">
    <div class="section-head">
      <h2 id="books-heading" class="section-heading">Front shelf</h2>
      <p class="section-intro">
        Start here. Each card names what the work is, how finished it is, and
        where its durable Writing Room gateway lives.
      </p>
      <p class="stable-link-note">
        Use the "Stable book link" for citations, emails, and review packets.
        The linked gateway page will keep pointing readers to the right draft
        or long-term home as the publication matures.
      </p>
    </div>

    <div class="book-grid">
      {frontShelf.map((book) => (
        <article class="book-card">
          <p class="card-kicker">{book.kicker}</p>
          <h3 class="card-title">
            <a href={`/writing/books/${book.slug}/`}>
              {book.slug === 'school-trust-lands-hornbook' ? (
                <>
                  <span>{shelfTitle(book)}</span>
                  <small><em>{book.title}</em></small>
                </>
              ) : (
                <em>{book.title}</em>
              )}
            </a>
          </h3>
          <p class="card-byline">{book.byline}</p>
          <p class="card-blurb">{book.blurb}</p>
          <p class="card-status">Status: {book.status}</p>
          <p class="card-bridge">{book.fit}</p>
          <div class="card-cta-row">
            <a href={`/writing/books/${book.slug}/`} class="card-cta">Stable book link -&gt;</a>
            {book.currentHref && (
              <a href={book.currentHref} class="card-cta">{book.ctaLabel ?? 'Current home'} -&gt;</a>
            )}
            {!book.currentHref && book.draftHref && (
              <a href={book.draftHref} class="card-cta">{book.draftLabel ?? 'Current draft'} -&gt;</a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="workshop mt-10" aria-labelledby="workshop-heading">
    <div class="section-head">
      <h2 id="workshop-heading" class="section-heading">In the workshop</h2>
      <p class="section-intro">
        These pieces keep their stable Writing Room gateways, but they are not
        the first shelf for a new reader.
      </p>
    </div>
    <ul class="workshop-list">
      {workshopBooks.map((book) => (
        <li>
          <a href={`/writing/books/${book.slug}/`}><em>{book.title}</em></a>
          <span class="workshop-type">{workshopType(book)}</span>
          <span class="workshop-state">{workshopState(book)}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="dispatches mt-10" aria-labelledby="dispatches-heading">
    <h2 id="dispatches-heading" class="section-heading">Dispatches: write for the Library</h2>
    <div class="prose prose-slate max-w-none prose-a:text-blue-700 prose-a:underline">
      <p>
        Seen a school-trust harm, or a win, firsthand? Send us the story and
        the documents. The Library fact-checks every dispatch against primary
        sources and publishes it at house standard: your byline, our
        verification. Recurring contributors are invited into State
        Correspondent roles.
        <a href="/writing/dispatches/">How to contribute &rarr;</a>
      </p>
    </div>
  </section>

  <section class="methods mt-10" aria-labelledby="methods-heading">
    <h2 id="methods-heading" class="section-heading">Citations, footnotes, and verification</h2>
    <div class="prose prose-slate max-w-none prose-a:text-blue-700 prose-a:underline">
      <p>
        Everything written in this room runs on one verification system. Every
        authority, every case, statute, report, and archive, lives in a single
        register that records whether we hold the original document and have
        checked our quotation and page citation against it. Where a citation is
        still being verified, the draft says so with a visible flag rather
        than passing the claim off as settled. Our own books and model
        legislation are never cited as evidence for anything.
      </p>
      <p>
        When checking finds an error, the text is corrected and the correction
        is published, not buried. This week's verification pass removed a
        famous quotation that turned out not to exist in the opinion it is
        always attributed to, corrected a billion-dollar state fund figure
        that was really a forecast, and retired a widely repeated statistic no
        survey supports.
      </p>
      <p>
        <a href="/writing/how-we-check-our-work/">Read the full method, and
        what it caught, here &rarr;</a>
      </p>
    </div>
  </section>

</RoomLayout>

<style>
  .writing-intro,
  .section-head {
    max-width: 72ch;
  }

  .section-heading {
    font-family: var(--font-serif, Georgia, serif);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--deep-navy, #1e3a5f);
    margin: 0 0 1rem;
  }

  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 20rem), 1fr));
    gap: 1rem;
    align-items: stretch;
  }

  .book-card,
  .essay-card {
    background: var(--linen-card, #fafaf7);
    border: 1px solid var(--rule-border, #e5e7eb);
    border-left: 3px solid var(--old-gold, #8b7355);
    border-radius: 4px;
    padding: 1.5rem 1.5rem 1.25rem;
    margin: 0 0 1.25rem;
    display: flex;
    flex-direction: column;
  }

  .book-card {
    min-height: 100%;
  }

  .card-kicker {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--old-gold, #8b7355);
    margin: 0 0 0.5rem;
  }

  .card-title {
    font-family: var(--font-serif, Georgia, serif);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--deep-navy, #1e3a5f);
    line-height: 1.35;
    margin: 0 0 0.4rem;
  }

  .card-title a {
    display: grid;
    gap: 0.15rem;
    color: var(--deep-navy, #1e3a5f);
    text-decoration: none;
  }

  .card-title small {
    font-family: var(--font-sans, system-ui, sans-serif);
    font-size: 0.82rem;
    font-weight: 500;
    color: #475569;
  }

  .card-title a:hover {
    text-decoration: underline;
  }

  .card-byline {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: #475569;
    margin: 0 0 0.35rem;
  }

  .card-blurb {
    font-size: 0.95rem;
    line-height: 1.55;
    color: #334155;
    margin: 0 0 1rem;
  }

  .card-status {
    font-size: 0.85rem;
    font-style: italic;
    color: var(--ink-soft, #475569);
    margin: 0 0 0.75rem;
  }

  .card-bridge {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    line-height: 1.45;
    color: #64748b;
    font-style: italic;
    margin: auto 0 1rem;
  }

  .card-cta {
    align-self: flex-start;
    color: #1d4ed8;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .card-cta:hover {
    color: #1e40af;
  }

  .card-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1.25rem;
    margin: 0;
  }

  .section-intro {
    font-size: 0.95rem;
    line-height: 1.55;
    color: #334155;
    margin: 0 0 0.75rem;
  }

  .stable-link-note {
    margin: 0 0 1.5rem;
    padding: 0.8rem 1rem;
    border: 1px solid #d8c18b;
    border-left: 4px solid var(--old-gold, #8b7355);
    border-radius: 4px;
    background: #fff8df;
    color: #422006;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .workshop-list {
    max-width: 70rem;
    display: grid;
    gap: 0;
    padding: 0;
    margin: 0;
    list-style: none;
    border-top: 1px solid #e2e8f0;
  }

  .workshop-list li {
    display: grid;
    grid-template-columns: minmax(14rem, 1.2fr) minmax(9rem, 0.7fr) minmax(14rem, 1fr);
    gap: 0.75rem 1rem;
    align-items: baseline;
    padding: 0.85rem 0;
    border-bottom: 1px solid #e2e8f0;
  }

  .workshop-list a {
    color: var(--deep-navy, #1e3a5f);
    font-family: var(--font-serif, Georgia, serif);
    font-weight: 600;
    text-decoration: none;
  }

  .workshop-list a:hover {
    text-decoration: underline;
  }

  .workshop-type,
  .workshop-state {
    font-family: var(--font-sans, system-ui, sans-serif);
    font-size: 0.88rem;
    line-height: 1.4;
    color: #475569;
  }

  .workshop-type {
    font-weight: 700;
    color: #334155;
  }

  @media (max-width: 760px) {
    .workshop-list li {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>

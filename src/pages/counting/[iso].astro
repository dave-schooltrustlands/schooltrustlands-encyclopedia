---
import RoomLayout from '../../layouts/RoomLayout.astro';
import StateDossier from '../../components/StateDossier.astro';
import financeData from '../../data/finance/states.json';

type FinanceRecord = {
  stateIso: string;
  fips: string;
  displayName: string;
  eraCohort: string;
  eraCohortNumber: number;
  governanceForm: string;
  governanceDescription: string;
  corpus: { value: number | null; asOf: string | null; confidence: string; source: string | null };
  distribution: { value: number | null; fiscalYear: string | null; confidence: string; source: string | null };
  transparency: { status: string; source: string | null };
  federalGrantAcres: { value: number; confidence: string };
  substrateVersion: string;
  lastReviewed: string;
};

const records = financeData as FinanceRecord[];

export async function getStaticPaths() {
  const recs = (await import('../../data/finance/states.json')).default as FinanceRecord[];
  return recs.map((r) => ({
    params: { iso: r.stateIso },
    props: { record: r },
  }));
}

const { record } = Astro.props as { record: FinanceRecord };

const usd = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
const num = new Intl.NumberFormat('en-US');

const govLabels: Record<string, string> = {
  SLB: 'State Land Board (ex officio)',
  DSL: 'Single elected/appointed commissioner',
  'land-grant-trust': 'Distributed (no unified board)',
  'no-trust': 'No federal trust (state-derived)',
};

const transparencyLabels: Record<string, string> = {
  'data-published': 'Corpus and distribution disclosed',
  'data-partially-published': 'Partially disclosed',
  unknown: 'Disclosure unknown',
  'never-had-trust': 'No federal trust to disclose',
};

const transparencyDescriptions: Record<string, string> = {
  'data-published': 'Both the permanent fund corpus and the most recent distribution figure are present in the substrate.',
  'data-partially-published': 'One of corpus or recent distribution is present in the substrate; the other has not yet been disclosed or extracted.',
  unknown: 'The state has a federal trust but neither corpus nor recent distribution is in the substrate yet. Awaiting state disclosure or future substrate work.',
  'never-had-trust': 'State-derived: never received a federal admission grant, so there is no federal-trust corpus to publish. (The state may still have its own state-derived fund or other school-finance instruments.)',
};

const isStateDerived = record.federalGrantAcres.value === 0;

// Confidence chip styling — kept consistent with the table page.
const confidenceClasses: Record<string, string> = {
  verified: 'bg-emerald-50 text-emerald-800',
  'awaiting-disclosure': 'bg-orange-50 text-orange-800',
  'source-conflict': 'bg-amber-50 text-amber-800',
  'not-applicable': 'bg-slate-100 text-slate-500',
};

const confidenceLabels: Record<string, string> = {
  verified: 'Verified',
  'awaiting-disclosure': 'Awaiting State Disclosure',
  'source-conflict': 'Source conflict',
  'not-applicable': 'Not applicable',
};
---

<RoomLayout
  room="counting"
  state={{ iso: record.stateIso, name: record.displayName }}
  title={`${record.displayName} financial profile`}
  subtitle={`${record.eraCohort} (cohort ${record.eraCohortNumber}) · ${govLabels[record.governanceForm]}`}
  width="prose"
  sourceId={`finance-${record.stateIso}-v${record.substrateVersion}`}
>
  <p class="mt-3 text-xs text-slate-500">
    Substrate v{record.substrateVersion} · Last reviewed {record.lastReviewed} ·{' '}
    <a href={`/reading/${record.stateIso}/`} class="text-blue-700 underline hover:text-blue-900">Read the encyclopedia entry</a>
  </p>

  {isStateDerived && (
    <section class="mt-8 rounded-md border border-slate-200 bg-slate-50 p-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-600">
        State-derived: no federal admission grant
      </h2>
      <p class="mt-2 text-slate-700">
        {record.displayName} entered the Union without a federal school-land grant — either because
        it predated the federal land-grant template (the Original 13) or because it was admitted
        under a different model (annexation by treaty, cession from a parent state, statehood from
        a sovereign republic). Counting House measures the federal-trust architecture; for
        {' '}{record.displayName} that architecture was never built. The state's own school-finance
        instruments (general appropriations, local property tax, in some cases a state-derived
        endowment) live elsewhere in the encyclopedia.
      </p>
    </section>
  )}

  <section class="mt-8">
    <h2 class="text-xl font-semibold tracking-tight">Permanent fund corpus</h2>
    <div class="mt-3 flex items-baseline gap-3">
      <span class="text-3xl font-semibold tabular-nums">
        {record.corpus.value !== null ? usd.format(record.corpus.value) : '—'}
      </span>
      <span class:list={['inline-flex items-center rounded px-2 py-0.5 text-xs font-medium', confidenceClasses[record.corpus.confidence]]}>
        {confidenceLabels[record.corpus.confidence]}
      </span>
    </div>
    {record.corpus.asOf && (
      <p class="mt-1 text-sm text-slate-500">As of {record.corpus.asOf}</p>
    )}
    {record.corpus.confidence === 'awaiting-disclosure' && (
      <p class="mt-2 text-sm text-slate-700">
        The substrate doesn't yet have a verified corpus value for {record.displayName}. This is
        a known gap in the editorial workstream (B-025 hand-curation pass), not an indication that
        no fund exists.
      </p>
    )}
  </section>

  <section class="mt-8">
    <h2 class="text-xl font-semibold tracking-tight">Most recent distribution</h2>
    <div class="mt-3 flex items-baseline gap-3">
      <span class="text-3xl font-semibold tabular-nums">
        {record.distribution.value !== null ? usd.format(record.distribution.value) : '—'}
      </span>
      <span class:list={['inline-flex items-center rounded px-2 py-0.5 text-xs font-medium', confidenceClasses[record.distribution.confidence]]}>
        {confidenceLabels[record.distribution.confidence]}
      </span>
    </div>
    {record.distribution.fiscalYear && (
      <p class="mt-1 text-sm text-slate-500">Fiscal year {record.distribution.fiscalYear}</p>
    )}
  </section>

  <section class="mt-8">
    <h2 class="text-xl font-semibold tracking-tight">Federal grant acreage</h2>
    <div class="mt-3 flex items-baseline gap-3">
      <span class="text-3xl font-semibold tabular-nums">
        {record.federalGrantAcres.value > 0 ? `${num.format(record.federalGrantAcres.value)} acres` : '—'}
      </span>
      <span class:list={['inline-flex items-center rounded px-2 py-0.5 text-xs font-medium', confidenceClasses[record.federalGrantAcres.confidence]]}>
        {confidenceLabels[record.federalGrantAcres.confidence]}
      </span>
    </div>
  </section>

  <section class="mt-8">
    <h2 class="text-xl font-semibold tracking-tight">Transparency status</h2>
    <p class="mt-3">
      <span class="rounded-md bg-slate-100 px-2 py-1 text-sm font-medium text-slate-800">
        {transparencyLabels[record.transparency.status]}
      </span>
    </p>
    <p class="mt-3 text-slate-700">
      {transparencyDescriptions[record.transparency.status]}
    </p>
  </section>

  <section class="mt-8">
    <h2 class="text-xl font-semibold tracking-tight">Governance form</h2>
    <p class="mt-3 text-sm text-slate-600">
      Classification: <span class="font-medium text-slate-800">{govLabels[record.governanceForm]}</span>
    </p>
    <p class="mt-3 text-slate-700">
      {record.governanceDescription}
    </p>
  </section>

  <section class="mt-12">
    <StateDossier iso={record.stateIso} name={record.displayName} />
  </section>
</RoomLayout>
